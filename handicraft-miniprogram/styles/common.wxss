/* ---------- 边框和圆角类 ---------- */

.rounded-sm { border-radius: 8rpx; }
.rounded-md { border-radius: 16rpx; }
.rounded-lg { border-radius: 24rpx; }
.rounded-xl { border-radius: 32rpx; }
.rounded-full { border-radius: 9999rpx; }

.border { border: 1rpx solid #E8E8E8; }
.border-top { border-top: 1rpx solid #E8E8E8; }
.border-bottom { border-bottom: 1rpx solid #E8E8E8; }
.border-left { border-left: 1rpx solid #E8E8E8; }
.border-right { border-right: 1rpx solid #E8E8E8; }

/* ---------- 背景色类 ---------- */

.bg-white { background-color: #FFFFFF; }
.bg-page { background-color: #FFF8E7; }
.bg-gray { background-color: #F5F5F5; }
.bg-primary { background-color: #E67E22; }
.bg-primary-light { background-color: rgba(230, 126, 34, 0.1); }
.bg-success { background-color: #27AE60; }
.bg-warning { background-color: #F39C12; }
.bg-error { background-color: #E74C3C; }

/* ---------- 显示类 ---------- */

.hidden { display: none !important; }
.visible { display: block !important; }

/* ---------- 位置类 ---------- */

.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.sticky { position: sticky; }

/* ---------- 其他实用类 ---------- */

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.img-full { width: 100%; height: 100%; }
.img-cover { width: 100%; height: 100%; object-fit: cover; }

.divider { height: 1rpx; background-color: #F0E6D2; margin: 0 32rpx; }
.divider-full { height: 1rpx; background-color: #F0E6D2; }

.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin: 16rpx 32rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(93, 64, 55, 0.08);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  height: 80rpx;
  line-height: 80rpx;
}

.btn-primary { background-color: #E67E22; color: #FFFFFF; }
.btn-primary::after { border: none; }

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #E67E22;
  color: #E67E22;
}
.btn-outline::after { border: none; }

.btn-disabled { background-color: #BCAAA4; color: #FFFFFF; }

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.tag-primary { background-color: rgba(230, 126, 34, 0.1); color: #E67E22; }
.tag-success { background-color: rgba(39, 174, 96, 0.1); color: #27AE60; }
.tag-warning { background-color: rgba(243, 156, 18, 0.1); color: #F39C12; }
.tag-error { background-color: rgba(231, 76, 60, 0.1); color: #E74C3C; }
