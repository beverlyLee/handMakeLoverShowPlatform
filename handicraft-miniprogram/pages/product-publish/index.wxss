/* pages/product-publish/index.wxss */

.product-publish-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 140rpx;
}

.image-section {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.section-title .required {
  color: #E74C3C;
  margin-left: 4rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #F5F5F5;
  position: relative;
  overflow: hidden;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #FFFFFF;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #D2B48C;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #FFFAF0;
}

.add-icon {
  font-size: 48rpx;
  color: #D2B48C;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #BCAAA4;
}

.image-tip {
  font-size: 22rpx;
  color: #BCAAA4;
  margin-top: 16rpx;
}

.form-section {
  background-color: #FFFFFF;
  margin-bottom: 16rpx;
}

.form-item {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0E6D2;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: #5D4037;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.form-label .required {
  color: #E74C3C;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #5D4037;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #BCAAA4;
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.6;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #BCAAA4;
}

.textarea-count {
  text-align: right;
  font-size: 22rpx;
  color: #BCAAA4;
  margin-top: 12rpx;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.form-col {
  flex: 1;
}

.price-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
}

.price-symbol {
  font-size: 32rpx;
  color: #E67E22;
  font-weight: 600;
  margin-right: 8rpx;
}

.price-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #5D4037;
}

.price-input::placeholder {
  color: #BCAAA4;
}

.picker-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #5D4037;
}

.picker-text.placeholder {
  color: #BCAAA4;
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #BCAAA4;
  border-right: 2rpx solid #BCAAA4;
  transform: rotate(45deg);
}

.switch-section {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-label {
  font-size: 28rpx;
  color: #5D4037;
}

.switch-desc {
  font-size: 24rpx;
  color: #BCAAA4;
  margin-top: 8rpx;
}

.save-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
  z-index: 100;
  padding-bottom: calc(0rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(0rpx + env(safe-area-inset-bottom));
}
