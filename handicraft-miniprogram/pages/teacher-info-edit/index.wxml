<view class="edit-container">
  <view class="edit-header">
    <view class="header-icon">✏️</view>
    <text class="header-title">修改入驻信息</text>
    <text class="header-desc">完善您的个人资料，展示专业形象</text>
  </view>

  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">📋</text>
      <text class="title-text">基本信息</text>
      <text class="required-mark">*</text>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">真实姓名</text>
        <text class="required-mark">*</text>
      </view>
      <input 
        class="form-input" 
        placeholder="请输入真实姓名" 
        value="{{formData.real_name}}"
        data-field="real_name"
        bindinput="onInputChange"
        maxlength="20"
      />
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">身份证号</text>
        <text class="required-mark">*</text>
      </view>
      <input 
        class="form-input form-input-disabled" 
        placeholder="身份证号" 
        value="{{formData.id_card}}"
        disabled
      />
      <text class="form-hint">身份证号已隐藏，如需修改请联系客服</text>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">联系电话</text>
        <text class="required-mark">*</text>
      </view>
      <input 
        class="form-input form-input-disabled" 
        placeholder="手机号" 
        value="{{formData.phone}}"
        disabled
      />
      <text class="form-hint">手机号已隐藏，如需修改请联系客服</text>
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">✨</text>
      <text class="title-text">擅长领域</text>
      <text class="required-mark">*</text>
    </view>

    <view class="form-item form-item-picker" bindtap="toggleSpecialtyPicker">
      <view class="form-label">
        <text class="label-text">选择擅长领域</text>
      </view>
      <view class="picker-value">
        <text class="{{formData.specialties.length > 0 ? 'picker-text' : 'picker-placeholder'}}">
          {{formData.specialties.length > 0 ? formData.specialties.join('、') : '请选择擅长领域'}}
        </text>
        <text class="picker-arrow">›</text>
      </view>
    </view>

    <view class="selected-tags" wx:if="{{formData.specialties.length > 0}}">
      <view class="tag-item" wx:for="{{formData.specialties}}" wx:key="*this">
        <text class="tag-text">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">
      <text class="title-icon">📝</text>
      <text class="title-text">个人简介</text>
    </view>

    <view class="form-item form-item-textarea">
      <textarea 
        class="form-textarea" 
        placeholder="请介绍您的手作经历、教学经验等（选填）" 
        value="{{formData.intro}}"
        data-field="intro"
        bindinput="onInputChange"
        maxlength="500"
        auto-height
      />
    </view>
  </view>

  <view class="submit-section">
    <button 
      class="submit-btn {{isSubmitting ? 'submit-btn-disabled' : ''}}" 
      bindtap="submitForm"
      disabled="{{isSubmitting}}"
    >
      <text class="submit-text">{{isSubmitting ? '保存中...' : '保存修改'}}</text>
    </button>
  </view>
</view>

<view class="specialty-picker-mask" wx:if="{{showSpecialtyPicker}}" catchtouchmove="preventMove">
  <view class="specialty-picker">
    <view class="picker-header">
      <text class="picker-title">选择擅长领域</text>
      <view class="picker-confirm" bindtap="confirmSpecialty">
        <text class="confirm-text">确定</text>
      </view>
    </view>
    <view class="picker-content">
      <view class="specialty-grid">
        <view 
          class="specialty-item {{item.checked ? 'specialty-item-selected' : ''}}" 
          wx:for="{{specialtyOptions}}" 
          wx:key="value"
          data-index="{{index}}"
          bindtap="onSpecialtyChange"
        >
          <text class="specialty-label">{{item.label}}</text>
          <text class="specialty-check" wx:if="{{item.checked}}">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>