.review-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.detail-content {
  height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  padding: 40rpx 30rpx;
}

.overall-rating {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.overall-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.overall-value {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.rating-number {
  font-size: 64rpx;
  font-weight: bold;
  color: #FFB300;
}

.rating-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.rating-breakdown {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.breakdown-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.breakdown-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.breakdown-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 4rpx;
}

.breakdown-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFB300;
}

.user-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.review-time {
  font-size: 24rpx;
  color: #999;
}

.order-info {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.order-value {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
}

.owner-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  margin-left: 20rpx;
}

.edit-btn {
  background-color: rgba(121, 85, 72, 0.1);
}

.delete-btn {
  background-color: rgba(244, 67, 54, 0.1);
}

.btn-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 24rpx;
  color: #666;
}

.edit-btn .btn-text {
  color: #795548;
}

.delete-btn .btn-text {
  color: #f44336;
}

.content-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.review-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.review-images {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.review-image {
  width: 100%;
  height: 100%;
}

.detail-rating-section {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.detail-rating-section .section-header {
  padding: 30rpx;
  margin-bottom: 0;
  cursor: pointer;
}

.header-left {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: #ccc;
  transform: rotate(90deg);
  transition: transform 0.3s;
}

.arrow-down {
  transform: rotate(-90deg);
}

.section-content {
  padding: 0 30rpx 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.detail-list {
  margin-top: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-item:last-child {
  border-bottom: none;
}

.item-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 20rpx;
}

.item-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #999;
}

.item-rating {
  flex-shrink: 0;
}

.section-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #FFF8E7;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #795548;
}

.summary-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFB300;
}

.reply-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reply-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #795548;
}

.reply-time {
  font-size: 24rpx;
  color: #999;
}

.reply-content {
  padding: 20rpx;
  background-color: #FFF8E7;
  border-radius: 12rpx;
}

.reply-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: center;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  background-color: #f5f5f5;
  margin: 0 20rpx;
}

.action-item.liked {
  background-color: rgba(255, 179, 0, 0.1);
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

.action-item.liked .action-text {
  color: #FFB300;
}

.action-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.reply-input-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.reply-input-wrapper {
  margin-bottom: 16rpx;
}

.reply-input {
  width: 100%;
  height: 100rpx;
  padding: 16rpx 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.reply-actions {
  display: flex;
  justify-content: flex-end;
}

.btn-cancel {
  width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
  margin-right: 20rpx;
}

.btn-cancel::after {
  border: none;
}

.btn-send {
  width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  background-color: #795548;
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
}

.btn-send::after {
  border: none;
}

.bottom-spacer {
  height: 40rpx;
}
