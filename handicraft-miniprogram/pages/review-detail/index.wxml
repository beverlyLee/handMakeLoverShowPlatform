<view class="review-detail-container">
  <view class="loading-container" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <scroll-view wx:else class="detail-content" scroll-y>
    <view class="header-section" wx:if="{{review}}">
      <view class="overall-rating">
        <text class="overall-label">综合评分</text>
        <view class="overall-value">
          <text class="rating-number">{{review.overall_rating}}</text>
          <text class="rating-unit">分</text>
        </view>
        <star-rating 
          value="{{review.overall_rating}}" 
          disabled="{{true}}"
          size="large"
          showValue="{{false}}"
        />
      </view>
      
      <view class="rating-breakdown">
        <view class="breakdown-item">
          <text class="breakdown-icon">🎨</text>
          <text class="breakdown-label">商品</text>
          <text class="breakdown-value">{{review.product_rating}}分</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-icon">👩‍🏫</text>
          <text class="breakdown-label">老师</text>
          <text class="breakdown-value">{{review.teacher_rating}}分</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-icon">🚚</text>
          <text class="breakdown-label">物流</text>
          <text class="breakdown-value">{{review.logistics_rating}}分</text>
        </view>
      </view>
    </view>

    <view class="user-section" wx:if="{{review}}">
      <view class="user-info">
        <image 
          class="user-avatar" 
          src="{{review.is_anonymous ? '/images/default-avatar.png' : (review.user_avatar || '/images/default-avatar.png')}}"
          mode="aspectFill"
        />
        <view class="user-detail">
          <text class="user-name">{{review.is_anonymous ? '匿名用户' : (review.user_name || '用户')}}</text>
          <text class="review-time">{{formatTime(review.created_at)}}</text>
        </view>
      </view>
      <view class="product-info-row" wx:if="{{review.product_info}}">
        <view class="product-name-row">
          <text class="product-label">作品</text>
          <text class="product-name">{{review.product_info.title}}</text>
        </view>
        <view class="order-actions">
          <view class="action-btn delete-btn" wx:if="{{isOwner}}" catchtap="handleDelete">
            <text class="btn-icon">🗑️</text>
            <text class="btn-text">删除</text>
          </view>
          <view class="action-btn append-btn" catchtap="handleAppendReview">
            <text class="btn-icon">📝</text>
            <text class="btn-text">追加评论</text>
          </view>
        </view>
      </view>
    </view>

    <view class="content-section" wx:if="{{review && (review.content || (review.images && review.images.length > 0))}}">
      <view class="section-header">
        <text class="section-title">评价内容</text>
      </view>
      <text class="review-content" wx:if="{{review.content}}">{{review.content}}</text>
      
      <view class="review-images" wx:if="{{review.images && review.images.length > 0}}">
        <view 
          wx:for="{{review.images}}" 
          wx:key="*this" 
          class="image-item"
          bindtap="previewImage"
          data-url="{{item}}"
        >
          <image class="review-image" src="{{item}}" mode="aspectFill" />
        </view>
      </view>
    </view>

    <view class="append-section" wx:if="{{review && review.append_reviews && review.append_reviews.length > 0}}">
      <view class="section-header">
        <text class="section-title">追加评论 ({{review.append_reviews.length}})</text>
      </view>
      <view class="append-list">
        <view 
          wx:for="{{review.append_reviews}}" 
          wx:key="id" 
          class="append-item"
        >
          <view class="append-user">
            <view class="append-user-info">
              <image 
                class="append-avatar" 
                src="{{item.user_avatar || '/images/default-avatar.png'}}"
                mode="aspectFill"
              />
              <view class="append-user-detail">
                <text class="append-user-name">{{item.user_name || '用户'}}</text>
                <text class="append-time">{{formatTime(item.created_at)}}</text>
              </view>
            </view>
            <view class="append-delete-btn" wx:if="{{item.is_owner}}" catchtap="handleDeleteAppend" data-append-review-id="{{item.id}}" data-user-id="{{item.user_id}}">
              <text class="delete-icon">🗑️</text>
              <text class="delete-text">删除</text>
            </view>
          </view>
          <view class="append-content">
            <text class="append-text">{{item.content}}</text>
          </view>
          <view class="append-images" wx:if="{{item.images && item.images.length > 0}}">
            <view 
              wx:for="{{item.images}}" 
              wx:for-item="img"
              wx:key="*this" 
              class="image-item"
            >
              <image class="review-image" src="{{img}}" mode="aspectFill" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="reply-section" wx:if="{{review && review.reply}}">
      <view class="reply-header">
        <text class="reply-label">老师追加评论</text>
        <text class="reply-time">{{formatTime(review.reply_time)}}</text>
      </view>
      <view class="reply-content">
        <text class="reply-text">{{review.reply}}</text>
      </view>
    </view>

    <view class="detail-rating-section product-section" wx:if="{{review}}">
      <view class="section-header" bindtap="toggleSection" data-section="product">
        <view class="header-left">
          <text class="section-icon">🎨</text>
          <text class="section-title">商品详细评分</text>
        </view>
        <text class="arrow-icon {{expandedSection === 'product' ? 'arrow-down' : ''}}">›</text>
      </view>
      
      <view class="section-content" wx:if="{{expandedSection === 'product'}}">
        <view class="detail-list">
          <view wx:for="{{productDetailItems}}" wx:key="key" class="detail-item">
            <view class="item-info">
              <text class="item-label">{{item.label}}</text>
              <text class="item-desc">{{item.description}}</text>
            </view>
            <view class="item-rating">
              <star-rating 
                value="{{review.product_detail_ratings ? review.product_detail_ratings[item.key] || 0 : 0}}" 
                disabled="{{true}}"
                size="default"
                showValue="{{true}}"
              />
            </view>
          </view>
        </view>
        
        <view class="section-summary">
          <text class="summary-label">商品平均评分</text>
          <text class="summary-value">{{review.product_rating}}分</text>
        </view>
      </view>
    </view>

    <view class="detail-rating-section teacher-section" wx:if="{{review}}">
      <view class="section-header" bindtap="toggleSection" data-section="teacher">
        <view class="header-left">
          <text class="section-icon">👩‍🏫</text>
          <text class="section-title">老师详细评分</text>
        </view>
        <text class="arrow-icon {{expandedSection === 'teacher' ? 'arrow-down' : ''}}">›</text>
      </view>
      
      <view class="section-content" wx:if="{{expandedSection === 'teacher'}}">
        <view class="detail-list">
          <view wx:for="{{teacherDetailItems}}" wx:key="key" class="detail-item">
            <view class="item-info">
              <text class="item-label">{{item.label}}</text>
              <text class="item-desc">{{item.description}}</text>
            </view>
            <view class="item-rating">
              <star-rating 
                value="{{review.teacher_detail_ratings ? review.teacher_detail_ratings[item.key] || 0 : 0}}" 
                disabled="{{true}}"
                size="default"
                showValue="{{true}}"
              />
            </view>
          </view>
        </view>
        
        <view class="section-summary">
          <text class="summary-label">老师平均评分</text>
          <text class="summary-value">{{review.teacher_rating}}分</text>
        </view>
      </view>
    </view>

    <view class="detail-rating-section logistics-section" wx:if="{{review}}">
      <view class="section-header" bindtap="toggleSection" data-section="logistics">
        <view class="header-left">
          <text class="section-icon">🚚</text>
          <text class="section-title">物流详细评分</text>
        </view>
        <text class="arrow-icon {{expandedSection === 'logistics' ? 'arrow-down' : ''}}">›</text>
      </view>
      
      <view class="section-content" wx:if="{{expandedSection === 'logistics'}}">
        <view class="detail-list">
          <view wx:for="{{logisticsDetailItems}}" wx:key="key" class="detail-item">
            <view class="item-info">
              <text class="item-label">{{item.label}}</text>
              <text class="item-desc">{{item.description}}</text>
            </view>
            <view class="item-rating">
              <star-rating 
                value="{{review.logistics_detail_ratings ? review.logistics_detail_ratings[item.key] || 0 : 0}}" 
                disabled="{{true}}"
                size="default"
                showValue="{{true}}"
              />
            </view>
          </view>
        </view>
        
        <view class="section-summary">
          <text class="summary-label">物流平均评分</text>
          <text class="summary-value">{{review.logistics_rating}}分</text>
        </view>
      </view>
    </view>

    <view class="reply-input-section" wx:if="{{showReplyInput}}">
      <view class="reply-input-wrapper">
        <textarea 
          class="reply-input" 
          placeholder="写下您的追加评论..."
          value="{{replyContent}}"
          bindinput="onReplyInput"
          maxlength="500"
        />
      </view>
      <view class="reply-actions">
        <button class="btn-cancel" bindtap="toggleReplyInput">取消</button>
        <button class="btn-send" bindtap="submitReply">发送</button>
      </view>
    </view>

    <view class="append-input-section" wx:if="{{showAppendInput}}">
      <view class="append-header">
        <text class="append-title">追加评论</text>
        <text class="append-close" catchtap="toggleAppendInput">✕</text>
      </view>
      <view class="append-content-wrapper">
        <textarea 
          class="append-input" 
          placeholder="写下您的追加评论内容..."
          value="{{appendContent}}"
          bindinput="onAppendContentInput"
          maxlength="500"
        />
      </view>
      <view class="append-images">
        <view 
          wx:for="{{appendImages}}" 
          wx:key="*this" 
          class="append-image-item"
        >
          <image 
            class="append-image" 
            src="{{item}}" 
            mode="aspectFill"
            catchtap="previewAppendInputImage"
            data-url="{{item}}"
          />
          <view class="append-image-remove" catchtap="removeAppendImage" data-index="{{index}}">
            <text class="remove-icon">✕</text>
          </view>
        </view>
        <view 
          class="append-image-item add-image" 
          wx:if="{{appendImages.length < 9}}"
          catchtap="chooseAppendImages"
        >
          <text class="add-icon">+</text>
          <text class="add-text">添加图片</text>
        </view>
      </view>
      <view class="append-actions">
        <button class="btn-cancel" catchtap="toggleAppendInput">取消</button>
        <button class="btn-submit-append {{isSubmitting ? 'disabled' : ''}}" catchtap="submitAppendReview" disabled="{{isSubmitting}}">
          {{isSubmitting ? '提交中...' : '提交'}}
        </button>
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>
</view>
