/* pages/message-list/index.wxss */

.message-list-container {
  min-height: 100vh;
  background-color: #FFF8E7;
}

.message-tabs {
  display: flex;
  background-color: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 10;
}

.message-tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #795548;
  position: relative;
}

.message-tab-item.active {
  color: #E67E22;
  font-weight: 500;
}

.message-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #E67E22;
  border-radius: 2rpx;
}

.message-tab-badge {
  position: absolute;
  top: 16rpx;
  right: 50rpx;
  min-width: 28rpx;
  height: 28rpx;
  background-color: #E74C3C;
  border-radius: 14rpx;
  font-size: 18rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.message-list {
  background-color: #FFFFFF;
}

.message-item {
  display: flex;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0E6D2;
  position: relative;
}

.message-item.unread::before {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  background-color: #E74C3C;
  border-radius: 50%;
}

.message-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.message-icon.system {
  background-color: rgba(230, 126, 34, 0.1);
}

.message-icon.order {
  background-color: rgba(33, 150, 243, 0.1);
}

.message-icon.interaction {
  background-color: rgba(156, 39, 176, 0.1);
}

.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.message-title {
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 500;
}

.message-time {
  font-size: 22rpx;
  color: #BCAAA4;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.message-desc {
  font-size: 24rpx;
  color: #795548;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #BCAAA4;
}
