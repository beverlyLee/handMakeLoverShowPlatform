.messages-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  display: flex;
  flex-direction: column;
}

.tab-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid rgba(121, 85, 72, 0.1);
  box-shadow: 0 2rpx 12rpx rgba(121, 85, 72, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-scroll {
  flex: 1;
  white-space: nowrap;
}

.tabs-wrapper {
  display: flex;
  gap: 8rpx;
}

.tab-item {
  position: relative;
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  transition: all 0.3s ease;
}

.tab-active {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
}

.tab-text {
  font-size: 26rpx;
  color: #8D6E63;
  font-weight: 500;
}

.tab-active .tab-text {
  color: #FFF8E7;
}

.tab-dot {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #E65100 0%, #BF360C 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.tab-dot-text {
  font-size: 18rpx;
  color: #fff;
  font-weight: bold;
}

.tab-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-left: 16rpx;
  padding-left: 16rpx;
  border-left: 1rpx solid rgba(121, 85, 72, 0.15);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background-color: rgba(121, 85, 72, 0.05);
  border-radius: 20rpx;
}

.action-icon {
  font-size: 24rpx;
}

.action-text {
  font-size: 24rpx;
  color: #795548;
  font-weight: 500;
}

.message-list-wrapper {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.message-movable-area {
  position: relative;
  width: 100%;
  height: 180rpx;
  overflow: hidden;
  border-radius: 20rpx;
}

.message-movable-view {
  width: 100%;
  height: 100%;
}

.message-item {
  display: flex;
  align-items: stretch;
  height: 180rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.06);
  transition: all 0.3s ease;
}

.message-item:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(121, 85, 72, 0.08);
}

.message-edit-mode {
  padding-right: 0;
}

.select-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  background-color: rgba(121, 85, 72, 0.03);
  height: 100%;
}

.select-box {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(121, 85, 72, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.select-box.selected {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  border-color: transparent;
}

.select-check {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.message-content-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 24rpx;
  gap: 20rpx;
  height: 100%;
  box-sizing: border-box;
}

.message-left-wrapper {
  position: relative;
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
}

.message-icon-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
}

.message-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 44rpx;
}

.unread-dot {
  position: absolute;
  top: 4rpx;
  left: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #E64A19;
  border-radius: 50%;
  border: 2rpx solid #fff;
  z-index: 10;
}

.message-avatar-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
}

.message-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  border: 2rpx solid rgba(121, 85, 72, 0.1);
}

.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #E65100 0%, #BF360C 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border: 2rpx solid #fff;
  z-index: 10;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.message-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
  min-width: 0;
  height: 100%;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.message-title {
  flex: 1;
  font-size: 30rpx;
  color: #5D4037;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-time {
  font-size: 22rpx;
  color: #A1887F;
  flex-shrink: 0;
}

.message-preview {
  display: flex;
  align-items: center;
  height: 40rpx;
}

.message-desc {
  flex: 1;
  font-size: 26rpx;
  color: #8D6E63;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 40rpx;
}

.text-faded {
  color: #BCAAA4;
}

.message-arrow {
  margin-left: 12rpx;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 36rpx;
  color: #D7CCC8;
}

.swipe-actions {
  position: absolute;
  top: 0;
  right: 0;
  height: 100%;
  display: flex;
  align-items: center;
}

.swipe-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
  gap: 6rpx;
}

.swipe-action-mark {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
}

.swipe-action-delete {
  background: linear-gradient(135deg, #E65100 0%, #BF360C 100%);
}

.swipe-action-icon {
  font-size: 32rpx;
}

.swipe-action-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, rgba(121, 85, 72, 0.08) 0%, rgba(141, 110, 99, 0.06) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.empty-icon {
  font-size: 72rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #5D4037;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #A1887F;
}

.loading-state,
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-text,
.load-more-text {
  font-size: 26rpx;
  color: #A1887F;
}

.edit-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid rgba(121, 85, 72, 0.1);
  box-shadow: 0 -4rpx 16rpx rgba(121, 85, 72, 0.08);
  gap: 24rpx;
  z-index: 100;
}

.edit-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx;
  background-color: rgba(121, 85, 72, 0.06);
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.edit-action.active {
  background: linear-gradient(135deg, rgba(121, 85, 72, 0.12) 0%, rgba(141, 110, 99, 0.1) 100%);
}

.edit-action-primary {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
}

.edit-action-primary.disabled {
  background: rgba(121, 85, 72, 0.2);
  opacity: 0.6;
}

.edit-action-icon {
  font-size: 32rpx;
}

.edit-action-text {
  font-size: 28rpx;
  color: #795548;
  font-weight: 500;
}

.edit-action-primary .edit-action-text {
  color: #FFF8E7;
}

page {
  background-color: #FFF8E7;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
