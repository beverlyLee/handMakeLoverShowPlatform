<view class="messages-container">
  <view class="tab-bar">
    <scroll-view scroll-x class="tab-scroll" enhanced show-scrollbar="{{false}}">
      <view class="tabs-wrapper">
        <view 
          wx:for="{{tabs}}" 
          wx:key="key"
          class="tab-item {{activeTab === item.key ? 'tab-active' : ''}}"
          bindtap="switchTab"
          data-tab="{{item.key}}"
        >
          <text class="tab-text">{{item.name}}</text>
          <view class="tab-dot" wx:if="{{item.key !== 'all' && unreadCounts[item.key] > 0}}">
            <text class="tab-dot-text">{{unreadCounts[item.key] > 99 ? '99+' : unreadCounts[item.key]}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="tab-actions">
      <view class="action-btn" wx:if="{{!isEditMode}}" bindtap="markAllAsRead">
        <text class="action-icon">📖</text>
        <text class="action-text">全部已读</text>
      </view>
      <view class="action-btn" bindtap="toggleEditMode">
        <text class="action-icon">{{isEditMode ? '✓' : '☰'}}</text>
        <text class="action-text">{{isEditMode ? '完成' : '编辑'}}</text>
      </view>
    </view>
  </view>

  <view class="message-list-wrapper">
    <view class="message-list" wx:if="{{messageList.length > 0}}">
      <movable-area 
        wx:for="{{messageList}}" 
        wx:key="id"
        class="message-movable-area"
      >
        <movable-view 
          class="message-movable-view"
          direction="horizontal"
          x="{{item.x || 0}}"
          out-of-bounds="true"
          damping="30"
          friction="15"
          data-index="{{index}}"
          bindchange="onMovableViewChange"
          bindtouchend="onSwipeEnd"
        >
          <view class="message-item {{isEditMode ? 'message-edit-mode' : ''}}">
            <view class="select-wrapper" wx:if="{{isEditMode}}" bindtap="toggleSelect" data-id="{{item.messageId || item.id}}" data-item-type="{{item.itemType}}">
              <view class="select-box {{item.isSelected ? 'selected' : ''}}">
                <text class="select-check" wx:if="{{item.isSelected}}">✓</text>
              </view>
            </view>
            
            <view class="message-content-wrapper" bindtap="goToDetail" data-item-type="{{item.itemType}}" data-message-id="{{item.messageId}}" data-id="{{item.id}}" data-is-read="{{item.isRead}}">
              <view class="message-left-wrapper">
                <view class="message-icon-wrapper" wx:if="{{item.itemType === 'message'}}">
                  <view class="message-icon" style="background: {{item.typeConfig.bgColor}}">
                    <text class="icon-text">{{item.typeConfig.icon}}</text>
                  </view>
                  <view class="unread-dot" wx:if="{{item.isUnread}}"></view>
                </view>

                <view class="message-avatar-wrapper" wx:if="{{item.itemType === 'conversation'}}">
                  <image class="message-avatar" src="{{item.avatar}}" mode="aspectFill" />
                  <view class="unread-dot" wx:if="{{item.isUnread}}"></view>
                </view>
              </view>

              <view class="message-info">
                <view class="message-header">
                  <text class="message-title">
                    {{item.itemType === 'conversation' ? item.name : item.title}}
                  </text>
                  <text class="message-time">
                    {{item.createTime || item.last_message_time ? (item.createTime ? item.createTime.slice(5, 16) : item.last_message_time.slice(5, 16)) : ''}}
                  </text>
                </view>
                <view class="message-preview">
                  <text class="message-desc" lines="1">
                    {{item.preview}}
                  </text>
                </view>
              </view>

              <view class="message-arrow">
                <text class="arrow-icon">›</text>
              </view>
            </view>
          </view>
        </movable-view>

        <view class="swipe-actions">
          <view 
            class="swipe-action-item swipe-action-mark" 
            wx:if="{{!item.isRead || (item.itemType === 'conversation' && item.unread_count > 0)}}"
            bindtap="onSwipeAction"
            data-action="markRead"
            data-index="{{index}}"
            data-id="{{item.messageId || item.id}}"
            data-item-type="{{item.itemType}}"
          >
            <text class="swipe-action-icon">✓</text>
            <text class="swipe-action-text">已读</text>
          </view>
          <view 
            class="swipe-action-item swipe-action-delete"
            bindtap="onSwipeAction"
            data-action="delete"
            data-index="{{index}}"
            data-id="{{item.messageId || item.id}}"
            data-item-type="{{item.itemType}}"
          >
            <text class="swipe-action-icon">🗑️</text>
            <text class="swipe-action-text">删除</text>
          </view>
        </view>
      </movable-area>
    </view>

    <view class="empty-state" wx:elif="{{!isLoading}}">
      <view class="empty-icon-wrapper">
        <text class="empty-icon">📭</text>
      </view>
      <text class="empty-title">暂无消息</text>
      <text class="empty-desc">您的消息列表是空的</text>
    </view>

    <view class="loading-state" wx:if="{{isLoading && messageList.length === 0}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="load-more" wx:if="{{isLoading && messageList.length > 0}}">
      <text class="load-more-text">加载更多...</text>
    </view>
  </view>

  <view class="edit-footer" wx:if="{{isEditMode}}">
    <view class="edit-action {{selectedIds.length === messageList.length && messageList.length > 0 ? 'active' : ''}}" bindtap="selectAll">
      <text class="edit-action-icon">{{selectedIds.length === messageList.length && messageList.length > 0 ? '✓' : '○'}}</text>
      <text class="edit-action-text">全选</text>
    </view>
    <view class="edit-action edit-action-primary {{selectedIds.length === 0 ? 'disabled' : ''}}" bindtap="batchDelete">
      <text class="edit-action-icon">🗑️</text>
      <text class="edit-action-text">删除({{selectedIds.length}})</text>
    </view>
  </view>
</view>
