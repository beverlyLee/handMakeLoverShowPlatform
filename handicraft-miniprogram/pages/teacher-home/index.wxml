<view class="teacher-home-container">
  <view class="loading-container" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="home-content" wx:else>
    <view class="header-section">
      <view class="header-bg"></view>
      <view class="teacher-info-card">
        <view class="teacher-main-info">
          <image 
            class="teacher-avatar" 
            src="{{teacher.user_info ? teacher.user_info.avatar : '/images/default-avatar.png'}}" 
            mode="aspectFill" 
          />
          <view class="teacher-detail">
            <view class="teacher-name-row">
              <text class="teacher-name">{{teacher.user_info ? teacher.user_info.nickname : '' || teacher.real_name || '手作老师'}}</text>
              <view class="verify-badge" wx:if="{{teacher.is_verified}}">
                <text class="verify-icon">✓</text>
                <text class="verify-text">已认证</text>
              </view>
              <view class="edit-btn-small" wx:if="{{isOwner}}" bindtap="openEditDialog" data-field="nickname" data-title="昵称" data-value="{{teacher.user_info ? teacher.user_info.nickname : ''}}">
                <text class="edit-icon">✏️</text>
              </view>
            </view>
            <view class="teacher-studio">
              <text class="studio-icon">🏠</text>
              <text class="studio-name">{{teacher.studio_name || '未设置工作室'}}</text>
              <view class="edit-btn-small" wx:if="{{isOwner}}" bindtap="openStudioEdit">
                <text class="edit-icon">✏️</text>
              </view>
            </view>
            <view class="teacher-tags">
              <block wx:if="{{teacher.specialties && teacher.specialties.length > 0}}">
                <text 
                  wx:for="{{teacher.specialties}}" 
                  wx:for-item="tag" 
                  wx:key="*this" 
                  class="teacher-tag"
                >{{tag}}</text>
              </block>
              <text wx:else class="teacher-tag teacher-tag-placeholder">未设置擅长领域</text>
              <view class="edit-btn-small" wx:if="{{isOwner}}" bindtap="openSpecialtiesEdit">
                <text class="edit-icon">✏️</text>
              </view>
            </view>
          </view>
        </view>
        
        <view class="teacher-stats-row">
          <view class="stat-item" wx:if="{{teacher.rating}}">
            <text class="stat-value">★{{teacher.rating}}</text>
            <text class="stat-label">评分</text>
          </view>
          <view class="stat-divider" wx:if="{{teacher.rating && teacher.follower_count}}"></view>
          <view class="stat-item" wx:if="{{teacher.follower_count}}">
            <text class="stat-value">{{teacher.follower_count}}</text>
            <text class="stat-label">粉丝</text>
          </view>
          <view class="stat-divider" wx:if="{{(teacher.rating || teacher.follower_count) && productsTotal > 0}}"></view>
          <view class="stat-item" wx:if="{{productsTotal > 0}}">
            <text class="stat-value">{{productsTotal}}</text>
            <text class="stat-label">作品</text>
          </view>
          <view class="stat-divider" wx:if="{{(teacher.rating || teacher.follower_count || productsTotal > 0) && teacher.order_count}}"></view>
          <view class="stat-item" wx:if="{{teacher.order_count}}">
            <text class="stat-value">{{teacher.order_count}}</text>
            <text class="stat-label">接单</text>
          </view>
        </view>

        <view class="header-actions">
          <button wx:if="{{!isOwner}}" class="action-btn action-btn-primary" bindtap="followTeacher">
            <text class="btn-icon">+</text>
            <text class="btn-text">关注</text>
          </button>
          <button wx:if="{{!isOwner}}" class="action-btn action-btn-secondary" bindtap="contactTeacher">
            <text class="btn-icon">💬</text>
            <text class="btn-text">咨询</text>
          </button>
          <button wx:if="{{isOwner}}" class="action-btn action-btn-manage" bindtap="goToEditInfo">
            <text class="btn-icon">✏️</text>
            <text class="btn-text">修改入驻信息</text>
          </button>
        </view>
      </view>
    </view>

    <view class="cert-section" wx:if="{{teacher.certifications && teacher.certifications.length > 0}}">
      <view class="section-header">
        <text class="section-title">资质认证</text>
        <view class="title-decoration"></view>
      </view>
      <view class="cert-list">
        <view wx:for="{{teacher.certifications}}" wx:for-item="cert" wx:key="*this" class="cert-item">
          <text class="cert-icon">🏆</text>
          <text class="cert-text">{{cert}}</text>
        </view>
      </view>
    </view>

    <view class="tab-section">
      <view class="tab-bar">
        <view 
          class="tab-item {{currentTab === 'orders' ? 'active' : ''}}" 
          bindtap="switchTab" 
          data-tab="orders"
        >
          <text class="tab-text">接单</text>
        </view>
        <view 
          class="tab-item {{currentTab === 'products' ? 'active' : ''}}" 
          bindtap="switchTab" 
          data-tab="products"
        >
          <text class="tab-text">作品 ({{productsTotal || 0}})</text>
        </view>
        <view 
          class="tab-item {{currentTab === 'reviews' ? 'active' : ''}}" 
          bindtap="switchTab" 
          data-tab="reviews"
        >
          <text class="tab-text">评价 ({{reviewStats ? reviewStats.total : 0}})</text>
        </view>
      </view>

      <view class="tab-content">
        <view class="orders-tab" wx:if="{{currentTab === 'orders'}}">
          <view class="time-range-tabs" wx:if="{{orderStats}}">
            <view class="time-tab {{orderTimeRange === 'total' ? 'active' : ''}}" bindtap="switchTimeRange" data-range="total">
              <text class="time-tab-text">全部</text>
            </view>
            <view class="time-tab {{orderTimeRange === 'today' ? 'active' : ''}}" bindtap="switchTimeRange" data-range="today">
              <text class="time-tab-text">今日</text>
            </view>
            <view class="time-tab {{orderTimeRange === 'week' ? 'active' : ''}}" bindtap="switchTimeRange" data-range="week">
              <text class="time-tab-text">本周</text>
            </view>
            <view class="time-tab {{orderTimeRange === 'month' ? 'active' : ''}}" bindtap="switchTimeRange" data-range="month">
              <text class="time-tab-text">本月</text>
            </view>
          </view>
          
          <view class="order-stats-card" wx:if="{{orderStats}}">
            <view class="order-stats-header">
              <text class="order-stats-title">接单统计</text>
              <text class="order-stats-subtitle">{{currentTimeRangeLabel}}</text>
            </view>
            <view class="order-stats-grid">
              <view class="order-stat-item">
                <text class="order-stat-value" style="color: #333;">{{orderStats.total || 0}}</text>
                <text class="order-stat-label">总接单</text>
              </view>
              <view class="order-stat-item">
                <text class="order-stat-value" style="color: #4CAF50;">{{orderStats.completed || 0}}</text>
                <text class="order-stat-label">已完成</text>
              </view>
              <view class="order-stat-item">
                <text class="order-stat-value" style="color: #FF9800;">{{pendingOrders.total_pending || 0}}</text>
                <text class="order-stat-label">进行中</text>
              </view>
              <view class="order-stat-item">
                <text class="order-stat-value" style="color: #E64A19;">¥{{orderStats.total_amount || 0}}</text>
                <text class="order-stat-label">成交额</text>
              </view>
            </view>
          </view>
          
          <view class="income-stats-card" wx:if="{{orderStats && orderStats.total > 0}}">
            <view class="section-header">
              <text class="section-title">收入统计</text>
              <view class="title-decoration"></view>
            </view>
            <view class="income-stats-grid">
              <view class="income-stat-item">
                <text class="income-stat-label">平均客单价</text>
                <text class="income-stat-value">¥{{orderStats.avg_order_value || 0}}</text>
              </view>
              <view class="income-stat-item">
                <text class="income-stat-label">日均收入(近30天)</text>
                <text class="income-stat-value">¥{{orderStats.avg_daily_amount_30days || 0}}</text>
              </view>
              <view class="income-stat-item">
                <text class="income-stat-label">完成率</text>
                <text class="income-stat-value success">{{orderStats.completion_rate || 0}}%</text>
              </view>
              <view class="income-stat-item">
                <text class="income-stat-label">取消率</text>
                <text class="income-stat-value danger">{{orderStats.cancellation_rate || 0}}%</text>
              </view>
            </view>
            <view class="income-extended-grid" wx:if="{{orderStats.max_order_value > 0}}">
              <view class="extended-stat-item">
                <text class="extended-stat-label">最高订单金额</text>
                <text class="extended-stat-value">¥{{orderStats.max_order_value || 0}}</text>
              </view>
              <view class="extended-stat-item">
                <text class="extended-stat-label">最低订单金额</text>
                <text class="extended-stat-value">¥{{orderStats.min_order_value || 0}}</text>
              </view>
            </view>
          </view>
          
          <view class="pending-stats-card" wx:if="{{pendingOrders && pendingOrders.total_pending > 0}}">
            <view class="section-header">
              <text class="section-title">待处理订单</text>
              <view class="title-decoration"></view>
            </view>
            <view class="pending-stats-grid">
              <view class="pending-stat-item pending-accept" wx:if="{{pendingOrders.pending_accept > 0}}">
                <text class="pending-stat-icon">⏳</text>
                <text class="pending-stat-value">{{pendingOrders.pending_accept}}</text>
                <text class="pending-stat-label">待接单</text>
              </view>
              <view class="pending-stat-item accepted" wx:if="{{pendingOrders.accepted > 0}}">
                <text class="pending-stat-icon">✅</text>
                <text class="pending-stat-value">{{pendingOrders.accepted}}</text>
                <text class="pending-stat-label">已接单</text>
              </view>
              <view class="pending-stat-item in-progress" wx:if="{{pendingOrders.in_progress > 0}}">
                <text class="pending-stat-icon">🔨</text>
                <text class="pending-stat-value">{{pendingOrders.in_progress}}</text>
                <text class="pending-stat-label">制作中</text>
              </view>
              <view class="pending-stat-item paid" wx:if="{{pendingOrders.paid > 0}}">
                <text class="pending-stat-icon">📦</text>
                <text class="pending-stat-value">{{pendingOrders.paid}}</text>
                <text class="pending-stat-label">待发货</text>
              </view>
              <view class="pending-stat-item shipped" wx:if="{{pendingOrders.shipped > 0}}">
                <text class="pending-stat-icon">🚚</text>
                <text class="pending-stat-value">{{pendingOrders.shipped}}</text>
                <text class="pending-stat-label">待收货</text>
              </view>
            </view>
          </view>
          
          <view class="trend-stats-card" wx:if="{{dailyTrend && dailyTrend.length > 0}}">
            <view class="section-header">
              <text class="section-title">近7天订单趋势</text>
              <view class="title-decoration"></view>
            </view>
            <view class="trend-chart">
              <view class="trend-bars">
                <view wx:for="{{dailyTrend}}" wx:key="date" class="trend-bar-item">
                  <view class="trend-bar-wrapper">
                    <view class="trend-bar trend-bar-count" style="height: {{item.count > 0 ? (item.count / maxTrendCount * 100) : 0}}%;">
                      <text class="trend-bar-value">{{item.count}}</text>
                    </view>
                  </view>
                  <text class="trend-bar-label">{{item.date.slice(5)}}</text>
                  <text class="trend-bar-amount">¥{{item.amount}}</text>
                </view>
              </view>
              <view class="trend-legend">
                <view class="legend-item">
                  <view class="legend-color legend-count"></view>
                  <text class="legend-text">订单数</text>
                </view>
              </view>
            </view>
          </view>
          
          <view class="alerts-card" wx:if="{{(pending_reviews_count > 0) || (pending_reply_count > 0)}}">
            <view class="section-header">
              <text class="section-title">待处理事项</text>
              <view class="title-decoration"></view>
            </view>
            <view class="alerts-list">
              <view class="alert-item alert-review" wx:if="{{pending_reviews_count > 0}}" bindtap="goToReviewManage">
                <view class="alert-icon">
                  <text class="icon-text">📝</text>
                </view>
                <view class="alert-content">
                  <text class="alert-title">新评价提醒</text>
                  <text class="alert-desc">有 {{pending_reviews_count}} 条新评价待查看</text>
                </view>
                <view class="alert-badge">
                  <text class="badge-text">{{pending_reviews_count}}</text>
                </view>
              </view>
              <view class="alert-item alert-reply" wx:if="{{pending_reply_count > 0}}" bindtap="goToReviewManage">
                <view class="alert-icon">
                  <text class="icon-text">💬</text>
                </view>
                <view class="alert-content">
                  <text class="alert-title">待回复评价</text>
                  <text class="alert-desc">有 {{pending_reply_count}} 条评价待回复</text>
                </view>
                <view class="alert-badge">
                  <text class="badge-text">{{pending_reply_count}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="recent-orders-section" wx:if="{{recentOrders.length > 0}}">
            <view class="section-header">
              <text class="section-title">近期接单</text>
            </view>
            <view class="order-list">
              <view wx:for="{{recentOrders}}" wx:key="id" class="order-card">
                <view class="order-header">
                  <text class="order-id">订单号: {{item.id}}</text>
                  <text class="order-status" style="color: {{item.status === 'completed' ? '#4CAF50' : item.status === 'cancelled' ? '#F44336' : '#FF9800'}};">
                    {{item.status_name}}
                  </text>
                </view>
                <view class="order-items">
                  <view wx:for="{{item.items}}" wx:for-item="orderItem" wx:key="product_title" class="order-item">
                    <image class="order-item-image" src="{{orderItem.product_image}}" mode="aspectFill" />
                    <view class="order-item-info">
                      <text class="order-item-title" lines="1">{{orderItem.product_title}}</text>
                      <view class="order-item-price-row">
                        <text class="order-item-price">¥{{orderItem.price}}</text>
                        <text class="order-item-quantity">x{{orderItem.quantity}}</text>
                      </view>
                    </view>
                  </view>
                </view>
                <view class="order-footer">
                  <text class="order-time">{{item.create_time}}</text>
                  <view class="order-total">
                    <text class="order-total-label">订单金额:</text>
                    <text class="order-total-price">¥{{item.pay_amount}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view class="empty-state" wx:elif="{{!ordersLoading && (!orderStats || recentOrders.length === 0)}}">
            <text class="empty-icon">📋</text>
            <text class="empty-text">暂无接单记录</text>
          </view>

          <view class="load-more" wx:if="{{ordersLoading}}">
            <text class="load-more-text">加载中...</text>
          </view>
        </view>

        <view class="products-tab" wx:if="{{currentTab === 'products'}}">
          <view class="create-product-btn" wx:if="{{isOwner}}" bindtap="openProductCreate">
            <text class="create-icon">+</text>
            <text class="create-text">发布新作品</text>
          </view>

          <view class="products-grid" wx:if="{{products.length > 0}}">
            <view 
              wx:for="{{products}}" 
              wx:key="id" 
              class="product-card"
            >
              <view class="product-image-wrapper" catchtap="goToProductDetail" data-id="{{item.id}}">
                <image class="product-image" src="{{item.cover_image}}" mode="aspectFill" />
                <view class="product-tags-overlay" wx:if="{{item.tags && item.tags.length > 0}}">
                  <text class="product-tag">{{item.tags[0]}}</text>
                </view>
                <view class="product-stats" wx:if="{{item.sales_count > 0}}">
                  <text class="stat-text">已售{{item.sales_count}}</text>
                </view>
              </view>
              <view class="product-info">
                <text class="product-title" lines="2" catchtap="goToProductDetail" data-id="{{item.id}}">{{item.title}}</text>
                <view class="product-price-row">
                  <view class="price-section">
                    <text class="price-symbol">¥</text>
                    <text class="product-price">{{item.price}}</text>
                    <text class="original-price" wx:if="{{item.original_price > item.price}}">¥{{item.original_price}}</text>
                  </view>
                  <view class="favorite-section" wx:if="{{item.favorite_count > 0}}">
                    <text class="favorite-icon">❤</text>
                    <text class="favorite-count">{{item.favorite_count}}</text>
                  </view>
                </view>
                <view class="product-actions" wx:if="{{isOwner}}">
                  <view class="action-btn" catchtap="openProductEdit" data-product="{{item}}">
                    <text class="action-icon">✏️</text>
                    <text class="action-text">编辑</text>
                  </view>
                  <view class="action-btn action-btn-delete" catchtap="deleteProduct" data-product="{{item}}">
                    <text class="action-icon">🗑️</text>
                    <text class="action-text">删除</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view class="empty-state" wx:elif="{{!productsLoading && products.length === 0}}">
            <text class="empty-icon">🎨</text>
            <text class="empty-text">暂无作品</text>
            <text class="empty-desc" wx:if="{{isOwner}}">点击上方按钮发布您的第一个作品</text>
            <text class="empty-desc" wx:else>这位老师还没有发布作品</text>
          </view>

          <view class="load-more" wx:if="{{productsLoading}}">
            <text class="load-more-text">加载中...</text>
          </view>

          <view class="no-more" wx:if="{{!productsHasMore && products.length > 0 && !productsLoading}}">
            <text class="no-more-text">没有更多了</text>
          </view>
        </view>

        <view class="reviews-tab" wx:if="{{currentTab === 'reviews'}}">
          <view class="quick-actions-card" wx:if="{{isOwner}}">
            <view class="quick-actions-header">
              <text class="quick-actions-title">评价管理</text>
            </view>
            <view class="quick-actions-grid">
              <view class="quick-action-item" bindtap="goToReviewManageWithFilter" data-filter="all">
                <view class="action-icon-wrapper all">
                  <text class="action-icon">📋</text>
                </view>
                <text class="action-label">全部评价</text>
                <text class="action-badge" wx:if="{{reviewStats && reviewStats.total > 0}}">{{reviewStats.total}}</text>
              </view>
              <view class="quick-action-item" bindtap="goToReviewManageWithFilter" data-filter="pending">
                <view class="action-icon-wrapper pending">
                  <text class="action-icon">💬</text>
                </view>
                <text class="action-label">待回复</text>
                <text class="action-badge highlight" wx:if="{{reviewStats && reviewStats.pendingReply > 0}}">{{reviewStats.pendingReply}}</text>
              </view>
              <view class="quick-action-item" bindtap="goToReviewManageWithFilter" data-filter="unread">
                <view class="action-icon-wrapper unread">
                  <text class="action-icon">📖</text>
                </view>
                <text class="action-label">未读评价</text>
                <text class="action-badge highlight" wx:if="{{reviewStats && reviewStats.unread > 0}}">{{reviewStats.unread}}</text>
              </view>
              <view class="quick-action-item" bindtap="goToReviewStats">
                <view class="action-icon-wrapper stats">
                  <text class="action-icon">📊</text>
                </view>
                <text class="action-label">趋势统计</text>
                <text class="action-arrow">›</text>
              </view>
            </view>
          </view>
          
          <view class="review-stats-card" wx:if="{{reviewStats && reviewStats.total > 0}}">
            <view class="review-stats-header">
              <text class="review-stats-title">评价统计</text>
              <view class="review-stats-actions">
                <text class="manage-btn" wx:if="{{isOwner}}" bindtap="goToReviewManage">管理评价 ›</text>
                <text class="view-all-btn" bindtap="goToAllReviews">查看全部 ›</text>
              </view>
            </view>
            <view class="review-stats-main">
              <view class="stats-rating">
                <text class="rating-number">{{reviewStats.avg_rating || 0}}</text>
                <star-rating 
                  value="{{reviewStats.avg_rating || 0}}" 
                  disabled="{{true}}"
                  size="small"
                  showValue="{{false}}"
                />
              </view>
              <view class="stats-breakdown">
                <view class="breakdown-item">
                  <text class="breakdown-label">好评</text>
                  <view class="breakdown-bar">
                    <view class="bar-fill good" style="width: {{reviewStats.total > 0 ? (reviewStats.goodCount / reviewStats.total * 100) : 0}}%"></view>
                  </view>
                  <text class="breakdown-value">{{reviewStats.goodCount || 0}}</text>
                </view>
                <view class="breakdown-item">
                  <text class="breakdown-label">中评</text>
                  <view class="breakdown-bar">
                    <view class="bar-fill medium" style="width: {{reviewStats.total > 0 ? (reviewStats.mediumCount / reviewStats.total * 100) : 0}}%"></view>
                  </view>
                  <text class="breakdown-value">{{reviewStats.mediumCount || 0}}</text>
                </view>
                <view class="breakdown-item">
                  <text class="breakdown-label">差评</text>
                  <view class="breakdown-bar">
                    <view class="bar-fill bad" style="width: {{reviewStats.total > 0 ? (reviewStats.badCount / reviewStats.total * 100) : 0}}%"></view>
                  </view>
                  <text class="breakdown-value">{{reviewStats.badCount || 0}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="reviews-list" wx:if="{{reviews.length > 0}}">
            <view 
              wx:for="{{reviews}}" 
              wx:key="id"
              class="review-card"
              bindtap="goToReviewDetail"
              data-id="{{item.id}}"
            >
              <view class="review-header">
                <view class="user-info">
                  <image 
                    class="user-avatar" 
                    src="{{item.is_anonymous ? '/images/default-avatar.png' : (item.user_avatar || '/images/default-avatar.png')}}"
                    mode="aspectFill"
                  />
                  <view class="user-detail">
                    <view class="user-name-row">
                      <text class="user-name">{{item.is_anonymous ? '匿名用户' : (item.user_name || '用户')}}</text>
                      <text class="user-role-tag" wx:if="{{!item.is_anonymous && item.user_role_label}}">{{item.user_role_label}}</text>
                    </view>
                    <view class="user-meta">
                      <star-rating 
                        value="{{item.overall_rating}}" 
                        disabled="{{true}}"
                        size="small"
                        showValue="{{false}}"
                      />
                      <text class="review-time">{{formatReviewTime(item.created_at)}}</text>
                    </view>
                  </view>
                </view>
              </view>

              <view class="review-rating-mini">
                <view class="rating-item">
                  <text class="rating-icon">🎨</text>
                  <text class="rating-text">商品 {{item.product_rating}}分</text>
                </view>
                <view class="rating-item">
                  <text class="rating-icon">👩‍🏫</text>
                  <text class="rating-text">老师 {{item.teacher_rating}}分</text>
                </view>
                <view class="rating-item">
                  <text class="rating-icon">🚚</text>
                  <text class="rating-text">物流 {{item.logistics_rating}}分</text>
                </view>
              </view>

              <view class="review-content" wx:if="{{item.content}}">
                <text class="content-text">{{item.content}}</text>
              </view>

              <view class="review-images" wx:if="{{item.images && item.images.length > 0}}">
                <view 
                  wx:for="{{item.images.slice(0, 3)}}" 
                  wx:key="*this"
                  class="image-item"
                  catchtap="previewReviewImage"
                  data-url="{{item}}"
                  data-index="{{index}}"
                >
                  <image class="review-image" src="{{item}}" mode="aspectFill" />
                </view>
                <view 
                  wx:if="{{item.images.length > 3}}"
                  class="image-more"
                  catchtap="previewReviewImage"
                  data-url="{{item.images[0]}}"
                  data-index="{{0}}"
                >
                  <text class="more-text">+{{item.images.length - 3}}</text>
                </view>
              </view>

              <view class="review-reply" wx:if="{{item.reply}}">
                <text class="reply-label">老师回复：</text>
                <text class="reply-text">{{item.reply}}</text>
              </view>
            </view>
          </view>

          <view class="empty-state" wx:elif="{{!reviewsLoading && reviews.length === 0}}">
            <text class="empty-icon">📝</text>
            <text class="empty-text">暂无评价</text>
          </view>

          <view class="load-more" wx:if="{{reviewsLoading}}">
            <text class="load-more-text">加载中...</text>
          </view>

          <view class="no-more" wx:if="{{!reviewsHasMore && reviews.length > 0 && !reviewsLoading}}">
            <text class="no-more-text">没有更多了</text>
          </view>
        </view>
      </view>
    </view>

    <view class="edit-dialog-mask" wx:if="{{showEditDialog}}" catchtouchmove="preventMove">
      <view class="edit-dialog">
        <view class="dialog-header">
          <text class="dialog-title">{{editDialogTitle}}</text>
          <view class="dialog-close" bindtap="closeEditDialog">
            <text class="close-icon">×</text>
          </view>
        </view>

        <view class="dialog-content">
          <textarea 
            wx:if="{{editDialogType === 'textarea'}}"
            class="edit-textarea"
            value="{{editDialogValue}}"
            placeholder="请输入{{editDialogTitle}}"
            maxlength="500"
            bindinput="onEditInput"
            auto-height
            focus="{{showEditDialog}}"
          />
          <input 
            wx:elif="{{editDialogType === 'number'}}"
            class="edit-input"
            type="number"
            value="{{editDialogValue}}"
            placeholder="请输入{{editDialogTitle}}"
            bindinput="onEditInput"
            focus="{{showEditDialog}}"
          />
          <input 
            wx:else
            class="edit-input"
            value="{{editDialogValue}}"
            placeholder="请输入{{editDialogTitle}}"
            maxlength="50"
            bindinput="onEditInput"
            focus="{{showEditDialog}}"
          />
        </view>

        <view class="dialog-footer">
          <button class="dialog-btn dialog-btn-cancel" bindtap="closeEditDialog">取消</button>
          <button class="dialog-btn dialog-btn-confirm" bindtap="saveEditDialog" loading="{{savingEdit}}">保存</button>
        </view>
      </view>
    </view>

    <view class="edit-dialog-mask" wx:if="{{showSpecialtiesDialog}}" catchtouchmove="preventMove">
      <view class="edit-dialog edit-dialog-large">
        <view class="dialog-header">
          <text class="dialog-title">擅长领域</text>
          <view class="dialog-close" bindtap="closeSpecialtiesDialog">
            <text class="close-icon">×</text>
          </view>
        </view>

        <view class="dialog-content dialog-content-scroll">
          <view class="specialty-grid">
            <view 
              wx:for="{{specialtyOptions}}" 
              wx:key="value"
              class="specialty-item {{item.checked ? 'active' : ''}}"
              bindtap="toggleSpecialtyItem"
              data-index="{{index}}"
            >
              <text class="specialty-text">{{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="dialog-footer">
          <button class="dialog-btn dialog-btn-cancel" bindtap="closeSpecialtiesDialog">取消</button>
          <button class="dialog-btn dialog-btn-confirm" bindtap="saveSpecialtiesDialog" loading="{{savingEdit}}">保存</button>
        </view>
      </view>
    </view>

    <view class="edit-dialog-mask" wx:if="{{showStudioDialog}}" catchtouchmove="preventMove">
      <view class="edit-dialog">
        <view class="dialog-header">
          <text class="dialog-title">工作室信息</text>
          <view class="dialog-close" bindtap="closeStudioDialog">
            <text class="close-icon">×</text>
          </view>
        </view>

        <view class="dialog-content">
          <view class="studio-edit-item">
            <text class="studio-edit-label">工作室名称</text>
            <input 
              class="studio-edit-input"
              value="{{studioEditForm.name}}"
              placeholder="请输入工作室名称"
              bindinput="onStudioNameInput"
            />
          </view>
          <view class="studio-edit-item">
            <text class="studio-edit-label">工作室地址</text>
            <input 
              class="studio-edit-input"
              value="{{studioEditForm.address}}"
              placeholder="请输入工作室地址"
              bindinput="onStudioAddressInput"
            />
          </view>
        </view>

        <view class="dialog-footer">
          <button class="dialog-btn dialog-btn-cancel" bindtap="closeStudioDialog">取消</button>
          <button class="dialog-btn dialog-btn-confirm" bindtap="saveStudioDialog" loading="{{savingEdit}}">保存</button>
        </view>
      </view>
    </view>

    <view class="product-create-modal" wx:if="{{showProductCreate}}">
      <view class="modal-mask" bindtap="closeProductCreate"></view>
      <view class="modal-content">
        <view class="modal-header">
          <text class="modal-title">{{isEditingProduct ? '编辑作品' : '发布新作品'}}</text>
          <view class="modal-close" bindtap="closeProductCreate">
            <text class="close-icon">✕</text>
          </view>
        </view>

        <scroll-view class="modal-body" scroll-y>
          <view class="form-section">
            <view class="form-item">
              <text class="form-label">作品标题 *</text>
              <input 
                class="form-input" 
                value="{{productForm.title}}" 
                placeholder="请输入作品标题"
                data-field="title"
                bindinput="onProductInput"
              />
            </view>

            <view class="form-item">
              <text class="form-label">作品描述</text>
              <textarea 
                class="form-textarea" 
                value="{{productForm.description}}" 
                placeholder="请输入作品描述"
                data-field="description"
                bindinput="onProductInput"
                auto-height
              />
            </view>

            <view class="form-item">
              <text class="form-label">作品分类</text>
              <picker 
                mode="selector" 
                range="{{categories}}" 
                range-key="name"
                bindchange="onCategoryChange"
              >
                <view class="form-picker">
                  <text class="{{productForm.category_id ? '' : 'placeholder'}}">
                    {{productForm.category_name || '请选择分类'}}
                  </text>
                  <text class="picker-arrow">›</text>
                </view>
              </picker>
            </view>

            <view class="form-item">
              <text class="form-label">售价 *</text>
              <input 
                class="form-input" 
                type="digit"
                value="{{productForm.price}}" 
                placeholder="请输入售价"
                data-field="price"
                bindinput="onProductInput"
              />
            </view>

            <view class="form-item">
              <text class="form-label">原价</text>
              <input 
                class="form-input" 
                type="digit"
                value="{{productForm.original_price}}" 
                placeholder="请输入原价（可不填）"
                data-field="original_price"
                bindinput="onProductInput"
              />
            </view>

            <view class="form-item">
              <text class="form-label">库存</text>
              <input 
                class="form-input" 
                type="number"
                value="{{productForm.stock}}" 
                placeholder="请输入库存数量"
                data-field="stock"
                bindinput="onProductInput"
              />
            </view>

            <view class="form-item">
              <text class="form-label">作品图片</text>
              <view class="image-upload-area">
                <view 
                  wx:for="{{productForm.images}}" 
                  wx:key="*this" 
                  class="uploaded-image"
                >
                  <image class="preview-image" src="{{item}}" mode="aspectFill" />
                  <view class="remove-image" bindtap="removeImage" data-index="{{index}}">
                    <text class="remove-icon">✕</text>
                  </view>
                </view>
                <view 
                  class="upload-btn" 
                  wx:if="{{productForm.images.length < 9}}"
                  bindtap="chooseImages"
                >
                  <text class="upload-icon">+</text>
                  <text class="upload-text">添加图片</text>
                </view>
              </view>
              <text class="form-hint">最多上传9张图片，第一张作为封面</text>
            </view>
          </view>
        </scroll-view>

        <view class="modal-footer">
          <button class="modal-btn modal-btn-cancel" bindtap="closeProductCreate">
            取消
          </button>
          <button class="modal-btn modal-btn-confirm" bindtap="createProduct" loading="{{creatingProduct}}">
            发布作品
          </button>
        </view>
      </view>
    </view>
  </view>
</view>