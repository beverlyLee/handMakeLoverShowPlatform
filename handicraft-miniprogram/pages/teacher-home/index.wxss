.teacher-home-container {
  min-height: 100vh;
  background-color: #FFF8E7;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.header-section {
  position: relative;
  padding: 0 30rpx;
  padding-top: 20rpx;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(180deg, #795548 0%, #8D6E63 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.teacher-info-card {
  position: relative;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(121, 85, 72, 0.15);
}

.teacher-main-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.teacher-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #FFF8E7;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.teacher-detail {
  flex: 1;
  margin-left: 24rpx;
}

.teacher-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.teacher-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.verify-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.verify-icon {
  font-size: 20rpx;
  color: #fff;
  margin-right: 6rpx;
}

.verify-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

.teacher-studio {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.studio-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.studio-name {
  font-size: 26rpx;
  color: #795548;
}

.teacher-tags {
  display: flex;
  flex-wrap: wrap;
}

.teacher-tag {
  font-size: 22rpx;
  color: #795548;
  background-color: rgba(121, 85, 72, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid rgba(121, 85, 72, 0.2);
}

.teacher-stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  background-color: #FFF8E7;
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #795548;
}

.stat-label {
  font-size: 22rpx;
  color: #8D6E63;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(121, 85, 72, 0.2);
}

.stat-item-highlight {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  transform: scale(1.05);
}

.stat-value-popularity {
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.stat-label-popularity {
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  color: #fff;
}

.action-btn-secondary {
  background-color: #FFF8E7;
  color: #795548;
  border: 2rpx solid rgba(121, 85, 72, 0.3);
}

.action-btn-edit {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #fff;
}

.action-btn-manage {
  background-color: #E3F2FD;
  color: #1565C0;
  border: 2rpx solid rgba(21, 101, 192, 0.3);
}

.action-btn-stats {
  background: linear-gradient(135deg, #7E57C2 0%, #9575CD 100%);
  color: #fff;
}

.action-btn-activity {
  background: linear-gradient(135deg, #E64A19 0%, #FF5722 100%);
  color: #fff;
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.btn-text {
  font-weight: 500;
}

.intro-section,
.studio-section,
.cert-section {
  background-color: #fff;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.title-decoration {
  flex: 1;
  height: 4rpx;
  background: linear-gradient(90deg, #795548 0%, transparent 100%);
  border-radius: 2rpx;
}

.intro-content {
  margin-bottom: 24rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.info-grid {
  display: flex;
  gap: 20rpx;
}

.info-item {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #FFF8E7;
  padding: 20rpx;
  border-radius: 16rpx;
}

.info-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.info-text-group {
  display: flex;
  flex-direction: column;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #795548;
}

.info-label {
  font-size: 22rpx;
  color: #8D6E63;
}

.studio-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.studio-address {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.studio-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.studio-image {
  width: 210rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.cert-list {
  display: flex;
  flex-wrap: wrap;
}

.cert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFECB3 100%);
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.cert-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.cert-text {
  font-size: 26rpx;
  color: #795548;
  font-weight: 500;
}

.tab-section {
  background-color: #fff;
  margin-top: 20rpx;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 600rpx);
}

.tab-bar {
  display: flex;
  padding: 0 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #795548 0%, #8D6E63 100%);
  border-radius: 3rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: bold;
}

.tab-content {
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

.quick-stats {
  margin-bottom: 20rpx;
}

.quick-stat-card {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  border-radius: 20rpx;
  padding: 30rpx;
}

.quick-stat-header {
  margin-bottom: 24rpx;
}

.quick-stat-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.quick-stat-grid {
  display: flex;
  justify-content: space-around;
}

.quick-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.quick-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-hint .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-hint .empty-text {
  font-size: 28rpx;
  color: #999;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #f0f0f0;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-tags-overlay {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
}

.product-tag {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(121, 85, 72, 0.9);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.product-stats {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
}

.stat-text {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.product-info {
  padding: 16rpx;
}

.product-title {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #E64A19;
  margin-right: 2rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #E64A19;
}

.original-price {
  font-size: 20rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.like-section {
  display: flex;
  align-items: center;
}

.product-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.product-actions .action-btn {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  border: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF8E7;
  color: #795548;
  border: 1rpx solid rgba(121, 85, 72, 0.2);
}

.product-actions .action-btn::after {
  border: none;
}

.product-actions .action-btn:active {
  opacity: 0.7;
}

.product-actions .action-btn-delete {
  background-color: #FFEBEE;
  color: #E53935;
  border: 1rpx solid rgba(229, 57, 53, 0.2);
}

.product-actions .action-btn-submit {
  background-color: #E8F5E9;
  color: #43A047;
  border: 1rpx solid rgba(67, 160, 71, 0.2);
}

.product-actions .action-btn-pending {
  background-color: #FFF8E1;
  color: #F57C00;
  border: 1rpx solid rgba(245, 124, 0, 0.2);
}

.product-actions .action-btn-offline {
  background-color: #E3F2FD;
  color: #1976D2;
  border: 1rpx solid rgba(25, 118, 210, 0.2);
}

.product-pending .product-image-wrapper {
  opacity: 0.9;
}

.product-offline .product-image-wrapper {
  opacity: 0.85;
}

.product-status-overlay {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
}

.status-text {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-text.status-pending {
  background-color: rgba(255, 152, 0, 0.9);
  color: #fff;
}

.status-text.status-offline {
  background-color: rgba(158, 158, 158, 0.9);
  color: #fff;
}

.product-actions .action-icon {
  margin-right: 4rpx;
  font-size: 24rpx;
}

.product-actions .action-text {
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #ccc;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
}

.time-range-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.time-tab {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 64rpx;
  background-color: #FFF8E7;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.time-tab.active {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
}

.time-tab-text {
  font-size: 24rpx;
  color: #795548;
}

.time-tab.active .time-tab-text {
  color: #fff;
  font-weight: 500;
}

.order-stats-card {
  background-color: #FFF8E7;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.order-stats-header {
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-stats-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #795548;
}

.order-stats-subtitle {
  font-size: 22rpx;
  color: #A1887F;
}

.order-stats-grid {
  display: flex;
  justify-content: space-around;
}

.order-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-stat-value {
  font-size: 36rpx;
  font-weight: bold;
}

.order-stat-label {
  font-size: 22rpx;
  color: #8D6E63;
  margin-top: 8rpx;
}

.income-stats-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.income-stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.income-stat-item {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: #FFF8E7;
  border-radius: 16rpx;
}

.income-stat-label {
  font-size: 22rpx;
  color: #8D6E63;
  margin-bottom: 12rpx;
}

.income-stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #795548;
}

.income-stat-value.success {
  color: #4CAF50;
}

.income-stat-value.danger {
  color: #F44336;
}

.income-extended-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f5f5f5;
}

.extended-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.extended-stat-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.extended-stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.pending-stats-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.pending-stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pending-stat-item {
  width: calc(33.33% - 11rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  border-radius: 16rpx;
}

.pending-stat-item.pending-accept {
  background-color: #FFF3E0;
}

.pending-stat-item.accepted {
  background-color: #E8F5E9;
}

.pending-stat-item.in-progress {
  background-color: #E3F2FD;
}

.pending-stat-item.paid {
  background-color: #FCE4EC;
}

.pending-stat-item.shipped {
  background-color: #F3E5F5;
}

.pending-stat-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.pending-stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.pending-stat-label {
  font-size: 20rpx;
  color: #666;
}

.trend-stats-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.trend-chart {
  margin-top: 20rpx;
}

.trend-bars {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 240rpx;
  padding: 0 10rpx;
}

.trend-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(14.28% - 8rpx);
}

.trend-bar-wrapper {
  width: 100%;
  height: 160rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.trend-bar {
  width: 40rpx;
  border-radius: 8rpx 8rpx 0 0;
  position: relative;
  transition: height 0.3s;
}

.trend-bar-count {
  background: linear-gradient(180deg, #795548 0%, #8D6E63 100%);
}

.trend-bar-value {
  position: absolute;
  top: -32rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #795548;
  font-weight: 500;
}

.trend-bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
}

.trend-bar-amount {
  font-size: 18rpx;
  color: #E64A19;
  margin-top: 4rpx;
}

.trend-legend {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f5f5f5;
}

.legend-item {
  display: flex;
  align-items: center;
  margin-right: 32rpx;
}

.legend-item:last-child {
  margin-right: 0;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.legend-count {
  background: linear-gradient(180deg, #795548 0%, #8D6E63 100%);
}

.legend-text {
  font-size: 22rpx;
  color: #666;
}

.alerts-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.alerts-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.alert-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  position: relative;
}

.alert-item.alert-review {
  background-color: #FFF8E1;
}

.alert-item.alert-reply {
  background-color: #E3F2FD;
}

.alert-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  margin-right: 20rpx;
}

.icon-text {
  font-size: 36rpx;
}

.alert-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.alert-title {
