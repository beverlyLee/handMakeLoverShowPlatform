.teacher-home-container {
  min-height: 100vh;
  background-color: #FFF8E7;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.header-section {
  position: relative;
  padding: 0 30rpx;
  padding-top: 20rpx;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(180deg, #795548 0%, #8D6E63 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.teacher-info-card {
  position: relative;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(121, 85, 72, 0.15);
}

.teacher-main-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.teacher-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #FFF8E7;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.teacher-detail {
  flex: 1;
  margin-left: 24rpx;
}

.teacher-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.teacher-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.verify-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.verify-icon {
  font-size: 20rpx;
  color: #fff;
  margin-right: 6rpx;
}

.verify-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

.teacher-studio {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.studio-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.studio-name {
  font-size: 26rpx;
  color: #795548;
}

.teacher-tags {
  display: flex;
  flex-wrap: wrap;
}

.teacher-tag {
  font-size: 22rpx;
  color: #795548;
  background-color: rgba(121, 85, 72, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
  border: 1rpx solid rgba(121, 85, 72, 0.2);
}

.teacher-stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  background-color: #FFF8E7;
  border-radius: 16rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #795548;
}

.stat-label {
  font-size: 22rpx;
  color: #8D6E63;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(121, 85, 72, 0.2);
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  color: #fff;
}

.action-btn-secondary {
  background-color: #FFF8E7;
  color: #795548;
  border: 2rpx solid rgba(121, 85, 72, 0.3);
}

.action-btn-edit {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #fff;
}

.action-btn-manage {
  background-color: #E3F2FD;
  color: #1565C0;
  border: 2rpx solid rgba(21, 101, 192, 0.3);
}

.btn-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.btn-text {
  font-weight: 500;
}

.intro-section,
.studio-section,
.cert-section {
  background-color: #fff;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.title-decoration {
  flex: 1;
  height: 4rpx;
  background: linear-gradient(90deg, #795548 0%, transparent 100%);
  border-radius: 2rpx;
}

.intro-content {
  margin-bottom: 24rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.info-grid {
  display: flex;
  gap: 20rpx;
}

.info-item {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #FFF8E7;
  padding: 20rpx;
  border-radius: 16rpx;
}

.info-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.info-text-group {
  display: flex;
  flex-direction: column;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #795548;
}

.info-label {
  font-size: 22rpx;
  color: #8D6E63;
}

.studio-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.location-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.studio-address {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.studio-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.studio-image {
  width: 210rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.cert-list {
  display: flex;
  flex-wrap: wrap;
}

.cert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #FFF8E7 0%, #FFECB3 100%);
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.cert-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.cert-text {
  font-size: 26rpx;
  color: #795548;
  font-weight: 500;
}

.tab-section {
  background-color: #fff;
  margin-top: 20rpx;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 600rpx);
}

.tab-bar {
  display: flex;
  padding: 0 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #795548 0%, #8D6E63 100%);
  border-radius: 3rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: bold;
}

.tab-content {
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

.quick-stats {
  margin-bottom: 20rpx;
}

.quick-stat-card {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  border-radius: 20rpx;
  padding: 30rpx;
}

.quick-stat-header {
  margin-bottom: 24rpx;
}

.quick-stat-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.quick-stat-grid {
  display: flex;
  justify-content: space-around;
}

.quick-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.quick-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-hint .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-hint .empty-text {
  font-size: 28rpx;
  color: #999;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #f0f0f0;
}

.product-card:active {
  transform: scale(0.98);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-tags-overlay {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
}

.product-tag {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(121, 85, 72, 0.9);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.product-stats {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
}

.stat-text {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.product-info {
  padding: 16rpx;
}

.product-title {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #E64A19;
  margin-right: 2rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #E64A19;
}

.original-price {
  font-size: 20rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.favorite-section {
  display: flex;
  align-items: center;
}

.favorite-icon {
  font-size: 22rpx;
  color: #E64A19;
  margin-right: 4rpx;
}

.favorite-count {
  font-size: 20rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #ccc;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
}

.order-stats-card {
  background-color: #FFF8E7;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.order-stats-header {
  margin-bottom: 24rpx;
}

.order-stats-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #795548;
}

.order-stats-grid {
  display: flex;
  justify-content: space-around;
}

.order-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-stat-value {
  font-size: 36rpx;
  font-weight: bold;
}

.order-stat-label {
  font-size: 22rpx;
  color: #8D6E63;
  margin-top: 8rpx;
}

.recent-orders-section .section-header {
  margin-bottom: 20rpx;
}

.recent-orders-section .section-title {
  font-size: 28rpx;
  color: #333;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed #e0e0e0;
}

.order-id {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.order-item {
  display: flex;
  align-items: center;
}

.order-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.order-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.order-item-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.order-item-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.order-item-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #E64A19;
}

.order-item-quantity {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-time {
  font-size: 22rpx;
  color: #999;
}

.order-total {
  display: flex;
  align-items: baseline;
}

.order-total-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.order-total-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #E64A19;
}

.edit-btn-small {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(121, 85, 72, 0.1);
  border-radius: 50%;
  margin-left: 12rpx;
}

.edit-icon {
  font-size: 22rpx;
  color: #795548;
}

.teacher-tag-placeholder {
  color: #999;
  background-color: #f5f5f5;
  border: 1rpx solid #e0e0e0;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative;
}

.edit-btn-row {
  padding: 8rpx 20rpx;
  background-color: rgba(121, 85, 72, 0.1);
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.edit-text {
  font-size: 24rpx;
  color: #795548;
}

.intro-section {
  background-color: #fff;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.info-grid {
  display: flex;
  gap: 20rpx;
}

.info-item {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #FFF8E7;
  padding: 20rpx;
  border-radius: 16rpx;
  position: relative;
}

.edit-btn-inline {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  padding: 4rpx 12rpx;
  background-color: rgba(121, 85, 72, 0.15);
  border-radius: 12rpx;
}

.edit-text-inline {
  font-size: 20rpx;
  color: #795548;
}

.info-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.info-text-group {
  display: flex;
  flex-direction: column;
}

.info-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #795548;
}

.info-label {
  font-size: 22rpx;
  color: #8D6E63;
}

.specialties-section {
  background-color: #fff;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.specialties-content {
  display: flex;
  flex-wrap: wrap;
}

.empty-tags-text {
  font-size: 26rpx;
  color: #999;
  padding: 10rpx 0;
}

.edit-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-dialog {
  width: 80%;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 80vh;
}

.edit-dialog-large {
  width: 90%;
  max-height: 70vh;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dialog-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 36rpx;
  color: #999;
}

.dialog-content {
  padding: 30rpx;
}

.dialog-content-scroll {
  padding: 30rpx;
  max-height: 400rpx;
  overflow-y: scroll;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 24rpx;
  line-height: 88rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.edit-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.dialog-footer {
  display: flex;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.dialog-btn-confirm {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  color: #fff;
}

.dialog-btn-confirm[loading] {
  opacity: 0.6;
}

.specialty-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.specialty-item {
  padding: 16rpx 28rpx;
  background-color: #f5f5f5;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.specialty-item.active {
  background-color: rgba(121, 85, 72, 0.1);
  border-color: #795548;
}

.specialty-text {
  font-size: 26rpx;
  color: #666;
}

.specialty-item.active .specialty-text {
  color: #795548;
  font-weight: 500;
}

.studio-edit-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.studio-edit-item:last-child {
  margin-bottom: 0;
}

.studio-edit-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.studio-edit-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.create-product-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.create-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 12rpx;
}

.create-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.product-create-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 90%;
  max-height: 80vh;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  flex: 1;
  overflow-y: scroll;
  max-height: 500rpx;
}

.form-section {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 24rpx;
  line-height: 88rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.form-picker .placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.image-upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.uploaded-image {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove-image {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 24rpx;
  color: #fff;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
  border: 2rpx dashed #e0e0e0;
  border-radius: 12rpx;
}

.upload-icon {
  font-size: 48rpx;
  color: #ccc;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  color: #fff;
}

.modal-btn-confirm[loading] {
  opacity: 0.6;
}
