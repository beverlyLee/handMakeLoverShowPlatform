.community-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFF0D4 100%);
  padding-bottom: 120rpx;
}

.community-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FFE4B5 0%, #FFDAB9 100%);
}

.community-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.community-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #795548;
  margin-bottom: 8rpx;
}

.community-desc {
  font-size: 24rpx;
  color: #8B7355;
}

.quick-actions {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 20rpx;
  gap: 16rpx;
}

.action-card {
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.1);
  border: 2rpx dashed #FFE4B5;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #795548;
  font-weight: 500;
}

.featured-section {
  padding: 20rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #795548;
}

.loading-state,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #795548;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.1);
  border: 2rpx solid rgba(255, 228, 181, 0.5);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-stats {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
  display: flex;
  gap: 8rpx;
}

.stat-item {
  font-size: 20rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.5);
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
}

.product-info {
  padding: 16rpx;
}

.product-title {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  min-height: 72rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 20rpx;
  color: #E64340;
  font-weight: 500;
}

.product-price {
  font-size: 28rpx;
  color: #E64340;
  font-weight: 600;
}

.like-section {
  display: flex;
  align-items: center;
}

.create-section {
  padding: 20rpx 24rpx;
}

.create-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 244, 228, 0.9) 100%);
  border-radius: 20rpx;
  border: 2rpx dashed #FFB74D;
}

.create-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.create-text {
  font-size: 30rpx;
  color: #795548;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.create-hint {
  font-size: 22rpx;
  color: #999;
}
