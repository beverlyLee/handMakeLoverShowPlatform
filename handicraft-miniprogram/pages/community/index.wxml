<view class="community-container">
  <view class="banner-section" wx:if="{{bannerActivities.length > 0}}">
    <swiper 
      class="banner-swiper" 
      indicator-dots="{{true}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#795548"
      autoplay="{{true}}"
      circular="{{true}}"
      bindchange="onBannerChange"
      interval="{{autoplayInterval}}"
      duration="500"
    >
      <swiper-item 
        wx:for="{{bannerActivities}}" 
        wx:key="id"
        class="banner-swiper-item"
      >
        <view 
          class="banner-card"
          bindtap="onBannerClick"
          data-id="{{item.id}}"
        >
          <image 
            class="banner-image" 
            src="{{item.cover_image || defaultImage}}" 
            mode="aspectFill"
          />
          <view class="banner-overlay">
            <view class="banner-title-wrapper">
              <text class="banner-type">{{item.craft_type}} · {{item.activity_type}}</text>
              <text class="banner-title">{{item.title}}</text>
              <view class="banner-meta">
                <text class="meta-item" wx:if="{{item.start_time}}">📅 {{formatTimeRange(item.start_time, item.end_time)}}</text>
                <text class="meta-item" wx:if="{{item.location}}">📍 {{item.location}}</text>
                <text class="meta-item price" wx:if="{{item.price > 0}}">¥{{item.price}}</text>
                <text class="meta-item price free" wx:else>免费</text>
              </view>
            </view>
          </view>
        </view>
      </swiper-item>
    </swiper>
    <view class="banner-indicator">
      <text class="indicator-text">{{currentBannerIndex + 1}}/{{bannerActivities.length}}</text>
    </view>
  </view>

  <view class="banner-empty" wx:else>
    <view class="empty-banner-content">
      <text class="empty-banner-icon">🎪</text>
      <text class="empty-banner-title">暂无活动</text>
      <text class="empty-banner-desc">敬请期待精彩活动</text>
    </view>
  </view>

  <view class="quick-actions">
    <view class="action-item" bindtap="goToMyActivities">
      <view class="action-icon-wrapper">
        <text class="action-icon">📋</text>
      </view>
      <text class="action-label">我的活动</text>
    </view>
  </view>

  <view class="filter-section">
    <view class="filter-row">
      <view class="filter-label">
        <text class="label-icon">🎨</text>
        <text class="label-text">手工种类</text>
      </view>
      <scroll-view class="tags-scroll" scroll-x>
        <view class="tags-container">
          <view 
            wx:for="{{craftTypes}}" 
            wx:key="*this"
            class="tag-item {{selectedCraftType === item ? 'active' : ''}}"
            bindtap="onCraftTypeChange"
            data-type="{{item}}"
          >
            <text class="tag-text">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="filter-row">
      <view class="filter-label">
        <text class="label-icon">🎯</text>
        <text class="label-text">活动类型</text>
      </view>
      <scroll-view class="tags-scroll" scroll-x>
        <view class="tags-container">
          <view 
            wx:for="{{activityTypes}}" 
            wx:key="*this"
            class="tag-item {{selectedActivityType === item ? 'active' : ''}}"
            bindtap="onActivityTypeChange"
            data-type="{{item}}"
          >
            <text class="tag-text">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="activities-section">
    <view class="section-header">
      <text class="section-icon">✨</text>
      <text class="section-title">活动列表</text>
      <text class="section-count" wx:if="{{total > 0}}">共{{total}}个活动</text>
    </view>

    <view class="loading-state" wx:if="{{isLoading && activities.length === 0}}">
      <view class="loading-content">
        <text class="loading-spinner">⏳</text>
        <text class="loading-text">加载中...</text>
      </view>
    </view>

    <view class="empty-state" wx:elif="{{showEmpty}}">
      <text class="empty-icon">🎪</text>
      <text class="empty-text">暂无活动</text>
      <text class="empty-desc">换个筛选条件试试吧</text>
    </view>

    <view class="activities-list" wx:else>
      <view 
        wx:for="{{activities}}" 
        wx:key="id" 
        class="activity-card"
        bindtap="onActivityCardClick"
        data-id="{{item.id}}"
      >
        <view class="card-image-wrapper">
          <image 
            class="card-image" 
            src="{{item.cover_image || defaultImage}}" 
            mode="aspectFill"
          />
          <view class="card-type-badge">
            <text class="badge-text">{{item.craft_type}}</text>
          </view>
          <view class="card-status-badge" wx:if="{{!item.is_registration_open}}">
            <text class="status-text">报名截止</text>
          </view>
        </view>
        
        <view class="card-content">
          <view class="card-title-row">
            <text class="card-title" lines="2">{{item.title}}</text>
            <view class="card-activity-type">
              <text class="activity-type-text">{{item.activity_type}}</text>
            </view>
          </view>
          
          <view class="card-meta">
            <view class="meta-row" wx:if="{{item.start_time}}">
              <text class="meta-icon">📅</text>
              <text class="meta-text">{{formatTimeRange(item.start_time, item.end_time)}}</text>
            </view>
            <view class="meta-row" wx:if="{{item.location}}">
              <text class="meta-icon">📍</text>
              <text class="meta-text">{{item.location}}</text>
            </view>
            <view class="meta-row stats-row">
              <text class="stat-item" wx:if="{{item.current_participants > 0}}">👥 {{item.current_participants}}人已报名</text>
              <text class="stat-item" wx:if="{{item.view_count > 0}}">👁 {{item.view_count}}次浏览</text>
            </view>
          </view>
          
          <view class="card-footer">
            <view class="price-section">
              <text class="price" wx:if="{{item.price > 0}}">¥{{item.price}}</text>
              <text class="price free" wx:else>免费</text>
              <text class="original-price" wx:if="{{item.original_price > item.price}}">¥{{item.original_price}}</text>
            </view>
            <view class="spots-section" wx:if="{{item.max_participants < 999}}">
              <text class="spots-text">仅剩{{item.max_participants - item.current_participants}}个名额</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{isLoadingMore}}">
      <text class="loading-more-text">加载更多...</text>
    </view>

    <view class="no-more" wx:if="{{!hasNext && activities.length > 0}}">
      <text class="no-more-text">没有更多活动了</text>
    </view>
  </view>
</view>
