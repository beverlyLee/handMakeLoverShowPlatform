<view class="work-detail-container">
  <view class="loading-container" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="work-content" wx:else>
    <view class="image-section">
      <swiper 
        class="image-swiper" 
        indicator-dots="{{product.images.length > 1}}" 
        indicator-color="rgba(255,255,255,0.5)"
        indicator-active-color="#fff"
        autoplay="{{false}}" 
        circular="{{product.images.length > 1}}"
        bindchange="onImageChange"
      >
        <swiper-item wx:for="{{product.images}}" wx:key="*this">
          <image 
            class="work-image" 
            src="{{item}}" 
            mode="aspectFill" 
            bindtap="previewImage" 
            data-url="{{item}}"
          />
        </swiper-item>
      </swiper>
      <view class="image-counter" wx:if="{{product.images.length > 1}}">
        <text>{{currentImageIndex + 1}}/{{product.images.length}}</text>
      </view>
    </view>

    <view class="info-section">
      <view class="price-row">
        <view class="price-section">
          <text class="price-symbol">¥</text>
          <text class="work-price">{{product.price}}</text>
          <text class="original-price" wx:if="{{product.original_price > product.price}}">¥{{product.original_price}}</text>
        </view>
        <view class="stats-section">
          <view class="stat-item" wx:if="{{product.sales_count > 0}}">
            <text class="stat-value">{{product.sales_count}}</text>
            <text class="stat-label">已售</text>
          </view>
          <view class="stat-item" wx:if="{{product.favorite_count > 0}}">
            <text class="stat-value">{{product.favorite_count}}</text>
            <text class="stat-label">收藏</text>
          </view>
        </view>
      </view>

      <view class="rating-row" wx:if="{{reviewStats && reviewStats.total > 0}}">
        <view class="rating-info" bindtap="goToAllReviews">
          <view class="rating-main">
            <text class="rating-score">{{reviewStats.avg_rating || 0}}</text>
            <star-rating 
              value="{{reviewStats.avg_rating || 0}}" 
              disabled="{{true}}"
              size="small"
              showValue="{{false}}"
            />
          </view>
          <text class="rating-count">{{reviewStats.total}}条评价</text>
          <text class="arrow-icon">›</text>
        </view>
        <view class="rating-tags" wx:if="{{reviewStats.goodCount > 0 || reviewStats.mediumCount > 0 || reviewStats.badCount > 0}}">
          <text class="rating-tag good" wx:if="{{reviewStats.goodCount > 0}}">好评{{reviewStats.goodCount}}</text>
          <text class="rating-tag medium" wx:if="{{reviewStats.mediumCount > 0}}">中评{{reviewStats.mediumCount}}</text>
          <text class="rating-tag bad" wx:if="{{reviewStats.badCount > 0}}">差评{{reviewStats.badCount}}</text>
        </view>
      </view>

      <view class="title-section">
        <text class="work-title">{{product.title}}</text>
        <view class="work-tags">
          <text wx:for="{{product.tags}}" wx:for-item="tag" wx:key="*this" class="work-tag">{{tag}}</text>
        </view>
      </view>
    </view>

    <view class="teacher-card">
      <view class="teacher-header" bindtap="goToTeacherProfile" data-teacher-id="{{product.teacher_id}}">
        <image class="teacher-avatar" src="{{product.teacher ? product.teacher.avatar : '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="teacher-info">
          <view class="teacher-name-row">
            <text class="teacher-name">{{product.teacher ? (product.teacher.nickname || product.teacher.real_name || '手作老师') : '手作老师'}}</text>
            <text class="teacher-badge" wx:if="{{product.teacher && product.teacher.rating}}">★{{product.teacher.rating}}</text>
          </view>
          <text class="teacher-stats" wx:if="{{product.teacher && (product.teacher.follower_count > 0 || product.teacher.product_count > 0)}}">
            {{product.teacher.follower_count}}粉丝 · {{product.teacher.product_count}}作品
          </text>
          <text class="teacher-intro" wx:if="{{product.teacher && product.teacher.intro}}">
            {{product.teacher.intro}}
          </text>
        </view>
        <text class="arrow-icon">›</text>
      </view>
      <view class="teacher-actions">
        <button class="action-btn action-btn-primary" bindtap="goToTeacherProducts" data-teacher-id="{{product.teacher_id}}">
          查看Ta的作品
        </button>
        <button class="action-btn action-btn-secondary" bindtap="contactTeacher">
          联系老师
        </button>
      </view>
    </view>

    <view class="description-section">
      <view class="section-header">
        <text class="section-title">作品详情</text>
      </view>
      <view class="description-content">
        <text class="description-text">{{product.description}}</text>
      </view>
    </view>

    <view class="specs-section" wx:if="{{product.category}}">
      <view class="section-header">
        <text class="section-title">作品信息</text>
      </view>
      <view class="specs-list">
        <view class="spec-item" wx:if="{{product.category}}">
          <text class="spec-label">分类</text>
          <text class="spec-value">{{product.category.name}}</text>
        </view>
      </view>
    </view>

    <view class="reviews-section" wx:if="{{reviewStats && reviewStats.total > 0}}">
      <view class="section-header">
        <text class="section-title">用户评价({{reviewStats.total || 0}})</text>
        <text class="view-all" bindtap="goToAllReviews">查看全部 ›</text>
      </view>
      
      <view class="reviews-list">
        <view 
          wx:for="{{reviews}}" 
          wx:key="id"
          class="review-card"
          bindtap="goToReviewDetail"
          data-id="{{item.id}}"
        >
          <view class="review-header">
            <view class="user-info">
              <image 
                class="user-avatar" 
                src="{{item.is_anonymous ? '/images/default-avatar.png' : (item.user_avatar || '/images/default-avatar.png')}}"
                mode="aspectFill"
              />
              <view class="user-detail">
                <text class="user-name">{{item.is_anonymous ? '匿名用户' : (item.user_name || '用户')}}</text>
                <view class="user-meta">
                  <star-rating 
                    value="{{item.overall_rating}}" 
                    disabled="{{true}}"
                    size="small"
                    showValue="{{false}}"
                  />
                  <text class="rating-value">{{item.overall_rating}}分</text>
                  <text class="review-time">{{formatReviewTime(item.created_at)}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="review-content" wx:if="{{item.content}}">
            <text class="content-text">{{item.content}}</text>
          </view>

          <view class="review-images" wx:if="{{item.images && item.images.length > 0}}">
            <view 
              wx:for="{{item.images.slice(0, 3)}}" 
              wx:key="*this"
              class="image-item"
              catchtap="previewReviewImage"
              data-url="{{item}}"
              data-index="{{index}}"
            >
              <image class="review-image" src="{{item}}" mode="aspectFill" />
            </view>
          </view>

          <view class="review-reply" wx:if="{{item.reply}}">
            <text class="reply-label">老师回复：</text>
            <text class="reply-text">{{item.reply}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="more-works-section" wx:if="{{product.teacher && product.teacher.product_count > 0}}">
      <view class="section-header">
        <text class="section-title">更多Ta的作品</text>
        <text class="view-all" bindtap="goToTeacherProducts" data-teacher-id="{{product.teacher_id}}">查看全部 ›</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar {{isTeacher ? 'bottom-bar-teacher' : ''}}" wx:if="{{!isLoading}}">
    <view class="bar-actions">
      <view class="action-icon-wrapper" bindtap="toggleFavorite">
        <text class="action-icon">❤</text>
        <text class="action-text">收藏</text>
      </view>
      <view class="action-icon-wrapper" bindtap="contactTeacher">
        <text class="action-icon">💬</text>
        <text class="action-text">咨询</text>
      </view>
      <view class="action-icon-wrapper">
        <text class="action-icon">🛒</text>
        <text class="action-text">购物车</text>
      </view>
    </view>
    <view class="bar-buttons">
      <button class="btn-buy" bindtap="buyNow">立即购买</button>
    </view>
  </view>
</view>
