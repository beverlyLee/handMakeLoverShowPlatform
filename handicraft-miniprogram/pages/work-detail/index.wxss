.work-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.image-section {
  width: 100%;
  background-color: #fff;
  position: relative;
}

.image-swiper {
  width: 100%;
  height: 750rpx;
}

.work-image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.info-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #E64A19;
  margin-right: 4rpx;
}

.work-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #E64A19;
}

.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.stats-section {
  display: flex;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 30rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.title-section {
  margin-top: 20rpx;
}

.work-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.work-tags {
  display: flex;
  flex-wrap: wrap;
}

.work-tag {
  font-size: 22rpx;
  color: #795548;
  background-color: rgba(121, 85, 72, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
}

.teacher-card {
  background-color: #fff;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.teacher-header {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.teacher-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #e0e0e0;
}

.teacher-info {
  flex: 1;
}

.teacher-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.teacher-badge {
  font-size: 24rpx;
  color: #FFB300;
  background-color: rgba(255, 179, 0, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.teacher-stats {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.teacher-intro {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.arrow-icon {
  font-size: 36rpx;
  color: #ccc;
}

.teacher-actions {
  display: flex;
  margin-top: 20rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  background-color: #795548;
  color: #fff;
}

.action-btn-secondary {
  background-color: rgba(121, 85, 72, 0.1);
  color: #795548;
}

.description-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.view-all {
  font-size: 26rpx;
  color: #795548;
}

.description-content {
  padding-top: 10rpx;
}

.description-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.specs-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.specs-list {
  padding-top: 10rpx;
}

.spec-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.spec-item:last-child {
  border-bottom: none;
}

.spec-label {
  font-size: 28rpx;
  color: #999;
  width: 160rpx;
}

.spec-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.more-works-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bar-actions {
  display: flex;
  margin-right: 20rpx;
}

.action-icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 20rpx;
  color: #666;
}

.bar-buttons {
  flex: 1;
  display: flex;
  gap: 20rpx;
}

.btn-cart,
.btn-buy {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.btn-cart::after,
.btn-buy::after {
  border: none;
}

.btn-cart {
  background-color: rgba(121, 85, 72, 0.15);
  color: #795548;
}

.btn-buy {
  background-color: #795548;
  color: #fff;
}

.btn-order {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
  background-color: #795548;
  color: #fff;
}

.btn-order::after {
  border: none;
}

.btn-order.disabled {
  background-color: #ccc;
  color: #fff;
}

.btn-teacher {
  background-color: rgba(121, 85, 72, 0.3);
  color: #fff;
}

.btn-teacher:active {
  background-color: rgba(121, 85, 72, 0.3);
}

.bottom-bar-teacher {
  justify-content: center;
}

.bottom-bar-teacher .bar-actions {
  margin-right: 0;
  justify-content: center;
}

.order-confirm-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.order-confirm-dialog {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dialog-close {
  font-size: 36rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-content {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.order-product {
  display: flex;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.product-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 10rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #E64A19;
}

.product-original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.quantity-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.quantity-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.quantity-controls {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 36rpx;
  color: #333;
}

.quantity-btn.disabled {
  background-color: #fafafa;
  color: #ccc;
}

.quantity-value {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.order-summary {
  background-color: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-row:last-child {
  margin-bottom: 0;
}

.summary-row.total {
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
  margin-top: 16rpx;
}

.summary-label {
  font-size: 28rpx;
  color: #666;
}

.summary-value {
  font-size: 28rpx;
  color: #333;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #E64A19;
}

.dialog-footer {
  display: flex;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.footer-btn::after {
  border: none;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background-color: #795548;
  color: #fff;
}

.rating-row {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.rating-info {
  display: flex;
  align-items: center;
}

.rating-main {
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.rating-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFB300;
  margin-right: 12rpx;
}

.rating-count {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.rating-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.rating-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.rating-tag.good {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.rating-tag.medium {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.rating-tag.bad {
  background-color: rgba(244, 67, 54, 0.1);
  color: #F44336;
}

.reviews-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.reviews-list {
  margin-top: 10rpx;
}

.review-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.review-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.review-header .user-info {
  display: flex;
  align-items: center;
}

.review-header .user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.review-header .user-detail {
  display: flex;
  flex-direction: column;
}

.review-header .user-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.review-header .user-meta {
  display: flex;
  align-items: center;
}

.review-header .rating-value {
  font-size: 24rpx;
  color: #FFB300;
  font-weight: bold;
  margin-left: 8rpx;
}

.review-header .review-time {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

.review-content {
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.review-images {
  display: flex;
  margin-bottom: 16rpx;
}

.review-images .image-item {
  width: 140rpx;
  height: 140rpx;
  margin-right: 12rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.review-images .review-image {
  width: 100%;
  height: 100%;
}

.review-reply {
  background-color: #FFF8E7;
  padding: 16rpx;
  border-radius: 8rpx;
}

.review-reply .reply-label {
  font-size: 24rpx;
  color: #795548;
  font-weight: 500;
}

.review-reply .reply-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}
