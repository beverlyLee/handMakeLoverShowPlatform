.apply-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFF5E0 100%);
  padding-bottom: 40rpx;
}

.apply-header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.header-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #5D4037;
  display: block;
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #8D6E63;
}

.form-section {
  background: #FFFFFF;
  margin: 24rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(93, 64, 55, 0.08);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #3E2723;
}

.required-mark {
  color: #E53935;
  font-size: 28rpx;
  margin-left: 8rpx;
}

.section-tip {
  font-size: 24rpx;
  color: #A1887F;
  margin-top: -20rpx;
  margin-bottom: 20rpx;
  display: block;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: #5D4037;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #3E2723;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus {
  border-color: #8D6E63;
  background: #FFFFFF;
}

.form-item-picker {
  display: flex;
  flex-direction: column;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  height: 88rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.picker-text {
  font-size: 28rpx;
  color: #3E2723;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #BCAAA4;
}

.picker-arrow {
  font-size: 32rpx;
  color: #A1887F;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
  gap: 16rpx;
}

.tag-item {
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #5D4037;
}

.form-item-textarea {
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #3E2723;
  box-sizing: border-box;
  line-height: 1.6;
}

.textarea-count {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
}

.count-text {
  font-size: 24rpx;
  color: #A1887F;
}

.photo-upload-area {
  margin-top: 20rpx;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: 180rpx;
  height: 180rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 1;
}

.photo-add {
  width: 180rpx;
  height: 180rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  border: 2rpx dashed #BCAAA4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #A1887F;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #A1887F;
  margin-top: 8rpx;
}

.submit-section {
  padding: 40rpx 30rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #8D6E63 0%, #6D4C41 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(109, 76, 65, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn-disabled {
  background: linear-gradient(135deg, #BCAAA4 0%, #A1887F 100%);
  box-shadow: none;
}

.submit-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.agreement-section {
  text-align: center;
  padding: 0 30rpx 40rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #A1887F;
}

.agreement-link {
  font-size: 24rpx;
  color: #8D6E63;
  text-decoration: underline;
}

.specialty-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.specialty-picker {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #EFEBE9;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3E2723;
}

.picker-confirm {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #8D6E63 0%, #6D4C41 100%);
  border-radius: 24rpx;
}

.confirm-text {
  font-size: 26rpx;
  color: #FFFFFF;
}

.picker-content {
  padding: 30rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.specialty-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.specialty-item {
  width: calc(33.33% - 14rpx);
  padding: 24rpx 0;
  background: #FAFAFA;
  border-radius: 16rpx;
  text-align: center;
  position: relative;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.specialty-item-selected {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-color: #8D6E63;
}

.specialty-label {
  font-size: 26rpx;
  color: #5D4037;
}

.specialty-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 24rpx;
  color: #6D4C41;
  font-weight: bold;
}
