.teacher-profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.header-section {
  background-color: #795548;
  padding: 40rpx 30rpx;
  padding-bottom: 60rpx;
}

.teacher-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.teacher-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.teacher-detail {
  flex: 1;
}

.teacher-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.teacher-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
}

.verify-badge {
  font-size: 22rpx;
  color: #795548;
  background-color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.teacher-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.teacher-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
}

.teacher-stats-row {
  display: flex;
  margin-top: 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  background-color: #fff;
  color: #795548;
}

.action-btn-secondary {
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.tab-section {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -24rpx;
  position: relative;
  min-height: calc(100vh - 300rpx);
}

.tab-bar {
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #795548;
  border-radius: 3rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: bold;
}

.tab-content {
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

.info-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.card-header {
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-content {
  padding-top: 10rpx;
}

.info-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  display: block;
}

.cert-list {
  display: flex;
  flex-wrap: wrap;
}

.cert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: rgba(121, 85, 72, 0.05);
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.cert-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.cert-text {
  font-size: 26rpx;
  color: #795548;
}

.studio-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.studio-image {
  width: 210rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-stats {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
}

.stat-text {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.product-info {
  padding: 16rpx;
}

.product-title {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #E64A19;
  margin-right: 2rpx;
}

.product-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #E64A19;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
}
