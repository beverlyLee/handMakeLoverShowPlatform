.teacher-profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.header-section {
  background-color: #795548;
  padding: 40rpx 30rpx;
  padding-bottom: 40rpx;
}

.teacher-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 30rpx;
}

.teacher-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.teacher-detail {
  flex: 1;
}

.teacher-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.teacher-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
}

.teacher-name-input {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.15);
  margin-right: 16rpx;
  min-width: 200rpx;
}

.verify-badge {
  font-size: 22rpx;
  color: #795548;
  background-color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.teacher-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.teacher-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
}

.teacher-stats-row {
  display: flex;
  margin-top: 10rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  background-color: #fff;
  color: #795548;
}

.action-btn-secondary {
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.action-btn-edit {
  background-color: #fff;
  color: #795548;
}

.action-btn-cancel {
  background-color: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.action-btn-save {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #fff;
}

.edit-section {
  padding: 20rpx 30rpx;
}

.edit-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.card-header {
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.card-hint {
  font-size: 24rpx;
  color: #999;
}

.card-content {
  padding-top: 10rpx;
}

.specialty-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.specialty-item {
  padding: 16rpx 28rpx;
  background-color: #f8f8f8;
  border-radius: 24rpx;
  border: 2rpx solid #e0e0e0;
}

.specialty-item.active {
  background: linear-gradient(135deg, rgba(121, 85, 72, 0.1) 0%, rgba(141, 110, 99, 0.1) 100%);
  border-color: #795548;
}

.specialty-text {
  font-size: 26rpx;
  color: #666;
}

.specialty-item.active .specialty-text {
  color: #795548;
  font-weight: 500;
}

.intro-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 16rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.edit-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.edit-item:last-child {
  margin-bottom: 0;
}

.edit-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.edit-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.tab-section {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -24rpx;
  position: relative;
  min-height: calc(100vh - 300rpx);
}

.tab-bar {
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #795548;
  border-radius: 3rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: bold;
}

.tab-content {
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

.info-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #f0f0f0;
}

.info-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  display: block;
}

.cert-list {
  display: flex;
  flex-wrap: wrap;
}

.cert-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: rgba(121, 85, 72, 0.05);
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.cert-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.cert-text {
  font-size: 26rpx;
  color: #795548;
}

.studio-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.studio-image {
  width: 210rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.products-tab {
  padding-bottom: 40rpx;
}

.create-product-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(121, 85, 72, 0.05) 0%, rgba(141, 110, 99, 0.05) 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  border: 2rpx dashed #795548;
}

.create-icon {
  font-size: 40rpx;
  color: #795548;
  margin-right: 12rpx;
  font-weight: 300;
}

.create-text {
  font-size: 28rpx;
  color: #795548;
  font-weight: 500;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-stats {
  position: absolute;
  bottom: 12rpx;
  left: 12rpx;
}

.stat-text {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.product-info {
  padding: 16rpx;
}

.product-title {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 22rpx;
  color: #E64A19;
  margin-right: 2rpx;
}

.product-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #E64A19;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #ccc;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
}

.product-create-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  flex: 1;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  margin-top: 100rpx;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 32rpx;
  color: #999;
}

.modal-body {
  flex: 1;
  overflow-y: scroll;
  padding: 30rpx;
  max-height: calc(100vh - 400rpx);
}

.form-section {
  display: flex;
  flex-direction: column;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 24rpx;
  line-height: 88rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 16rpx 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}

.form-picker .placeholder {
  color: #999;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  display: block;
}

.image-upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.uploaded-image {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.remove-image {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 24rpx;
  color: #fff;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx dashed #d0d0d0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  color: #999;
  font-weight: 300;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  color: #fff;
}

.modal-btn-confirm[loading] {
  opacity: 0.6;
}

.edit-btn-small {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-left: 12rpx;
}

.edit-icon {
  font-size: 22rpx;
  color: #fff;
}

.edit-btn-row {
  padding: 8rpx 20rpx;
  background-color: rgba(121, 85, 72, 0.1);
  border-radius: 20rpx;
}

.edit-text {
  font-size: 24rpx;
  color: #795548;
}

.info-text-placeholder {
  color: #bbb;
}

.edit-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-dialog {
  width: 80%;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 80vh;
}

.edit-dialog-large {
  width: 90%;
  max-height: 70vh;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dialog-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-content {
  padding: 30rpx;
}

.dialog-content-scroll {
  padding: 30rpx;
  max-height: 400rpx;
  overflow-y: scroll;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 24rpx;
  line-height: 88rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.edit-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.dialog-footer {
  display: flex;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.dialog-btn-confirm {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  color: #fff;
}

.dialog-btn-confirm[loading] {
  opacity: 0.6;
}

.studio-edit-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.studio-edit-item:last-child {
  margin-bottom: 0;
}

.studio-edit-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.studio-edit-input {
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
}
