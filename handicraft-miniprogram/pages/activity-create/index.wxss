.activity-create-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.form-scroll {
  height: 100%;
}

.form-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-item-half {
  flex: 1;
}

.item-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.item-label.required::before {
  content: '*';
  color: #E64A19;
  margin-right: 4rpx;
}

.item-input {
  background-color: #fafafa;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
}

.item-input::placeholder {
  color: #aaa;
}

.item-textarea {
  background-color: #fafafa;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 160rpx;
}

.item-textarea::placeholder {
  color: #aaa;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fafafa;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-value .placeholder {
  color: #aaa;
}

.picker-value text:first-child {
  font-size: 28rpx;
  color: #333;
}

.picker-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.price-unit {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 26rpx;
  color: #999;
}

.form-item-half .item-input {
  position: relative;
  padding-right: 60rpx;
}

.input-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  margin-left: 4rpx;
}

.upload-section {
  margin-bottom: 24rpx;
}

.upload-section:last-child {
  margin-bottom: 0;
}

.upload-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.cover-upload {
  display: flex;
  gap: 20rpx;
}

.cover-image-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.images-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 200rpx;
  height: 200rpx;
  background-color: #fafafa;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-placeholder.small {
  width: 160rpx;
  height: 160rpx;
}

.upload-icon {
  font-size: 60rpx;
  color: #ccc;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.upload-placeholder.small .upload-icon {
  font-size: 48rpx;
  margin-bottom: 0;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 28rpx;
  color: #fff;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit::after {
  border: none;
}

.btn-submit.disabled {
  background: #ccc;
  color: #fff;
}

.time-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.time-picker-content {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-actions {
  display: flex;
  gap: 30rpx;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-confirm {
  font-size: 28rpx;
  color: #795548;
  font-weight: bold;
}

.picker-body {
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.picker-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.picker-col {
  flex: 1;
}

.picker-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.picker-preview {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.preview-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 12rpx;
}

.preview-value {
  font-size: 30rpx;
  color: #795548;
  font-weight: bold;
}
