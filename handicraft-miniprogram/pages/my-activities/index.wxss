.my-activities-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.status-tabs {
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #795548;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-go-community {
  background: linear-gradient(135deg, #795548, #8D6E63);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border: none;
}

.registrations-list {
  padding: 20rpx;
}

.registration-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.activity-header {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.activity-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.activity-info {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.activity-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.activity-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.meta-item {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.meta-item.craft-type {
  background-color: rgba(121, 85, 72, 0.1);
  color: #795548;
}

.meta-item.activity-type {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.activity-detail {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.detail-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #666;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-wrapper {
  display: flex;
  align-items: flex-start;
  margin-left: 12rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.status-badge.status-confirmed {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.status-badge.status-pending {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.status-badge.status-cancelled {
  background-color: rgba(158, 158, 158, 0.1);
  color: #9E9E9E;
}

.registration-info {
  padding: 20rpx;
  background-color: #fafafa;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.info-value.price {
  color: #E64A19;
  font-weight: bold;
}

.card-footer {
  padding: 16rpx 20rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: flex-end;
}

.footer-actions {
  display: flex;
  gap: 16rpx;
}

.btn-cancel-registration {
  background-color: transparent;
  color: #999;
  border: 1rpx solid #ddd;
  border-radius: 24rpx;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  margin: 0;
}

.loading-more {
  display: flex;
  justify-content: center;
  padding: 20rpx;
}

.loading-more-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 20rpx;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
}
