<view class="my-activities-container">
  <view class="status-tabs">
    <view 
      wx:for="{{statusTabs}}" 
      wx:key="key"
      class="tab-item {{statusTab === item.key ? 'active' : ''}}"
      bindtap="onStatusTabChange"
      data-tab="{{item.key}}"
    >
      <text class="tab-text">{{item.label}}</text>
    </view>
  </view>

  <view class="loading-state" wx:if="{{isLoading && registrations.length === 0}}">
    <view class="loading-content">
      <text class="loading-spinner">⏳</text>
      <text class="loading-text">加载中...</text>
    </view>
  </view>

  <view class="empty-state" wx:elif="{{showEmpty}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无报名的活动</text>
    <text class="empty-desc">去手工圈看看有什么精彩活动吧</text>
    <button class="btn-go-community" bindtap="goToCommunity">去手工圈</button>
  </view>

  <view class="registrations-list" wx:else>
    <view 
      wx:for="{{registrations}}" 
      wx:key="id" 
      class="registration-card"
    >
      <view class="activity-header" bindtap="goToActivityDetail" data-id="{{item.activity_id}}">
        <image 
          class="activity-cover" 
          src="{{item.activity ? (item.activity.cover_image || '/images/default-avatar.png') : '/images/default-avatar.png'}}" 
          mode="aspectFill"
        />
        <view class="activity-info">
          <text class="activity-title" lines="2">{{item.activity ? item.activity.title : '活动已下架'}}</text>
          <view class="activity-meta">
            <text class="meta-item craft-type" wx:if="{{item.activity && item.activity.craft_type}}">{{item.activity.craft_type}}</text>
            <text class="meta-item activity-type" wx:if="{{item.activity && item.activity.activity_type}}">{{item.activity.activity_type}}</text>
          </view>
          <view class="activity-detail">
            <text class="detail-icon">📅</text>
            <text class="detail-text" wx:if="{{item.activity && item.activity.start_time}}">{{formatTime(item.activity.start_time)}}</text>
          </view>
          <view class="activity-detail">
            <text class="detail-icon">📍</text>
            <text class="detail-text" wx:if="{{item.activity && item.activity.location}}">{{item.activity.location}}</text>
          </view>
        </view>
        <view class="status-wrapper">
          <view class="status-badge {{getStatusClass(item.status)}}">
            <text class="status-text">{{getStatusText(item.status)}}</text>
          </view>
        </view>
      </view>

      <view class="registration-info">
        <view class="info-row">
          <text class="info-label">报名人</text>
          <text class="info-value">{{item.name || '未填写'}}</text>
        </view>
        <view class="info-row" wx:if="{{item.phone}}">
          <text class="info-label">手机号</text>
          <text class="info-value">{{item.phone}}</text>
        </view>
        <view class="info-row" wx:if="{{item.activity}}">
          <text class="info-label">活动价格</text>
          <text class="info-value price">{{formatPrice(item.activity.price)}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">报名时间</text>
          <text class="info-value">{{formatTime(item.created_at)}}</text>
        </view>
        <view class="info-row" wx:if="{{item.remark}}">
          <text class="info-label">备注</text>
          <text class="info-value">{{item.remark}}</text>
        </view>
      </view>

      <view class="card-footer" wx:if="{{canCancel(item.status)}}">
        <view class="footer-actions">
          <button 
            class="btn-cancel-registration" 
            catchtap="cancelRegistration" 
            data-registration-id="{{item.id}}"
            data-activity-id="{{item.activity_id}}"
          >
            取消报名
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-more" wx:if="{{isLoading && registrations.length > 0}}">
    <text class="loading-more-text">加载更多...</text>
  </view>

  <view class="no-more" wx:if="{{!hasNext && registrations.length > 0}}">
    <text class="no-more-text">没有更多了</text>
  </view>
</view>
