/* pages/teacher-products/index.wxss */

.teacher-products-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 140rpx;
}

.product-tabs {
  display: flex;
  background-color: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 10;
}

.product-tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #795548;
  position: relative;
}

.product-tab-item.active {
  color: #E67E22;
  font-weight: 500;
}

.product-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #E67E22;
  border-radius: 2rpx;
}

.product-list {
  padding: 16rpx;
}

.product-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(93, 64, 55, 0.06);
  display: flex;
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: #F5F5F5;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.product-title {
  flex: 1;
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-right: 16rpx;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-tag.on-sale {
  background-color: rgba(39, 174, 96, 0.1);
  color: #27AE60;
}

.status-tag.off-sale {
  background-color: rgba(158, 158, 158, 0.1);
  color: #9E9E9E;
}

.product-stats {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #BCAAA4;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 32rpx;
  color: #E67E22;
  font-weight: 600;
}

.product-price::before {
  content: '¥';
  font-size: 0.8em;
}

.product-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.action-btn.primary {
  background-color: #E67E22;
  color: #FFFFFF;
}

.action-btn.secondary {
  background-color: transparent;
  border: 2rpx solid #BCAAA4;
  color: #795548;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #BCAAA4;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background-color: #E67E22;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.add-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
  z-index: 100;
  padding-bottom: calc(0rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(0rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
