<view class="teacher-reviews-container">
  <view class="loading-container" wx:if="{{isLoading && reviews.length === 0}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else class="reviews-content">
    <view class="stats-header">
      <view class="stats-card" bindtap="openStatsDialog">
        <view class="stats-main">
          <view class="main-item">
            <text class="main-value">{{stats.avgRating}}</text>
            <text class="main-label">平均评分</text>
          </view>
          <view class="main-divider"></view>
          <view class="main-item">
            <text class="main-value">{{stats.total}}</text>
            <text class="main-label">评价总数</text>
          </view>
        </view>
        <view class="stats-sub">
          <view class="sub-item">
            <text class="sub-badge unread">{{stats.unread}}</text>
            <text class="sub-label">未读</text>
          </view>
          <view class="sub-item">
            <text class="sub-badge pending">{{stats.pendingReply}}</text>
            <text class="sub-label">待回复</text>
          </view>
        </view>
        <view class="stats-arrow">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <view class="filter-section">
      <view class="filter-row">
        <scroll-view class="filter-scroll" scroll-x>
          <view class="filter-list">
            <view 
              wx:for="{{ratingFilters}}" 
              wx:key="key"
              class="filter-item {{currentRating === item.key ? 'active' : ''}}"
              bindtap="onRatingChange"
              data-rating="{{item.key}}"
            >
              <text class="filter-text">{{item.label}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
      
      <view class="filter-row">
        <scroll-view class="filter-scroll" scroll-x>
          <view class="filter-list">
            <view 
              wx:for="{{replyStatusFilters}}" 
              wx:key="key"
              class="filter-item {{currentReplyStatus === item.key ? 'active' : ''}}"
              bindtap="onReplyStatusChange"
              data-status="{{item.key}}"
            >
              <text class="filter-text">{{item.label}}</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="filter-row sort-row">
        <view class="sort-label">排序：</view>
        <scroll-view class="sort-scroll" scroll-x>
          <view class="sort-list">
            <view 
              wx:for="{{sortOptions}}" 
              wx:key="key"
              class="sort-item {{sortBy === item.key ? 'active' : ''}}"
              bindtap="onSortChange"
              data-sort="{{item.key}}"
            >
              <text class="sort-text">{{item.label}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <view class="action-bar" wx:if="{{isSelectMode}}">
      <view class="action-left">
        <view class="select-all-btn" bindtap="toggleSelectAll">
          <view class="checkbox {{selectedReviews.length === reviews.length && reviews.length > 0 ? 'checked' : ''}}">
            <text wx:if="{{selectedReviews.length === reviews.length && reviews.length > 0}}" class="check-icon">✓</text>
          </view>
          <text class="select-all-text">全选</text>
        </view>
        <text class="selected-count">已选 {{selectedReviews.length}} 项</text>
      </view>
      <view class="action-right">
        <view class="action-btn primary" bindtap="markSelectedAsRead">
          <text class="action-btn-text">标记已读</text>
        </view>
        <view class="action-btn cancel" bindtap="toggleSelectMode">
          <text class="action-btn-text">取消</text>
        </view>
      </view>
    </view>

    <view class="normal-action-bar" wx:else>
      <view class="action-left">
        <text class="review-count">共 {{reviews.length}} 条评价</text>
      </view>
      <view class="action-right">
        <view class="action-btn outline" bindtap="toggleSelectMode">
          <text class="action-btn-text">批量管理</text>
        </view>
      </view>
    </view>

    <view class="reviews-list">
      <view 
        wx:if="{{reviews.length === 0 && !isLoading}}"
        class="empty-state"
      >
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无评价</text>
        <text class="empty-tip">当用户对您的作品进行评价后，将在此处显示</text>
      </view>

      <view 
        wx:for="{{reviews}}" 
        wx:key="id"
        class="review-card {{item.isUnread ? 'unread' : ''}} {{item.isPendingReply ? 'pending-reply' : ''}} {{isSelectMode ? 'select-mode' : ''}}"
      >
        <view class="card-select" wx:if="{{isSelectMode}}" catchtap="toggleReviewSelection" data-id="{{item.id}}">
          <view class="checkbox {{selectedReviews.indexOf(item.id) > -1 ? 'checked' : ''}}">
            <text wx:if="{{selectedReviews.indexOf(item.id) > -1}}" class="check-icon">✓</text>
          </view>
        </view>

        <view class="card-content">
          <view class="card-header">
            <view class="user-info">
              <image 
                class="user-avatar" 
                src="{{item.is_anonymous ? '/assets/images/default-product.jpg' : (item.user_avatar || '/assets/images/default-product.jpg')}}"
                mode="aspectFill"
              />
              <view class="user-detail">
                <view class="user-name-row">
                  <text class="user-name">{{item.is_anonymous ? '匿名用户' : (item.user_name || '用户')}}</text>
                  <text class="user-role-tag" wx:if="{{!item.is_anonymous && item.user_role_label}}">{{item.user_role_label}}</text>
                </view>
                <view class="user-meta">
                  <text class="review-time">{{formatTime(item.created_at)}}</text>
                  <text class="rating-tag {{getRatingTagClass(item.overall_rating)}}">{{getRatingText(item.overall_rating)}}</text>
                  <view class="status-badge" wx:if="{{item.isUnread}}">
                    <text class="badge-text">未读</text>
                  </view>
                  <view class="status-badge pending" wx:if="{{item.isPendingReply}}">
                    <text class="badge-text">待回复</text>
                  </view>
                </view>
              </view>
            </view>
            <star-rating 
              value="{{item.overall_rating}}" 
              disabled="{{true}}"
              size="small"
              showValue="{{false}}"
            />
          </view>

          <view class="card-rating" wx:if="{{item.product_rating || item.teacher_rating || item.logistics_rating}}">
            <view class="rating-item-mini" wx:if="{{item.product_rating}}">
              <text class="rating-icon">🎨</text>
              <text class="rating-label-mini">商品</text>
              <text class="rating-value-mini">{{item.product_rating}}分</text>
            </view>
            <view class="rating-item-mini" wx:if="{{item.teacher_rating}}">
              <text class="rating-icon">👩‍🏫</text>
              <text class="rating-label-mini">教学</text>
              <text class="rating-value-mini">{{item.teacher_rating}}分</text>
            </view>
            <view class="rating-item-mini" wx:if="{{item.logistics_rating}}">
              <text class="rating-icon">🚚</text>
              <text class="rating-label-mini">物流</text>
              <text class="rating-value-mini">{{item.logistics_rating}}分</text>
            </view>
          </view>

          <view class="card-product" wx:if="{{item.product_info}}" catchtap="goToProductDetail" data-id="{{item.product_info.id}}">
            <image class="product-cover" src="{{item.product_info.cover_image || '/assets/images/default-product.jpg'}}" mode="aspectFill" />
            <view class="product-info">
              <text class="product-title">{{item.product_info.title}}</text>
              <text class="product-price">¥{{item.product_info.price}}</text>
            </view>
            <text class="product-arrow">›</text>
          </view>

          <view class="card-content" wx:if="{{item.content}}">
            <text class="review-content">{{item.content}}</text>
          </view>

          <view class="card-images" wx:if="{{item.images && item.images.length > 0}}">
            <view 
              wx:for="{{item.images.slice(0, 3)}}" 
              wx:key="*this"
              class="image-item"
              catchtap="previewImage"
              data-url="{{item}}"
              data-index="{{index}}"
            >
              <image class="review-image" src="{{item}}" mode="aspectFill" />
            </view>
            <view 
              wx:if="{{item.images.length > 3}}"
              class="image-more"
              catchtap="previewImage"
              data-url="{{item.images[0]}}"
              data-index="{{0}}"
            >
              <text class="more-text">+{{item.images.length - 3}}</text>
            </view>
          </view>

          <view class="card-reply" wx:if="{{item.reply}}">
            <view class="reply-header">
              <text class="reply-label">我的回复</text>
              <text class="reply-time">{{formatTime(item.reply_time)}}</text>
            </view>
            <text class="reply-content">{{item.reply}}</text>
          </view>

          <view class="card-actions">
            <view class="action-item" catchtap="openReplyDialog" data-id="{{item.id}}" data-index="{{index}}">
              <text class="action-icon">💬</text>
              <text class="action-text">{{item.isPendingReply ? '回复' : '编辑回复'}}</text>
            </view>
            <view class="action-item" catchtap="goToReviewDetail" data-id="{{item.id}}">
              <text class="action-icon">👁️</text>
              <text class="action-text">查看详情</text>
            </view>
            <view class="action-item" wx:if="{{item.isUnread}}" catchtap="markReviewAsRead" data-id="{{item.id}}">
              <text class="action-icon">📖</text>
              <text class="action-text">标记已读</text>
            </view>
          </view>
        </view>
      </view>

      <view class="load-more" wx:if="{{isLoadMore}}">
        <text class="load-text">加载中...</text>
      </view>

      <view class="no-more" wx:if="{{!hasMore && reviews.length > 0}}">
        <text class="no-more-text">没有更多了</text>
      </view>
    </view>
  </view>

  <view class="reply-dialog" wx:if="{{showReplyDialog}}">
    <view class="dialog-mask" catchtap="closeReplyDialog"></view>
    <view class="dialog-content">
      <view class="dialog-header">
        <text class="dialog-title">{{isEditingReply ? '编辑回复' : '回复评价'}}</text>
        <view class="dialog-close" catchtap="closeReplyDialog">
          <text class="close-icon">✕</text>
        </view>
      </view>
      
      <view class="dialog-body">
        <view class="review-preview">
          <view class="preview-user">
            <image class="preview-avatar" src="{{replyingReview.user_avatar || '/assets/images/default-product.jpg'}}" />
            <view class="preview-info">
              <text class="preview-name">{{replyingReview.is_anonymous ? '匿名用户' : (replyingReview.user_name || '用户')}}</text>
              <text class="preview-time">{{formatTime(replyingReview.created_at)}}</text>
            </view>
          </view>
          <text class="preview-content">{{replyingReview.content}}</text>
        </view>
        
        <view class="reply-input-section">
          <textarea 
            class="reply-input"
            placeholder="请输入回复内容..."
            value="{{replyContent}}"
            bindinput="onReplyInput"
            maxlength="500"
            auto-height
          />
          <view class="input-footer">
            <text class="char-count">{{replyContent.length}}/500</text>
          </view>
        </view>
      </view>
      
      <view class="dialog-footer">
        <view class="footer-btn cancel" catchtap="closeReplyDialog">
          <text class="btn-text">取消</text>
        </view>
        <view class="footer-btn danger" wx:if="{{isEditingReply}}" catchtap="cancelReply">
          <text class="btn-text">撤销回复</text>
        </view>
        <view class="footer-btn primary" catchtap="submitReply">
          <text class="btn-text">{{isEditingReply ? '更新' : '发送'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="stats-dialog" wx:if="{{showStatsDialog}}">
    <view class="dialog-mask" catchtap="closeStatsDialog"></view>
    <view class="stats-dialog-content">
      <view class="dialog-header">
        <text class="dialog-title">评价统计</text>
        <view class="dialog-close" catchtap="closeStatsDialog">
          <text class="close-icon">✕</text>
        </view>
      </view>
      
      <view class="stats-tabs">
        <view class="tab-item {{currentStatTab === 'overview' ? 'active' : ''}}" catchtap="onStatTabChange" data-tab="overview">
          <text class="tab-text">总体统计</text>
        </view>
        <view class="tab-item {{currentStatTab === 'trend' ? 'active' : ''}}" catchtap="onStatTabChange" data-tab="trend">
          <text class="tab-text">评分趋势</text>
        </view>
      </view>
      
      <view class="stats-tab-content" wx:if="{{currentStatTab === 'overview'}}">
        <view class="overview-stats">
          <view class="overview-item">
            <text class="overview-value">{{stats.avgRating}}</text>
            <text class="overview-label">平均评分</text>
          </view>
          <view class="overview-item">
            <text class="overview-value">{{stats.total}}</text>
            <text class="overview-label">评价总数</text>
          </view>
        </view>
        
        <view class="rating-breakdown">
          <view class="breakdown-title">评分分布</view>
          <view class="breakdown-item">
            <text class="breakdown-label">好评</text>
            <view class="breakdown-bar">
              <view class="bar-fill good" style="width: {{stats.total > 0 ? (stats.goodCount / stats.total * 100) : 0}}%"></view>
            </view>
            <text class="breakdown-value">{{stats.goodCount}}</text>
          </view>
          <view class="breakdown-item">
            <text class="breakdown-label">中评</text>
            <view class="breakdown-bar">
              <view class="bar-fill medium" style="width: {{stats.total > 0 ? (stats.mediumCount / stats.total * 100) : 0}}%"></view>
            </view>
            <text class="breakdown-value">{{stats.mediumCount}}</text>
          </view>
          <view class="breakdown-item">
            <text class="breakdown-label">差评</text>
            <view class="breakdown-bar">
              <view class="bar-fill bad" style="width: {{stats.total > 0 ? (stats.badCount / stats.total * 100) : 0}}%"></view>
            </view>
            <text class="breakdown-value">{{stats.badCount}}</text>
          </view>
        </view>
        
        <view class="status-stats">
          <view class="status-title">状态统计</view>
          <view class="status-list">
            <view class="status-item">
              <text class="status-icon">📖</text>
              <text class="status-label">未读评价</text>
              <text class="status-value">{{stats.unread}}</text>
            </view>
            <view class="status-item">
              <text class="status-icon">💬</text>
              <text class="status-label">待回复</text>
              <text class="status-value">{{stats.pendingReply}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="stats-tab-content" wx:if="{{currentStatTab === 'trend'}}">
        <view class="trend-controls">
          <view class="control-item {{trendStats.days === 7 ? 'active' : ''}}" catchtap="onTrendDaysChange" data-days="7">
            <text class="control-text">近7天</text>
          </view>
          <view class="control-item {{trendStats.days === 30 ? 'active' : ''}}" catchtap="onTrendDaysChange" data-days="30">
            <text class="control-text">近30天</text>
          </view>
          <view class="control-item {{trendStats.days === 90 ? 'active' : ''}}" catchtap="onTrendDaysChange" data-days="90">
            <text class="control-text">近90天</text>
          </view>
        </view>
        
        <view class="trend-chart" wx:if="{{trendStats.trendData && trendStats.trendData.length > 0}}">
          <view class="chart-title">评分趋势 (最近{{trendStats.days}}天)</view>
          <view class="chart-placeholder">
            <text class="placeholder-text">评分趋势图</text>
            <text class="placeholder-tip">展示最近{{trendStats.days}}天的平均评分变化</text>
            <view class="trend-list">
              <view class="trend-item" wx:for="{{trendStats.trendData}}" wx:key="date" wx:if="{{item.count > 0}}">
                <text class="trend-date">{{item.date}}</text>
                <view class="trend-rating">
                  <text class="rating-num">{{item.avg_rating}}</text>
                  <text class="rating-unit">分</text>
                </view>
                <text class="trend-count">{{item.count}}条评价</text>
              </view>
            </view>
          </view>
        </view>
        
        <view class="trend-empty" wx:else>
          <text class="empty-icon">📈</text>
          <text class="empty-text">暂无趋势数据</text>
        </view>
      </view>
    </view>
  </view>
</view>
