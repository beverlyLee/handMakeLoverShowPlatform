.teacher-reviews-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.reviews-content {
  display: flex;
  flex-direction: column;
}

.stats-header {
  background-color: #fff;
  padding: 20rpx 30rpx;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  position: relative;
}

.stats-main {
  display: flex;
  align-items: center;
}

.main-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.main-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin-right: 40rpx;
}

.main-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

.main-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-sub {
  display: flex;
  align-items: center;
}

.sub-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
}

.sub-badge {
  font-size: 24rpx;
  font-weight: bold;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 4rpx;
}

.sub-badge.unread {
  background-color: #FF5722;
}

.sub-badge.pending {
  background-color: #FF9800;
}

.sub-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-arrow {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
}

.arrow-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
}

.filter-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.filter-row {
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-row:last-child {
  border-bottom: none;
}

.filter-scroll,
.sort-scroll {
  white-space: nowrap;
}

.filter-list,
.sort-list {
  display: flex;
  padding: 0 20rpx;
}

.filter-item,
.sort-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin: 0 10rpx;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.filter-text,
.sort-text {
  font-size: 26rpx;
  color: #666;
}

.filter-item.active,
.sort-item.active {
  background-color: #FFF8E7;
}

.filter-item.active .filter-text,
.sort-item.active .sort-text {
  color: #795548;
  font-weight: 500;
}

.sort-row {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.sort-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.action-bar,
.normal-action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.action-left {
  display: flex;
  align-items: center;
}

.select-all-btn {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.checkbox.checked {
  background-color: #795548;
  border-color: #795548;
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
}

.select-all-text {
  font-size: 26rpx;
  color: #666;
}

.selected-count {
  font-size: 26rpx;
  color: #795548;
}

.action-right {
  display: flex;
  align-items: center;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  margin-left: 20rpx;
}

.action-btn.primary {
  background-color: #795548;
}

.action-btn.cancel {
  background-color: #f5f5f5;
}

.action-btn.outline {
  border: 1rpx solid #795548;
  background-color: #fff;
}

.action-btn-text {
  font-size: 26rpx;
}

.action-btn.primary .action-btn-text {
  color: #fff;
}

.action-btn.cancel .action-btn-text {
  color: #666;
}

.action-btn.outline .action-btn-text {
  color: #795548;
}

.review-count {
  font-size: 26rpx;
  color: #999;
}

.reviews-list {
  flex: 1;
  padding-bottom: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

.review-card {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  display: flex;
  transition: all 0.3s;
}

.review-card.unread {
  border-left: 6rpx solid #795548;
}

.review-card.pending-reply {
  background-color: #FFF5F5;
}

.review-card.select-mode {
  padding-left: 10rpx;
}

.card-select {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.user-detail {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-role-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  background-color: #E8F4FD;
  color: #1A73E8;
  flex-shrink: 0;
}

.user-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.review-time {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.rating-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.tag-good {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.tag-medium {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.tag-bad {
  background-color: rgba(244, 67, 54, 0.1);
  color: #F44336;
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  background-color: rgba(121, 85, 72, 0.1);
  color: #795548;
}

.status-badge.pending {
  background-color: rgba(255, 87, 34, 0.1);
  color: #FF5722;
}

.badge-text {
  font-size: 20rpx;
}

.card-rating {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
  background-color: #FFF8E7;
  border-radius: 12rpx;
}

.rating-item-mini {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rating-icon {
  font-size: 28rpx;
  margin-bottom: 6rpx;
}

.rating-label-mini {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.rating-value-mini {
  font-size: 26rpx;
  font-weight: bold;
  color: #FFB300;
}

.card-product {
  display: flex;
  align-items: center;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.product-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.product-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.product-title {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.product-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF5722;
}

.product-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 10rpx;
}

.card-content {
  margin-bottom: 20rpx;
}

.review-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.card-images {
  display: flex;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.review-image {
  width: 100%;
  height: 100%;
}

.image-more {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.card-reply {
  background-color: #FFF8E7;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.reply-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #795548;
}

.reply-time {
  font-size: 22rpx;
  color: #999;
}

.reply-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.card-actions {
  display: flex;
  justify-content: flex-start;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background-color: #f5f5f5;
  margin-right: 20rpx;
}

.action-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
}

.load-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}

.reply-dialog,
.stats-dialog {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.dialog-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.dialog-content,
.stats-dialog-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.stats-dialog-content {
  max-height: 90vh;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.dialog-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 32rpx;
  color: #999;
}

.dialog-body {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.review-preview {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.preview-user {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.preview-info {
  display: flex;
  flex-direction: column;
}

.preview-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.preview-time {
  font-size: 22rpx;
  color: #999;
}

.preview-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.reply-input-section {
  display: flex;
  flex-direction: column;
}

.reply-input {
  width: 100%;
  min-height: 200rpx;
  max-height: 400rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.input-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 10rpx;
}

.char-count {
  font-size: 22rpx;
  color: #999;
}

.dialog-footer {
  display: flex;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  margin: 0 10rpx;
}

.footer-btn.cancel {
  background-color: #f5f5f5;
}

.footer-btn.danger {
  background-color: rgba(255, 87, 34, 0.1);
}

.footer-btn.primary {
  background-color: #795548;
}

.btn-text {
  font-size: 28rpx;
}

.footer-btn.cancel .btn-text {
  color: #666;
}

.footer-btn.danger .btn-text {
  color: #FF5722;
}

.footer-btn.primary .btn-text {
  color: #fff;
}

.stats-tabs {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #795548;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: 500;
}

.stats-tab-content {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

.overview-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  margin-bottom: 30rpx;
  background-color: #FFF8E7;
  border-radius: 16rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #795548;
  margin-bottom: 8rpx;
}

.overview-label {
  font-size: 24rpx;
  color: #999;
}

.rating-breakdown {
  margin-bottom: 30rpx;
}

.breakdown-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.breakdown-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.breakdown-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.breakdown-bar {
  flex: 1;
  height: 16rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.bar-fill.good {
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
}

.bar-fill.medium {
  background: linear-gradient(90deg, #FF9800, #FFC107);
}

.bar-fill.bad {
  background: linear-gradient(90deg, #F44336, #FF5722);
}

.breakdown-value {
  width: 60rpx;
  font-size: 26rpx;
  color: #999;
  text-align: right;
  flex-shrink: 0;
}

.status-stats {
  margin-bottom: 30rpx;
}

.status-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.status-list {
  display: flex;
  justify-content: space-around;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.status-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.status-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #795548;
}

.trend-controls {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.control-item {
  padding: 12rpx 30rpx;
  border-radius: 32rpx;
  margin: 0 10rpx;
  background-color: #f5f5f5;
}

.control-item.active {
  background-color: #795548;
}

.control-text {
  font-size: 26rpx;
  color: #666;
}

.control-item.active .control-text {
  color: #fff;
}

.trend-chart {
  margin-bottom: 30rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.chart-placeholder {
  background-color: #f9f9f9;
  border-radius: 16rpx;
  padding: 30rpx;
}

.placeholder-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 10rpx;
  text-align: center;
}

.placeholder-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
  text-align: center;
}

.trend-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.trend-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.trend-item:last-child {
  border-bottom: none;
}

.trend-date {
  font-size: 24rpx;
  color: #666;
  width: 160rpx;
}

.trend-rating {
  display: flex;
  align-items: baseline;
}

.rating-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #795548;
}

.rating-unit {
  font-size: 20rpx;
  color: #999;
  margin-left: 4rpx;
}

.trend-count {
  font-size: 24rpx;
  color: #999;
}

.trend-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
