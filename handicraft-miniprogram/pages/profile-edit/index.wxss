/* pages/profile-edit/index.wxss */

.profile-edit-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 120rpx;
}

.avatar-section {
  background-color: #FFFFFF;
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  border: 4rpx solid #F0E6D2;
}

.avatar-edit {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background-color: #E67E22;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFFFFF;
  border: 4rpx solid #FFFFFF;
}

.avatar-tip {
  font-size: 24rpx;
  color: #BCAAA4;
}

.form-section {
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0E6D2;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #5D4037;
  flex-shrink: 0;
}

.form-value {
  flex: 1;
  font-size: 28rpx;
  color: #795548;
  text-align: right;
}

.form-value.placeholder {
  color: #BCAAA4;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #5D4037;
  text-align: right;
}

.form-input::placeholder {
  color: #BCAAA4;
}

.form-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #BCAAA4;
  border-right: 2rpx solid #BCAAA4;
  transform: rotate(45deg);
  margin-left: 16rpx;
}

.textarea-section {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.textarea-label {
  font-size: 28rpx;
  color: #5D4037;
  margin-bottom: 16rpx;
}

.textarea-content {
  width: 100%;
  height: 200rpx;
  font-size: 26rpx;
  color: #5D4037;
  line-height: 1.6;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.textarea-content::placeholder {
  color: #BCAAA4;
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: #BCAAA4;
  margin-top: 12rpx;
}

.role-section {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.role-title {
  font-size: 28rpx;
  color: #5D4037;
  margin-bottom: 20rpx;
}

.role-options {
  display: flex;
  gap: 24rpx;
}

.role-option {
  flex: 1;
  padding: 28rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.role-option.active {
  border-color: #E67E22;
  background-color: rgba(230, 126, 34, 0.05);
}

.role-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.role-name {
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 22rpx;
  color: #BCAAA4;
}

.save-btn {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
  z-index: 100;
  padding-bottom: calc(0rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(0rpx + env(safe-area-inset-bottom));
}
