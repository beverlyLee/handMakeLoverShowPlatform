<view class="reviews-container">
  <view class="loading-container" wx:if="{{isLoading && reviews.length === 0}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:else class="reviews-content">
    <view class="stats-section" wx:if="{{stats.total > 0}}">
      <view class="stats-overview">
        <view class="overview-item">
          <text class="overview-value">{{stats.avgRating}}</text>
          <text class="overview-label">平均评分</text>
        </view>
        <view class="overview-item">
          <text class="overview-value">{{stats.total}}</text>
          <text class="overview-label">评价总数</text>
        </view>
      </view>
      <view class="stats-breakdown">
        <view class="breakdown-item">
          <text class="breakdown-label">好评</text>
          <view class="breakdown-bar">
            <view class="bar-fill good" style="width: {{stats.total > 0 ? (stats.goodCount / stats.total * 100) : 0}}%"></view>
          </view>
          <text class="breakdown-value">{{stats.goodCount}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-label">中评</text>
          <view class="breakdown-bar">
            <view class="bar-fill medium" style="width: {{stats.total > 0 ? (stats.mediumCount / stats.total * 100) : 0}}%"></view>
          </view>
          <text class="breakdown-value">{{stats.mediumCount}}</text>
        </view>
        <view class="breakdown-item">
          <text class="breakdown-label">差评</text>
          <view class="breakdown-bar">
            <view class="bar-fill bad" style="width: {{stats.total > 0 ? (stats.badCount / stats.total * 100) : 0}}%"></view>
          </view>
          <text class="breakdown-value">{{stats.badCount}}</text>
        </view>
      </view>
    </view>

    <view class="filter-section">
      <scroll-view class="type-scroll" scroll-x>
        <view class="type-list">
          <view 
            wx:for="{{filterTypes}}" 
            wx:key="key"
            class="type-item {{currentType === item.key ? 'active' : ''}}"
            bindtap="onTypeChange"
            data-type="{{item.key}}"
          >
            <text class="type-text">{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
      
      <scroll-view class="rating-scroll" scroll-x>
        <view class="rating-list">
          <view 
            wx:for="{{ratingFilters}}" 
            wx:key="key"
            class="rating-item {{currentRating === item.key ? 'active' : ''}}"
            bindtap="onRatingChange"
            data-rating="{{item.key}}"
          >
            <text class="rating-text">{{item.label}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="reviews-list">
      <view 
        wx:if="{{reviews.length === 0 && !isLoading}}"
        class="empty-state"
      >
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无评价</text>
      </view>

      <view 
        wx:for="{{reviews}}" 
        wx:key="id"
        class="review-card"
        bindtap="goToReviewDetail"
        data-id="{{item.id}}"
        data-order-id="{{item.order_id}}"
      >
        <view class="card-header">
          <view class="user-info">
            <image 
              class="user-avatar" 
              src="{{item.is_anonymous ? '/images/default-avatar.png' : (item.user_avatar || '/images/default-avatar.png')}}"
              mode="aspectFill"
            />
            <view class="user-detail">
              <text class="user-name">{{item.is_anonymous ? '匿名用户' : (item.user_name || '用户')}}</text>
              <view class="user-meta">
                <text class="review-time">{{formatTime(item.created_at)}}</text>
                <text class="rating-tag {{getRatingTagClass(item.overall_rating)}}">{{getRatingText(item.overall_rating)}}</text>
              </view>
            </view>
          </view>
          <star-rating 
            value="{{item.overall_rating}}" 
            disabled="{{true}}"
            size="small"
            showValue="{{false}}"
          />
        </view>

        <view class="card-rating">
          <view class="rating-item-mini">
            <text class="rating-icon">🎨</text>
            <text class="rating-label-mini">商品</text>
            <text class="rating-value-mini">{{item.product_rating}}分</text>
          </view>
          <view class="rating-item-mini">
            <text class="rating-icon">👩‍🏫</text>
            <text class="rating-label-mini">老师</text>
            <text class="rating-value-mini">{{item.teacher_rating}}分</text>
          </view>
          <view class="rating-item-mini">
            <text class="rating-icon">🚚</text>
            <text class="rating-label-mini">物流</text>
            <text class="rating-value-mini">{{item.logistics_rating}}分</text>
          </view>
        </view>

        <view class="card-content" wx:if="{{item.content}}">
          <text class="review-content">{{item.content}}</text>
        </view>

        <view class="card-images" wx:if="{{item.images && item.images.length > 0}}">
          <view 
            wx:for="{{item.images.slice(0, 3)}}" 
            wx:key="*this"
            class="image-item"
            catchtap="previewImage"
            data-url="{{item}}"
            data-index="{{index}}"
          >
            <image class="review-image" src="{{item}}" mode="aspectFill" />
          </view>
          <view 
            wx:if="{{item.images.length > 3}}"
            class="image-more"
            catchtap="previewImage"
            data-url="{{item.images[0]}}"
            data-index="{{0}}"
          >
            <text class="more-text">+{{item.images.length - 3}}</text>
          </view>
        </view>

        <view class="card-reply" wx:if="{{item.reply}}">
          <view class="reply-header">
            <text class="reply-label">老师回复</text>
            <text class="reply-time">{{formatTime(item.reply_time)}}</text>
          </view>
          <text class="reply-content">{{item.reply}}</text>
        </view>

        <view class="card-actions">
          <view 
            class="action-item {{item.is_liked ? 'liked' : ''}}"
            catchtap="handleLike"
            data-id="{{item.id}}"
            data-index="{{index}}"
          >
            <text class="action-icon">{{item.is_liked ? '❤️' : '🤍'}}</text>
            <text class="action-text">{{item.like_count > 0 ? item.like_count : '点赞'}}</text>
          </view>
        </view>
      </view>

      <view class="load-more" wx:if="{{isLoadMore}}">
        <text class="load-text">加载中...</text>
      </view>

      <view class="no-more" wx:if="{{!hasMore && reviews.length > 0}}">
        <text class="no-more-text">没有更多了</text>
      </view>
    </view>
  </view>
</view>
