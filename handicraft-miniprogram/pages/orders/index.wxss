.orders-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.role-banner {
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
  padding: 20rpx 30rpx;
}

.role-banner-customer {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.banner-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.banner-text {
  font-size: 26rpx;
  color: #5D4037;
  font-weight: 500;
}

.stats-section {
  background-color: #fff;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #795548;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #8D6E63;
  margin-top: 8rpx;
}

.stats-summary {
  text-align: center;
  padding-top: 16rpx;
  border-top: 1rpx dashed #EFEFEF;
}

.summary-text {
  font-size: 24rpx;
  color: #A1887F;
}

.search-section {
  background-color: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  padding: 8rpx 24rpx;
  background-color: #795548;
  border-radius: 24rpx;
  margin-left: 16rpx;
}

.search-btn-text {
  font-size: 24rpx;
  color: #fff;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
}

.clear-icon {
  font-size: 32rpx;
  color: #999;
  line-height: 1;
}

.tabs-section {
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tabs-header {
  display: flex;
  align-items: center;
  padding-right: 16rpx;
}

.tabs-scroll {
  flex: 1;
  white-space: nowrap;
}

.tabs-list {
  display: flex;
  padding: 0 20rpx;
}

.tab-item {
  position: relative;
  padding: 30rpx 30rpx;
  margin-right: 20rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: bold;
}

.tab-badge {
  position: absolute;
  top: 20rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #FF5722;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #795548;
  border-radius: 3rpx;
}

.search-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 32rpx;
}

.pending-alert {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  padding: 20rpx 30rpx;
  margin: 16rpx 20rpx;
  border-radius: 12rpx;
  border-left: 8rpx solid #FF9800;
}

.alert-content {
  display: flex;
  align-items: center;
}

.alert-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.alert-text {
  font-size: 26rpx;
  color: #E65100;
  font-weight: 500;
}

.orders-list {
  padding: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.teacher-order-card {
  border-left: 8rpx solid #FFB74D;
}

.pending-accept-card {
  border-left: 8rpx solid #FF5722;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(255, 87, 34, 0.4);
  }
  70% {
    box-shadow: 0 0 0 10rpx rgba(255, 87, 34, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(255, 87, 34, 0);
  }
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.shop-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.shop-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.shop-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.teacher-shop-info .shop-name {
  color: #E65100;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.order-status.pending {
  background-color: #FFF3E0;
}

.order-status.pending .status-text {
  color: #E65100;
}

.order-status.pending_accept {
  background-color: #FFEBEE;
}

.order-status.pending_accept .status-text {
  color: #C62828;
}

.order-status.accepted {
  background-color: #E8F5E9;
}

.order-status.accepted .status-text {
  color: #2E7D32;
}

.order-status.paid {
  background-color: #E3F2FD;
}

.order-status.paid .status-text {
  color: #1565C0;
}

.order-status.shipped {
  background-color: #F3E5F5;
}

.order-status.shipped .status-text {
  color: #7B1FA2;
}

.order-status.delivered {
  background-color: #E0F7FA;
}

.order-status.delivered .status-text {
  color: #00838F;
}

.order-status.completed {
  background-color: #E8F5E9;
}

.order-status.completed .status-text {
  color: #2E7D32;
}

.order-status.cancelled {
  background-color: #F5F5F5;
}

.order-status.cancelled .status-text {
  color: #999;
}

.order-status.rejected {
  background-color: #FFEBEE;
}

.order-status.rejected .status-text {
  color: #C62828;
}

.pending-highlight {
  background-color: #FF5722;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.highlight-text {
  font-size: 20rpx;
  color: #fff;
}

.status-text {
  font-size: 24rpx;
}

.expand-icon {
  font-size: 20rpx;
  color: #999;
  margin-left: 12rpx;
  transition: transform 0.3s;
}

.order-card.expanded .expand-icon {
  transform: rotate(90deg);
}

.order-items {
  padding: 20rpx;
}

.order-item {
  display: flex;
  padding: 16rpx 0;
}

.order-item:first-child {
  padding-top: 0;
}

.order-item:last-child {
  padding-bottom: 0;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #F5F5F5;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 28rpx;
  color: #E64A19;
  font-weight: bold;
}

.item-quantity {
  font-size: 26rpx;
  color: #999;
}

.order-footer {
  padding: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.order-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-text {
  font-size: 24rpx;
  color: #999;
}

.total-price {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 24rpx;
  color: #666;
}

.total-amount {
  font-size: 32rpx;
  color: #E64A19;
  font-weight: bold;
  margin-left: 8rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  flex-wrap: wrap;
}

.action-btn {
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  line-height: 64rpx;
  border: none;
  margin: 0;
}

.action-btn.primary {
  background-color: #795548;
  color: #fff;
}

.action-btn.secondary {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #DDD;
}

.action-btn.reject-btn {
  color: #F44336;
  border-color: #FFCDD2;
}

.order-detail-expand {
  background-color: #FAFAFA;
  padding: 0 20rpx 20rpx;
  border-top: 1rpx solid #EFEFEF;
}

.expand-section {
  padding: 20rpx 0;
  border-bottom: 1rpx dashed #E0E0E0;
}

.expand-section:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.expand-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.title-text {
  font-size: 26rpx;
  color: #5D4037;
  font-weight: bold;
}

.expand-content {
  padding-left: 8rpx;
}

.content-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  display: block;
}

.content-text.address-detail {
  color: #8D6E63;
  margin-top: 4rpx;
}

.content-text.reject-reason {
  color: #C62828;
  background-color: #FFEBEE;
  padding: 16rpx;
  border-radius: 8rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
  align-items: center;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 24rpx;
  color: #5D4037;
  flex: 1;
}

.tracking-row {
  cursor: pointer;
}

.tracking-number {
  color: #1976D2;
}

.copy-hint {
  font-size: 20rpx;
  color: #999;
  margin-left: 12rpx;
  padding: 4rpx 12rpx;
  background-color: #E3F2FD;
  border-radius: 8rpx;
}

.logistics-timeline {
  position: relative;
  padding-left: 40rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: 24rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -40rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #D7CCC8;
  border: 3rpx solid #FFF;
}

.timeline-item.latest .timeline-dot {
  background-color: #FF9800;
  width: 20rpx;
  height: 20rpx;
  left: -42rpx;
}

.timeline-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.timeline-desc {
  font-size: 24rpx;
  color: #5D4037;
  line-height: 1.5;
}

.timeline-item.latest .timeline-desc {
  color: #E65100;
  font-weight: bold;
}

.timeline-location {
  font-size: 22rpx;
  color: #A1887F;
}

.timeline-time {
  font-size: 20rpx;
  color: #BDBDBD;
}

.price-detail {
  padding: 16rpx;
  background-color: #FFF;
  border-radius: 12rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.price-row:last-child {
  margin-bottom: 0;
}

.price-row.total {
  padding-top: 16rpx;
  border-top: 1rpx solid #EFEFEF;
  margin-top: 8rpx;
}

.price-label {
  font-size: 24rpx;
  color: #999;
}

.price-label.discount {
  color: #E65100;
}

.price-value {
  font-size: 24rpx;
  color: #5D4037;
}

.price-value.discount {
  color: #E65100;
}

.price-value.free {
  color: #4CAF50;
}

.price-value.total {
  font-size: 28rpx;
  color: #E65100;
  font-weight: bold;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-shopping-btn {
  background-color: #795548;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
}

.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  width: 85%;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
}

.reject-header {
  background: linear-gradient(135deg, #FFEBEE 0%, #FFCDD2 100%);
}

.ship-header {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.dialog-title {
  font-size: 32rpx;
  color: #5D4037;
  font-weight: bold;
}

.dialog-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 40rpx;
  color: #8D6E63;
  line-height: 1;
}

.dialog-content {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.info-item {
  display: flex;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item.address-item {
  align-items: flex-start;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
  line-height: 1.5;
}

.dialog-tip {
  margin-top: 30rpx;
  padding: 20rpx;
  background-color: #FFF8E7;
  border-radius: 12rpx;
}

.reject-tip {
  background-color: #FFEBEE;
}

.tip-text {
  font-size: 24rpx;
  color: #8D6E63;
}

.reject-tip .tip-text {
  color: #C62828;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.required {
  color: #F44336;
  margin-left: 4rpx;
}

.form-textarea {
  width: 100%;
  height: 180rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
  display: block;
}

.form-picker {
  width: 100%;
}

.picker-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.picker-text {
  font-size: 26rpx;
  color: #333;
}

.picker-text:empty {
  color: #999;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.dialog-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn-cancel {
  background-color: #F5F5F5;
  color: #666;
}

.dialog-btn-confirm {
  background: linear-gradient(135deg, #795548 0%, #6D4C41 100%);
  color: #fff;
}

.dialog-btn-reject {
  background: linear-gradient(135deg, #F44336 0%, #D32F2F 100%);
  color: #fff;
}
