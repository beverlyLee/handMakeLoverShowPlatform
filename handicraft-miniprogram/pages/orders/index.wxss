.orders-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.tabs-section {
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-list {
  display: flex;
  padding: 0 20rpx;
}

.tab-item {
  position: relative;
  padding: 30rpx 30rpx;
  margin-right: 20rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #795548;
  font-weight: bold;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #795548;
  border-radius: 3rpx;
}

.orders-list {
  padding: 20rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.shop-info {
  display: flex;
  align-items: center;
}

.shop-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.shop-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.arrow-icon {
  font-size: 32rpx;
  color: #999;
  margin-left: 8rpx;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.order-status.pending {
  background-color: #FFF3E0;
}

.order-status.pending .status-text {
  color: #E65100;
}

.order-status.paid {
  background-color: #E3F2FD;
}

.order-status.paid .status-text {
  color: #1565C0;
}

.order-status.shipped {
  background-color: #F3E5F5;
}

.order-status.shipped .status-text {
  color: #7B1FA2;
}

.order-status.completed {
  background-color: #E8F5E9;
}

.order-status.completed .status-text {
  color: #2E7D32;
}

.order-status.cancelled {
  background-color: #F5F5F5;
}

.order-status.cancelled .status-text {
  color: #999;
}

.status-text {
  font-size: 24rpx;
}

.order-items {
  padding: 20rpx;
}

.order-item {
  display: flex;
  padding: 16rpx 0;
}

.order-item:first-child {
  padding-top: 0;
}

.order-item:last-child {
  padding-bottom: 0;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #F5F5F5;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 28rpx;
  color: #E64A19;
  font-weight: bold;
}

.item-quantity {
  font-size: 26rpx;
  color: #999;
}

.order-footer {
  padding: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.order-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-text {
  font-size: 24rpx;
  color: #999;
}

.total-price {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 24rpx;
  color: #666;
}

.total-amount {
  font-size: 32rpx;
  color: #E64A19;
  font-weight: bold;
  margin-left: 8rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.action-btn {
  height: 64rpx;
  padding: 0 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  line-height: 64rpx;
  border: none;
  margin: 0;
}

.action-btn.primary {
  background-color: #795548;
  color: #fff;
}

.action-btn.secondary {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #DDD;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-shopping-btn {
  background-color: #795548;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
}
