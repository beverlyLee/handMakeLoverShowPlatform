/* pages/login/index.wxss */

.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 64rpx;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 126, 34, 0.2);
}

.login-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #BCAAA4;
  margin-bottom: 80rpx;
}

.login-form {
  width: 100%;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #795548;
  margin-bottom: 16rpx;
}

.form-input-group {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
}

.form-input-group:focus-within {
  border-color: #E67E22;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #BCAAA4;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #5D4037;
}

.form-input::placeholder {
  color: #BCAAA4;
}

.code-btn {
  padding: 12rpx 20rpx;
  background-color: rgba(230, 126, 34, 0.1);
  color: #E67E22;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.code-btn.disabled {
  color: #BCAAA4;
  background-color: #F5F5F5;
}

.agreement {
  display: flex;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.checkbox-icon {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 6rpx;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox-icon.checked {
  background-color: #E67E22;
  border-color: #E67E22;
  color: #FFFFFF;
  font-size: 24rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #BCAAA4;
  line-height: 1.6;
}

.agreement-link {
  color: #E67E22;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
  margin-bottom: 32rpx;
}

.login-btn.disabled {
  background: #BCAAA4;
  box-shadow: none;
}

.wechat-login {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 48rpx;
}

.wechat-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.other-login {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-title {
  font-size: 24rpx;
  color: #BCAAA4;
  margin-bottom: 24rpx;
  position: relative;
}

.other-title::before,
.other-title::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 80rpx;
  height: 1rpx;
  background-color: #E8E8E8;
}

.other-title::before {
  left: -100rpx;
}

.other-title::after {
  right: -100rpx;
}

.other-icons {
  display: flex;
  gap: 48rpx;
}

.other-icon-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.login-footer {
  margin-top: auto;
  padding-top: 48rpx;
  font-size: 24rpx;
  color: #BCAAA4;
}

.footer-link {
  color: #E67E22;
  margin: 0 16rpx;
}
