/* pages/product-detail/index.wxss */

.product-detail-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 120rpx;
}

.product-swiper {
  width: 100%;
  height: 600rpx;
  background-color: #FFFFFF;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-info {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.product-price {
  font-size: 44rpx;
  color: #E67E22;
  font-weight: 600;
}

.product-price::before {
  content: '¥';
  font-size: 0.7em;
}

.product-original-price {
  font-size: 26rpx;
  color: #BCAAA4;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.product-original-price::before {
  content: '¥';
}

.product-sales {
  font-size: 24rpx;
  color: #BCAAA4;
  margin-left: auto;
}

.product-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5D4037;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.product-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.product-tag {
  padding: 4rpx 16rpx;
  background-color: rgba(230, 126, 34, 0.1);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #E67E22;
}

.teacher-card {
  background-color: #FFFFFF;
  margin-top: 16rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
}

.teacher-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.teacher-info {
  flex: 1;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 8rpx;
}

.teacher-stats {
  font-size: 24rpx;
  color: #BCAAA4;
}

.teacher-follow {
  padding: 12rpx 32rpx;
  background-color: #E67E22;
  color: #FFFFFF;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.product-specs {
  background-color: #FFFFFF;
  margin-top: 16rpx;
  padding: 24rpx 32rpx;
}

.specs-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 20rpx;
}

.specs-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0E6D2;
}

.specs-item:last-child {
  border-bottom: none;
}

.specs-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #BCAAA4;
  flex-shrink: 0;
}

.specs-value {
  flex: 1;
  font-size: 26rpx;
  color: #5D4037;
}

.product-description {
  background-color: #FFFFFF;
  margin-top: 16rpx;
  padding: 24rpx 32rpx;
}

.desc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 20rpx;
}

.desc-content {
  font-size: 26rpx;
  color: #795548;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 16rpx rgba(93, 64, 55, 0.06);
  z-index: 100;
}

.bottom-actions {
  display: flex;
  margin-right: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
  position: relative;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 22rpx;
  color: #795548;
}

.action-badge {
  position: absolute;
  top: -4rpx;
  right: 12rpx;
  min-width: 28rpx;
  height: 28rpx;
  background-color: #E74C3C;
  border-radius: 14rpx;
  font-size: 18rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-buttons {
  display: flex;
  flex: 1;
  gap: 16rpx;
}

.btn-cart {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: rgba(230, 126, 34, 0.1);
  color: #E67E22;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-buy {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #E67E22;
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
}
