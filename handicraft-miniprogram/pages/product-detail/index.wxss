.product-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.image-section {
  width: 100%;
  background-color: #fff;
}

.image-swiper {
  width: 100%;
  height: 750rpx;
}

.product-image {
  width: 100%;
  height: 100%;
}

.info-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: #E64A19;
  margin-right: 4rpx;
}

.product-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #E64A19;
}

.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.stats-section {
  display: flex;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 30rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.title-section {
  margin-top: 20rpx;
}

.product-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
}

.product-tag {
  font-size: 22rpx;
  color: #795548;
  background-color: rgba(121, 85, 72, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
  margin-bottom: 10rpx;
}

.teacher-card {
  background-color: #fff;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.teacher-header {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.teacher-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #e0e0e0;
}

.teacher-info {
  flex: 1;
}

.teacher-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.teacher-badge {
  font-size: 24rpx;
  color: #FFB300;
  background-color: rgba(255, 179, 0, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.teacher-stats {
  font-size: 24rpx;
  color: #999;
}

.arrow-icon {
  font-size: 36rpx;
  color: #ccc;
}

.teacher-actions {
  display: flex;
  margin-top: 20rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.action-btn::after {
  border: none;
}

.action-btn-primary {
  background-color: #795548;
  color: #fff;
}

.action-btn-secondary {
  background-color: rgba(121, 85, 72, 0.1);
  color: #795548;
}

.description-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.view-all {
  font-size: 26rpx;
  color: #795548;
}

.description-content {
  padding-top: 10rpx;
}

.description-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.specs-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.specs-list {
  padding-top: 10rpx;
}

.spec-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.spec-item:last-child {
  border-bottom: none;
}

.spec-label {
  font-size: 28rpx;
  color: #999;
  width: 160rpx;
}

.spec-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.more-works-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bar-actions {
  display: flex;
  margin-right: 20rpx;
}

.action-icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-text {
  font-size: 20rpx;
  color: #666;
}

.bar-buttons {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.btn-cart,
.btn-buy {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.btn-cart::after,
.btn-buy::after {
  border: none;
}

.btn-cart {
  background-color: rgba(121, 85, 72, 0.15);
  color: #795548;
}

.btn-buy {
  background-color: #795548;
  color: #fff;
}
