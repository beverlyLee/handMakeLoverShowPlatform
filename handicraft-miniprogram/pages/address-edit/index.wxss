page {
  background-color: #FFF8E7;
  height: 100%;
}

.edit-container {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

.form-section {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.08);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(121, 85, 72, 0.08);
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 180rpx;
  font-size: 30rpx;
  color: #5D4037;
  font-weight: 500;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #5D4037;
}

.form-input::placeholder {
  color: #BCAAA4;
}

.form-item-picker {
  justify-content: space-between;
}

.picker-value {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #5D4037;
  margin-right: 16rpx;
}

.picker-placeholder {
  color: #BCAAA4;
}

.picker-icon {
  font-size: 28rpx;
}

.picker-arrow {
  font-size: 32rpx;
  color: #D7CCC8;
  font-weight: 300;
}

.form-item-textarea {
  flex-direction: column;
  align-items: flex-start;
}

.form-item-textarea .form-label {
  margin-bottom: 20rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.6;
  background-color: rgba(121, 85, 72, 0.03);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.form-textarea::placeholder {
  color: #BCAAA4;
}

.char-count {
  width: 100%;
  text-align: right;
  font-size: 22rpx;
  color: #A1887F;
  margin-top: 12rpx;
}

.settings-section {
  margin-top: 20rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.08);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.setting-icon {
  font-size: 32rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #5D4037;
}

.tips-section {
  margin-top: 30rpx;
  padding: 24rpx;
  background-color: rgba(255, 183, 77, 0.1);
  border-radius: 16rpx;
  border: 2rpx solid rgba(255, 152, 0, 0.2);
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: #E65100;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #8D6E63;
  line-height: 1.8;
}

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #FFF8E7;
  border-top: 1rpx solid rgba(121, 85, 72, 0.08);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #795548, #8D6E63);
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(121, 85, 72, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.submit-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
