.home-container {
  padding: 40rpx;
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 40rpx;
}

.welcome-section {
  margin-top: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #795548;
}

.description-section {
  margin-bottom: 40rpx;
  padding: 30rpx;
  background-color: rgba(121, 85, 72, 0.1);
  border-radius: 16rpx;
}

.description-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

.sort-section {
  position: relative;
  z-index: 100;
  margin-bottom: 20rpx;
}

.sort-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.sort-selector {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #fff;
  border-radius: 30rpx;
  border: 2rpx solid #e0e0e0;
}

.current-sort {
  font-size: 26rpx;
  color: #795548;
  margin-right: 10rpx;
}

.sort-arrow {
  font-size: 20rpx;
  color: #795548;
  transition: transform 0.3s;
}

.sort-arrow.up {
  transform: rotate(180deg);
}

.sort-dropdown {
  position: absolute;
  top: 100%;
  right: 0;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  padding: 10rpx 0;
  min-width: 280rpx;
  z-index: 200;
}

.sort-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sort-option:last-child {
  border-bottom: none;
}

.sort-option.active .sort-option-text {
  color: #795548;
  font-weight: bold;
}

.sort-option-text {
  font-size: 28rpx;
  color: #333;
}

.sort-check {
  font-size: 28rpx;
  color: #795548;
  font-weight: bold;
}

.sort-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
}

.products-section {
  margin-top: 20rpx;
}

.products-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s, box-shadow 0.2s;
}

.product-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 340rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-tags-overlay {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  flex-wrap: wrap;
  max-width: 70%;
}

.product-tag {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(121, 85, 72, 0.85);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.product-stats {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  display: flex;
}

.stat-item {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
}

.product-info {
  padding: 16rpx;
}

.product-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.teacher-info {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx solid #f5f5f5;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 12rpx;
}

.teacher-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.teacher-name {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.teacher-rating {
  font-size: 22rpx;
  color: #FFB300;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #E64A19;
  margin-right: 2rpx;
}

.product-price {
  font-size: 34rpx;
  font-weight: bold;
  color: #E64A19;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.favorite-section {
  display: flex;
  align-items: center;
}

.favorite-icon {
  font-size: 24rpx;
  color: #E64A19;
  margin-right: 4rpx;
}

.favorite-count {
  font-size: 22rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.load-more-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  justify-content: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
}
