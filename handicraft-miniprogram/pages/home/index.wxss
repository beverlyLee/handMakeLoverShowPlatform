.home-container {
  padding: 40rpx;
  min-height: 100vh;
  background-color: #FFF8E7;
}

.welcome-section {
  margin-top: 60rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #795548;
}

.description-section {
  margin-bottom: 60rpx;
  padding: 30rpx;
  background-color: rgba(121, 85, 72, 0.1);
  border-radius: 16rpx;
}

.description-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

.features-section {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
  margin-bottom: 40rpx;
  padding: 30rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.feature-title {
  font-size: 26rpx;
  color: #795548;
  font-weight: 500;
}
