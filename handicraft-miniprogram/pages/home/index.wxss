.home-container {
  padding: 40rpx;
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 40rpx;
}

.welcome-section {
  margin-top: 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.welcome-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #795548;
}

.description-section {
  margin-bottom: 40rpx;
  padding: 30rpx;
  background-color: rgba(121, 85, 72, 0.1);
  border-radius: 16rpx;
}

.description-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

.categories-section {
  margin-top: 20rpx;
}

.section-header {
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.category-list {
  display: flex;
  flex-direction: column;
}

.category-item {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.category-header {
  padding: 24rpx;
  background-color: rgba(121, 85, 72, 0.05);
  border-bottom: 1rpx solid #f0f0f0;
}

.category-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #795548;
  display: block;
  margin-bottom: 8rpx;
}

.category-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.hot-products-section {
  position: relative;
  padding: 20rpx;
}

.product-swiper {
  width: 100%;
  height: 580rpx;
}

.swiper-item {
  width: 100%;
  height: 100%;
}

.hot-product-card {
  width: 100%;
  height: 100%;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}

.hot-product-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.1);
}

.product-image-wrapper {
  position: relative;
  width: 100%;
  height: 380rpx;
  overflow: hidden;
}

.product-image {
  width: 100%;
  height: 100%;
}

.product-tags-overlay {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  flex-wrap: wrap;
  max-width: 70%;
}

.product-tag {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(121, 85, 72, 0.85);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.product-stats {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  display: flex;
}

.stat-item {
  font-size: 20rpx;
  color: #fff;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
}

.product-info {
  padding: 20rpx;
}

.product-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.product-price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #E64A19;
  margin-right: 2rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #E64A19;
}

.original-price {
  font-size: 22rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.popularity-section {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background-color: rgba(230, 74, 25, 0.1);
  border-radius: 20rpx;
}

.popularity-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.popularity-text {
  font-size: 22rpx;
  color: #E64A19;
  font-weight: 500;
}

.swiper-indicator {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  background-color: rgba(0, 0, 0, 0.6);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  z-index: 10;
}

.indicator-text {
  font-size: 22rpx;
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
