<view class="home-container">
  <view class="welcome-section">
    <text class="welcome-text">{{welcomeText}}</text>
  </view>
  
  <view class="description-section">
    <text class="description-text">在这里，您可以分享您的手工作品，与其他手工爱好者交流学习，发现更多创意灵感！</text>
  </view>

  <view class="categories-section">
    <view class="section-header">
      <text class="section-title">精选作品</text>
    </view>

    <view class="loading-state" wx:if="{{isLoading && categories.length === 0}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="empty-state" wx:elif="{{!isLoading && categories.length === 0}}">
      <text class="empty-icon">🎨</text>
      <text class="empty-text">暂无分类</text>
      <text class="empty-desc">快来发现更多精彩手作吧</text>
    </view>

    <view class="category-list" wx:else>
      <view 
        wx:for="{{categories}}" 
        wx:key="id" 
        class="category-item"
        wx:if="{{item.hot_products && item.hot_products.length > 0}}"
      >
        <view class="category-header">
          <text class="category-name">{{item.name}}</text>
          <text class="category-desc" wx:if="{{item.description}}">{{item.description}}</text>
        </view>

        <view class="hot-products-section">
          <swiper 
            class="product-swiper" 
            indicator-dots="{{item.hot_products.length > 1}}" 
            indicator-color="rgba(255,255,255,0.5)"
            indicator-active-color="#795548"
            autoplay="{{true}}" 
            circular="{{item.hot_products.length > 1}}"
            bindchange="onSwiperChange"
            data-category-id="{{item.id}}"
            interval="3000"
            duration="500"
          >
            <swiper-item 
              wx:for="{{item.hot_products}}" 
              wx:for-item="product" 
              wx:key="id"
              class="swiper-item"
            >
              <view 
                class="hot-product-card"
                bindtap="goToProductDetail"
                data-id="{{product.id}}"
              >
                <view class="product-image-wrapper">
                  <image 
                    class="product-image" 
                    src="{{product.cover_image || defaultImage}}" 
                    mode="aspectFill" 
                    binderror="onImageError"
                    data-category-id="{{item.id}}"
                    data-product-index="{{index}}"
                  />
                  <view class="product-tags-overlay" wx:if="{{product.tags && product.tags.length > 0}}">
                    <text 
                      wx:for="{{product.tags}}" 
                      wx:for-item="tag" 
                      wx:key="*this" 
                      class="product-tag"
                    >{{tag}}</text>
                  </view>
                  <view class="product-stats" wx:if="{{product.sales_count > 0 || product.favorite_count > 0}}">
                    <text class="stat-item" wx:if="{{product.sales_count > 0}}">已售{{product.sales_count}}</text>
                    <text class="stat-item" wx:if="{{product.favorite_count > 0}}">{{product.favorite_count}}人收藏</text>
                  </view>
                </view>
                
                <view class="product-info">
                  <text class="product-title" lines="2">{{product.title}}</text>
                  
                  <view class="product-price-row">
                    <view class="price-section">
                      <text class="price-symbol">¥</text>
                      <text class="product-price">{{product.price}}</text>
                      <text class="original-price" wx:if="{{product.original_price > product.price}}">¥{{product.original_price}}</text>
                    </view>
                    <view class="popularity-section" catchtap="preventBubble">
                      <like-button 
                        product-id="{{product.id}}"
                        is-liked="{{product.is_liked}}"
                        like-count="{{product.popularity_score || 0}}"
                        size="small"
                        show-count="{{true}}"
                        bind:change="onLikeChange"
                        data-category-id="{{item.id}}"
                        data-product-index="{{index}}"
                      />
                    </view>
                  </view>
                </view>
              </view>
            </swiper-item>
          </swiper>
          
          <view class="swiper-indicator" wx:if="{{item.hot_products.length > 1}}">
            <text class="indicator-text">{{currentSwiperIndex[item.id] + 1}}/{{item.hot_products.length}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
