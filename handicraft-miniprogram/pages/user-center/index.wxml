<view class="user-center-container">
  <!-- 用户头像和基本信息 -->
  <view class="user-header-section">
    <view class="avatar-wrapper">
      <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill" />
      <view class="avatar-decorator">
        <text class="decorator-icon">🎨</text>
      </view>
    </view>
    <view class="user-basic-info">
      <text class="user-nickname">{{userInfo.nickname}}</text>
      <view class="user-role-badge">
        <text class="role-text">{{userInfo.role === 'teacher' ? '手作老师' : '手作爱好者'}}</text>
      </view>
    </view>
  </view>

  <!-- 用户详细信息卡片 -->
  <view class="info-card-section">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">📋</text>
        <text class="header-title">个人信息</text>
      </view>
      <view class="header-decorator"></view>
    </view>

    <view class="info-list">
      <view class="info-item">
        <view class="info-label-wrapper">
          <text class="info-icon">👤</text>
          <text class="info-label">用户名</text>
        </view>
        <text class="info-value">{{userInfo.username}}</text>
      </view>

      <view class="info-item">
        <view class="info-label-wrapper">
          <text class="info-icon">📞</text>
          <text class="info-label">手机号</text>
        </view>
        <text class="info-value">{{userInfo.phone}}</text>
      </view>

      <view class="info-item">
        <view class="info-label-wrapper">
          <text class="info-icon">📧</text>
          <text class="info-label">邮箱</text>
        </view>
        <text class="info-value">{{userInfo.email || '未设置'}}</text>
      </view>

      <view class="info-item">
        <view class="info-label-wrapper">
          <text class="info-icon">⚥</text>
          <text class="info-label">性别</text>
        </view>
        <text class="info-value">{{genderText}}</text>
      </view>

      <view class="info-item">
        <view class="info-label-wrapper">
          <text class="info-icon">📅</text>
          <text class="info-label">注册时间</text>
        </view>
        <text class="info-value">{{userInfo.create_time}}</text>
      </view>
    </view>
  </view>

  <!-- 个人简介区域 -->
  <view class="bio-card-section">
    <view class="card-header">
      <view class="header-left">
        <text class="header-icon">✍️</text>
        <text class="header-title">个人简介</text>
      </view>
      <view class="edit-btn {{isEditingBio ? 'save-btn' : ''}}" bindtap="toggleBioEdit">
        <text class="edit-btn-text">{{isEditingBio ? '保存' : '编辑'}}</text>
      </view>
    </view>

    <view class="bio-content">
      <view wx:if="{{!isEditingBio}}" class="bio-display">
        <text class="bio-text">{{userInfo.bio || '暂无简介，点击编辑添加~'}}</text>
        <view class="bio-decorator">
          <text class="bio-decorator-text">✨ 用心创造，用爱分享 ✨</text>
        </view>
      </view>

      <view wx:else class="bio-edit-wrapper">
        <textarea 
          class="bio-textarea" 
          value="{{editBioValue}}" 
          placeholder="分享你的手作故事..."
          maxlength="200"
          bindinput="onBioInput"
          auto-height
        />
        <view class="textarea-footer">
          <text class="char-count">{{editBioValue.length}}/200</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="bottom-decorator">
    <view class="decorator-line"></view>
    <view class="decorator-icons">
      <text class="decor-icon">🧶</text>
      <text class="decor-icon">🎨</text>
      <text class="decor-icon">🪡</text>
      <text class="decor-icon">✂️</text>
      <text class="decor-icon">🧵</text>
    </view>
  </view>
</view>
