.user-center-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 40rpx;
}

/* 用户头像区域 */
.user-header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  background: linear-gradient(180deg, #795548 0%, #8D6E63 50%, #A1887F 100%);
  position: relative;
}

.user-header-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50rpx;
  background-color: #FFF8E7;
  border-radius: 50rpx 50rpx 0 0;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 30rpx;
  z-index: 1;
}

.user-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid #FFF8E7;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.avatar-edit-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.6) 100%);
  border-radius: 0 0 100rpx 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 12rpx;
}

.camera-icon {
  font-size: 28rpx;
}

.edit-text {
  font-size: 20rpx;
  color: #fff;
  margin-top: 4rpx;
}

.user-basic-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}

.user-nickname {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFF8E7;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.user-role-badge {
  padding: 10rpx 32rpx;
  background-color: rgba(255, 248, 231, 0.35);
  border-radius: 30rpx;
  border: 2rpx solid rgba(255, 248, 231, 0.6);
}

.role-text {
  font-size: 26rpx;
  color: #FFF8E7;
  font-weight: 500;
}

/* 卡片通用样式 */
.info-card-section,
.bio-card-section,
.quick-actions-section {
  margin: 40rpx 30rpx 0;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(121, 85, 72, 0.08);
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 36rpx;
  background-color: rgba(121, 85, 72, 0.03);
  border-bottom: 1rpx solid rgba(121, 85, 72, 0.08);
}

.header-left {
  display: flex;
  align-items: center;
}

.header-icon {
  font-size: 38rpx;
  margin-right: 18rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5D4037;
}

/* 信息列表 */
.info-list {
  padding: 0 36rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1rpx dashed rgba(121, 85, 72, 0.12);
}

.info-item:last-child {
  border-bottom: none;
}

.info-item-disabled {
  opacity: 0.6;
}

.info-label-wrapper {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 34rpx;
  margin-right: 18rpx;
}

.info-label {
  font-size: 30rpx;
  color: #6D4C41;
  font-weight: 500;
}

.info-value-wrapper {
  display: flex;
  align-items: center;
  max-width: 55%;
}

.info-value {
  font-size: 28rpx;
  color: #8D6E63;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value-disabled {
  color: #BCAAA4;
}

.arrow-icon {
  font-size: 36rpx;
  color: #D7CCC8;
  margin-left: 16rpx;
  font-weight: 300;
}

/* 个人简介内容 */
.bio-content {
  padding: 36rpx;
}

.bio-text {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.9;
  text-align: justify;
  min-height: 80rpx;
}

.bio-text-placeholder {
  color: #BCAAA4;
}

.bio-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(121, 85, 72, 0.08);
}

.char-count {
  font-size: 22rpx;
  color: #A1887F;
}

/* 快捷入口列表 */
.quick-actions-list {
  padding: 0 36rpx;
}

.action-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1rpx dashed rgba(121, 85, 72, 0.12);
}

.action-item:last-child {
  border-bottom: none;
}

.action-left {
  display: flex;
  align-items: center;
}

.action-icon {
  font-size: 34rpx;
  margin-right: 18rpx;
}

.action-label {
  font-size: 30rpx;
  color: #6D4C41;
  font-weight: 500;
}

/* 退出登录区域 */
.logout-section {
  margin: 60rpx 30rpx 0;
  display: flex;
  justify-content: center;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 80rpx;
  background-color: #fff;
  border-radius: 50rpx;
  border: 2rpx solid rgba(220, 53, 69, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(220, 53, 69, 0.08);
}

.logout-btn::after {
  border: none;
}

.logout-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.logout-text {
  font-size: 30rpx;
  color: #DC3545;
  font-weight: 500;
}

/* 底部装饰 */
.bottom-decorator {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
}

.decorator-icons {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 20rpx;
}

.decor-icon {
  font-size: 44rpx;
  opacity: 0.5;
}

.decor-text {
  font-size: 24rpx;
  color: #A1887F;
  font-style: italic;
}

/* 编辑弹窗 */
.edit-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.edit-dialog {
  width: 85%;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx;
  border-bottom: 1rpx solid rgba(121, 85, 72, 0.1);
}

.dialog-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #5D4037;
}

.dialog-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 48rpx;
  color: #A1887F;
  font-weight: 300;
  line-height: 1;
}

.dialog-content {
  padding: 36rpx;
}

.edit-input {
  width: 100%;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
  color: #5D4037;
  background-color: rgba(121, 85, 72, 0.03);
  border: 2rpx solid rgba(121, 85, 72, 0.15);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.edit-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.8;
  background-color: rgba(121, 85, 72, 0.03);
  border: 2rpx solid rgba(121, 85, 72, 0.15);
  border-radius: 16rpx;
  box-sizing: border-box;
}

.edit-input::placeholder,
.edit-textarea::placeholder {
  color: #BCAAA4;
}

.dialog-char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #A1887F;
  margin-top: 16rpx;
}

.dialog-footer {
  display: flex;
  border-top: 1rpx solid rgba(121, 85, 72, 0.1);
}

.dialog-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background-color: transparent;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn-cancel {
  color: #A1887F;
  border-right: 1rpx solid rgba(121, 85, 72, 0.1);
}

.dialog-btn-confirm {
  color: #795548;
  font-weight: bold;
}

/* 适配安全区域 */
page {
  background-color: #FFF8E7;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
