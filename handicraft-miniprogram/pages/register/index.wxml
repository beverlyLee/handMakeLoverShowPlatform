<view class="register-container">
  <view class="register-logo">🎨</view>
  <view class="register-title">完善信息</view>
  <view class="register-subtitle">开启您的手工创作之旅</view>

  <view class="register-form">
    <view class="form-group" wx:if="{{needBindPhone}}">
      <view class="form-label">头像</view>
      <button class="avatar-upload" open-type="chooseAvatar" bindchooseavatar="chooseAvatar">
        <image wx:if="{{avatar}}" class="avatar-preview" src="{{avatar}}" mode="aspectFill"></image>
        <view wx:else class="avatar-placeholder">
          <text class="avatar-icon">+</text>
          <text class="avatar-tip">点击选择头像</text>
        </view>
      </button>
    </view>

    <view class="form-group" wx:if="{{needBindPhone}}">
      <view class="form-label">昵称</view>
      <view class="form-input-group">
        <input 
          class="form-input" 
          type="nickname" 
          placeholder="请输入昵称" 
          value="{{nickname}}"
          bindblur="onNicknameBlur"
        />
      </view>
    </view>

    <view class="form-group">
      <view class="form-label">手机号</view>
      <view class="form-input-group">
        <text class="input-icon">📱</text>
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入手机号" 
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
    </view>

    <view class="form-group">
      <view class="form-label">验证码</view>
      <view class="form-input-group">
        <text class="input-icon">🔐</text>
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入验证码" 
          maxlength="6"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view 
          class="code-btn {{codeBtnDisabled ? 'disabled' : ''}}" 
          bindtap="getCode"
        >
          {{codeBtnText}}
        </view>
      </view>
    </view>

    <view class="agreement" bindtap="toggleAgreement">
      <view class="checkbox-icon {{agreeAgreement ? 'checked' : ''}}">
        <text wx:if="{{agreeAgreement}}">✓</text>
      </view>
      <view class="agreement-text">
        我已阅读并同意
        <text class="agreement-link">《用户协议》</text>
        和
        <text class="agreement-link">《隐私政策》</text>
      </view>
    </view>

    <view class="register-btn {{!agreeAgreement ? 'disabled' : ''}}" bindtap="doRegister">
      完成注册
    </view>

    <view class="login-link">
      已有账号？
      <text class="login-link-text" bindtap="goToLogin">立即登录</text>
    </view>
  </view>

  <view class="register-footer">
    手工爱好者平台 © 2024
  </view>
</view>
