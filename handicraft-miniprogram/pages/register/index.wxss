.register-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E7 0%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 64rpx;
  box-sizing: border-box;
}

.register-logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 126, 34, 0.2);
}

.register-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #5D4037;
  margin-bottom: 16rpx;
}

.register-subtitle {
  font-size: 28rpx;
  color: #BCAAA4;
  margin-bottom: 80rpx;
}

.register-form {
  width: 100%;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #795548;
  margin-bottom: 16rpx;
}

.form-input-group {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
}

.form-input-group:focus-within {
  border-color: #E67E22;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #BCAAA4;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #5D4037;
}

.form-input::placeholder {
  color: #BCAAA4;
}

.code-btn {
  padding: 12rpx 20rpx;
  background-color: rgba(230, 126, 34, 0.1);
  color: #E67E22;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.code-btn.disabled {
  color: #BCAAA4;
  background-color: #F5F5F5;
}

.avatar-upload {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 2rpx dashed #E8E8E8;
  position: relative;
  overflow: hidden;
}

.avatar-preview {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-icon {
  font-size: 48rpx;
  color: #BCAAA4;
  margin-bottom: 8rpx;
}

.avatar-tip {
  font-size: 22rpx;
  color: #BCAAA4;
}

.agreement {
  display: flex;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.checkbox-icon {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 6rpx;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox-icon.checked {
  background-color: #E67E22;
  border-color: #E67E22;
  color: #FFFFFF;
  font-size: 24rpx;
}

.agreement-text {
  font-size: 24rpx;
  color: #BCAAA4;
  line-height: 1.6;
}

.agreement-link {
  color: #E67E22;
}

.register-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
  margin-bottom: 32rpx;
}

.register-btn.disabled {
  background: #BCAAA4;
  box-shadow: none;
}

.login-link {
  display: flex;
  justify-content: center;
  font-size: 26rpx;
  color: #BCAAA4;
}

.login-link-text {
  color: #E67E22;
  margin-left: 8rpx;
}

.register-footer {
  margin-top: auto;
  padding-top: 48rpx;
  font-size: 24rpx;
  color: #BCAAA4;
}
