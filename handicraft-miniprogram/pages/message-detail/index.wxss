.message-detail-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #A1887F;
}

.message-header-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.06);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-text {
  font-size: 40rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.message-type {
  font-size: 30rpx;
  color: #5D4037;
  font-weight: 600;
}

.message-status {
  font-size: 22rpx;
  color: #E65100;
  background-color: rgba(230, 81, 0, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  width: fit-content;
}

.header-right {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(220, 53, 69, 0.08);
  border-radius: 50%;
}

.delete-icon {
  font-size: 32rpx;
}

.message-info-card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.06);
}

.info-section {
  padding: 24rpx;
}

.info-section:first-child {
  border-bottom: 1rpx solid rgba(121, 85, 72, 0.08);
}

.sender-section {
  background: linear-gradient(135deg, rgba(255, 248, 231, 0.8) 0%, rgba(255, 237, 204, 0.6) 100%);
}

.sender-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.sender-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  border: 2rpx solid rgba(121, 85, 72, 0.1);
}

.avatar-placeholder {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #A1887F 0%, #8D6E63 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 32rpx;
}

.sender-text-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.sender-name {
  font-size: 28rpx;
  color: #5D4037;
  font-weight: 500;
}

.send-time {
  font-size: 22rpx;
  color: #A1887F;
}

.title-section {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.message-title {
  font-size: 32rpx;
  color: #5D4037;
  font-weight: 600;
  line-height: 1.6;
}

.message-body-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(121, 85, 72, 0.06);
}

.body-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.header-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(121, 85, 72, 0.2) 50%, transparent 100%);
}

.body-label {
  font-size: 24rpx;
  color: #A1887F;
  background-color: rgba(121, 85, 72, 0.05);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.message-content-text {
  background-color: rgba(255, 248, 231, 0.6);
  border-radius: 16rpx;
  padding: 24rpx;
}

.content-text {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 2;
  white-space: pre-wrap;
  word-break: break-all;
}

.message-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(121, 85, 72, 0.1);
}

.action-btn.secondary {
  background-color: #fff;
  border: 2rpx solid rgba(121, 85, 72, 0.2);
}

.action-btn.primary {
  background: linear-gradient(135deg, #795548 0%, #8D6E63 100%);
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.secondary .action-text {
  color: #795548;
}

.action-btn.primary .action-text {
  color: #FFF8E7;
}

.bottom-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 40rpx 20rpx;
  background-color: rgba(121, 85, 72, 0.03);
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #A1887F;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon-wrapper {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, rgba(121, 85, 72, 0.08) 0%, rgba(141, 110, 99, 0.06) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-title {
  font-size: 34rpx;
  color: #5D4037;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #A1887F;
}

page {
  background-color: #FFF8E7;
}
