/* pages/message-detail/index.wxss */

.message-detail-container {
  min-height: 100vh;
  background-color: #FFFFFF;
}

.message-detail-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #F0E6D2;
}

.message-title {
  font-size: 32rpx;
  color: #5D4037;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.message-meta {
  display: flex;
  align-items: center;
}

.meta-tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.meta-tag.system {
  background-color: rgba(230, 126, 34, 0.1);
  color: #E67E22;
}

.meta-tag.order {
  background-color: rgba(33, 150, 243, 0.1);
  color: #2196F3;
}

.meta-tag.interaction {
  background-color: rgba(156, 39, 176, 0.1);
  color: #9C27B0;
}

.meta-time {
  font-size: 24rpx;
  color: #BCAAA4;
}

.message-detail-content {
  padding: 32rpx;
}

.content-text {
  font-size: 28rpx;
  color: #5D4037;
  line-height: 1.8;
}

.content-section {
  margin-bottom: 24rpx;
}

.content-section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #5D4037;
  margin-bottom: 16rpx;
}

.content-image {
  width: 100%;
  border-radius: 12rpx;
  background-color: #F5F5F5;
  margin-bottom: 16rpx;
}

.order-card {
  background-color: #FFFAF0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.order-info {
  display: flex;
  margin-bottom: 16rpx;
}

.order-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background-color: #FFFFFF;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.order-detail {
  flex: 1;
}

.order-title {
  font-size: 26rpx;
  color: #5D4037;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.order-specs {
  font-size: 22rpx;
  color: #BCAAA4;
}

.order-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(230, 126, 34, 0.1);
}

.order-no {
  font-size: 22rpx;
  color: #BCAAA4;
}

.order-price {
  font-size: 28rpx;
  color: #E67E22;
  font-weight: 600;
}

.order-price::before {
  content: '¥';
  font-size: 0.8em;
}

.action-section {
  padding: 32rpx;
  border-top: 1rpx solid #F0E6D2;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #E67E22;
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.secondary {
  background-color: transparent;
  border: 2rpx solid #E67E22;
  color: #E67E22;
  margin-top: 16rpx;
}
