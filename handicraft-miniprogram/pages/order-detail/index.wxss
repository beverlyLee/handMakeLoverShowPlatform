/* pages/order-detail/index.wxss */

.order-detail-container {
  min-height: 100vh;
  background-color: #FFF8E7;
  padding-bottom: 120rpx;
}

.order-status-section {
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  padding: 40rpx 32rpx;
  color: #FFFFFF;
}

.status-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.progress-section {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.progress-steps {
  display: flex;
  justify-content: space-between;
  position: relative;
}

.progress-steps::before {
  content: '';
  position: absolute;
  top: 24rpx;
  left: 48rpx;
  right: 48rpx;
  height: 2rpx;
  background-color: #E8E8E8;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #E8E8E8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.progress-step.active .step-dot {
  background-color: #E67E22;
  color: #FFFFFF;
}

.progress-step.completed .step-dot {
  background-color: #27AE60;
  color: #FFFFFF;
}

.step-text {
  font-size: 22rpx;
  color: #BCAAA4;
}

.progress-step.active .step-text,
.progress-step.completed .step-text {
  color: #5D4037;
  font-weight: 500;
}

.progress-line {
  position: absolute;
  top: 24rpx;
  left: 48rpx;
  height: 2rpx;
  background-color: #27AE60;
  z-index: 1;
}

.address-section {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.address-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  color: #E67E22;
}

.address-info {
  flex: 1;
}

.address-name {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.name-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4037;
  margin-right: 24rpx;
}

.phone-text {
  font-size: 28rpx;
  color: #795548;
}

.address-detail {
  font-size: 26rpx;
  color: #795548;
  line-height: 1.5;
}

.product-section {
  background-color: #FFFFFF;
  margin-bottom: 16rpx;
}

.product-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #F0E6D2;
}

.shop-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #5D4037;
  display: flex;
  align-items: center;
}

.shop-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.product-item {
  display: flex;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0E6D2;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #F5F5F5;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-title {
  font-size: 28rpx;
  color: #5D4037;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.product-specs {
  font-size: 24rpx;
  color: #BCAAA4;
  margin-top: 8rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.product-price {
  font-size: 30rpx;
  color: #E67E22;
  font-weight: 600;
}

.product-price::before {
  content: '¥';
  font-size: 0.8em;
}

.product-quantity {
  font-size: 24rpx;
  color: #BCAAA4;
}

.order-info-section {
  background-color: #FFFFFF;
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0E6D2;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #BCAAA4;
}

.info-value {
  font-size: 26rpx;
  color: #5D4037;
}

.total-section {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #5D4037;
}

.total-price {
  font-size: 40rpx;
  color: #E67E22;
  font-weight: 600;
}

.total-price::before {
  content: '¥';
  font-size: 0.7em;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  box-shadow: 0 -2rpx 16rpx rgba(93, 64, 55, 0.06);
  z-index: 100;
}

.bottom-btn {
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.bottom-btn.primary {
  background-color: #E67E22;
  color: #FFFFFF;
}

.bottom-btn.secondary {
  background-color: transparent;
  border: 2rpx solid #BCAAA4;
  color: #795548;
}
