.review-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.already-reviewed {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.reviewed-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.reviewed-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #4CAF50;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.reviewed-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.reviewed-info {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.reviewed-rating {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.rating-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.reviewed-content {
  margin-bottom: 24rpx;
}

.reviewed-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.reviewed-images {
  display: flex;
  flex-wrap: wrap;
}

.reviewed-image-item {
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.reviewed-image {
  width: 100%;
  height: 100%;
}

.reviewed-actions {
  width: 100%;
}

.btn-view-detail {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #795548;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-view-detail::after {
  border: none;
}

.review-form {
  height: 100vh;
  padding-bottom: 140rpx;
}

.order-info-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.product-card {
  display: flex;
  padding: 20rpx;
  background-color: #FFF8E7;
  border-radius: 12rpx;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.product-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.rating-section {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.rating-section .section-header {
  padding: 30rpx;
  margin-bottom: 0;
  cursor: pointer;
}

.header-left {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.section-rating {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
}

.rating-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFB300;
  margin-right: 8rpx;
}

.rating-badge {
  font-size: 22rpx;
  color: #4CAF50;
  background-color: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.section-progress {
  margin-left: 20rpx;
}

.progress-text {
  font-size: 22rpx;
  color: #FF9800;
  background-color: rgba(255, 152, 0, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: #ccc;
  transform: rotate(90deg);
  transition: transform 0.3s;
}

.arrow-down {
  transform: rotate(-90deg);
}

.section-content {
  padding: 0 30rpx 30rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.rating-intro {
  padding: 20rpx 0;
}

.intro-text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.detail-items {
  margin-top: 10rpx;
}

.detail-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-item:last-child {
  border-bottom: none;
}

.item-header {
  margin-bottom: 16rpx;
}

.item-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-right: 12rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #999;
}

.item-rating {
  display: flex;
  justify-content: flex-start;
}

.section-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #FFF8E7;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #795548;
}

.summary-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFB300;
}

.rating-summary-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.summary-overall {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFB300;
}

.summary-breakdown {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.breakdown-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.breakdown-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.breakdown-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #795548;
}

.content-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.content-input-wrapper {
  position: relative;
}

.content-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.images-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.images-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  color: #fff;
  font-size: 24rpx;
}

.add-image {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f9f9f9;
  border: 2rpx dashed #ddd;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.anonymous-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.anonymous-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.anonymous-label {
  font-size: 28rpx;
  color: #333;
}

.anonymous-hint {
  font-size: 24rpx;
  color: #999;
}

.bottom-spacer {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  display: flex;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.bar-summary {
  display: flex;
  align-items: baseline;
  margin-right: 30rpx;
}

.bar-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.bar-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFB300;
}

.btn-submit {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #795548;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-submit::after {
  border: none;
}

.btn-submit.disabled {
  background-color: #ccc;
}
