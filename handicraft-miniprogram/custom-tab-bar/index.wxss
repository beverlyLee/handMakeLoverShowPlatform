.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  display: flex;
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
}

.tab-badge {
  position: absolute;
  top: -12rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #E64A19;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.badge-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: bold;
}

.tab-text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.tab-bar-item.active .tab-text {
  color: #795548;
  font-weight: 500;
}

.tab-bar-item.active .tab-icon {
  transform: scale(1.1);
}
