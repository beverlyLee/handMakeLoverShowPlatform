/* ============================================
   手工爱好者平台 - 全局样式
   ============================================ */

/* ---------- 页面基础样式 ---------- */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #5D4037;
  background-color: #FFF8E7;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ---------- 重置样式 ---------- */

view, text, scroll-view, swiper, swiper-item,
movable-view, movable-area, cover-view, cover-image {
  box-sizing: border-box;
}

/* ---------- 文字样式 ---------- */

/* 价格样式 */
.price {
  color: #E67E22;
  font-weight: 600;
}

.price::before {
  content: '¥';
  font-size: 0.8em;
}

/* 原价样式（划线） */
.original-price {
  color: #BCAAA4;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.original-price::before {
  content: '¥';
}

/* 销量样式 */
.sales {
  color: #BCAAA4;
  font-size: 22rpx;
}

/* ---------- 图标占位 ---------- */

/* 空状态图标占位 */
.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin: 80rpx auto 24rpx;
  opacity: 0.6;
}

/* 加载动画 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48rpx;
}

/* ---------- 表单样式 ---------- */

/* 表单组 */
.form-group {
  background-color: #FFFFFF;
  padding: 0 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F0E6D2;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #5D4037;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #5D4037;
}

.form-input::placeholder {
  color: #BCAAA4;
}

.form-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #BCAAA4;
  border-right: 2rpx solid #BCAAA4;
  transform: rotate(45deg);
  margin-left: 16rpx;
}

/* ---------- 列表样式 ---------- */

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #F0E6D2;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 28rpx;
  color: #5D4037;
}

.list-item-desc {
  font-size: 24rpx;
  color: #BCAAA4;
  margin-top: 8rpx;
}

/* ---------- 底部固定栏 ---------- */

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(93, 64, 55, 0.06);
  display: flex;
  align-items: center;
  z-index: 100;
}

/* ---------- 状态标签 ---------- */

.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.status-pending {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

.status-confirm {
  background-color: rgba(33, 150, 243, 0.1);
  color: #2196F3;
}

.status-ship {
  background-color: rgba(156, 39, 176, 0.1);
  color: #9C27B0;
}

.status-shipped {
  background-color: rgba(0, 188, 212, 0.1);
  color: #00BCD4;
}

.status-completed {
  background-color: rgba(76, 175, 80, 0.1);
  color: #4CAF50;
}

.status-cancelled {
  background-color: rgba(158, 158, 158, 0.1);
  color: #9E9E9E;
}

/* ---------- 通用按钮大小 ---------- */

.btn-sm {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
}

.btn-lg {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
}

.btn-block {
  width: 100%;
}

/* ---------- 间距工具 ---------- */

/* 页面底部留白，避免被TabBar遮挡 */
.page-bottom-padding {
  padding-bottom: 120rpx;
}

/* 页面顶部留白 */
.page-top-padding {
  padding-top: 24rpx;
}

/* 页面水平内边距 */
.page-horizontal-padding {
  padding-left: 32rpx;
  padding-right: 32rpx;
}
