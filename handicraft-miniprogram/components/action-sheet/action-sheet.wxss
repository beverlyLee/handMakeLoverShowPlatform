.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.action-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.action-mask.fadeIn {
  opacity: 1;
}

.action-mask.fadeOut {
  opacity: 0;
}

.action-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFF8E7;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.action-content.slideUp {
  transform: translateY(0);
}

.action-content.slideDown {
  transform: translateY(100%);
}

.action-title {
  padding: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #BCAAA4;
  border-bottom: 1rpx solid #F0E6D2;
}

.action-list {
  background-color: #FFFFFF;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  font-size: 30rpx;
  color: #5D4037;
  border-bottom: 1rpx solid #F0E6D2;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item.danger {
  color: #E74C3C;
}

.action-item.disabled {
  color: #BCAAA4;
  opacity: 0.5;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.action-text {
  font-weight: 500;
}

.action-cancel {
  margin-top: 16rpx;
  background-color: #FFFFFF;
}

.cancel-item {
  padding: 32rpx;
  text-align: center;
  font-size: 30rpx;
  color: #795548;
  font-weight: 500;
}
