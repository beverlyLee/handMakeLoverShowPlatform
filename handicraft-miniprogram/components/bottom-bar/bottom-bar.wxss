.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  box-sizing: border-box;
}

.bottom-left,
.bottom-center,
.bottom-right {
  display: flex;
  align-items: center;
}

.bottom-left {
  flex-shrink: 0;
}

.bottom-center {
  flex: 1;
  justify-content: center;
}

.bottom-right {
  flex-shrink: 0;
  justify-content: flex-end;
}

.bottom-placeholder {
  width: 100%;
  flex-shrink: 0;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
}

.btn-primary {
  background: linear-gradient(135deg, #E67E22 0%, #F39C12 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(230, 126, 34, 0.3);
}

.btn-secondary {
  background-color: rgba(230, 126, 34, 0.1);
  color: #E67E22;
}

.btn-outline {
  border: 2rpx solid #E67E22;
  color: #E67E22;
  background-color: transparent;
}

.btn-disable {
  background-color: #BCAAA4;
  color: #FFFFFF;
  box-shadow: none;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-large {
  padding: 20rpx 48rpx;
  font-size: 30rpx;
}

.btn-block {
  width: 100%;
}

.icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
}

.icon-btn-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.icon-btn-text {
  font-size: 22rpx;
  color: #795548;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 26rpx;
  color: #5D4037;
}

-price-value {
  font-size: 40rpx;
  color: #E67E22;
  font-weight: 600;
  margin-left: 8rpx;
}

.price-value::before {
  content: '¥';
  font-size: 0.7em;
}
