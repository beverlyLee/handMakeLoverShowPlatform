<view class="empty-state">
  <view class="empty-icon">{{icon || iconMap[type]}}</view>
  <view class="empty-title">{{title}}</view>
  <view wx:if="{{description}}" class="empty-desc">{{description}}</view>
  <view wx:if="{{showButton}}" class="empty-btn" bindtap="onButtonTap">{{buttonText}}</view>
</view>
