.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 248, 231, 0.9);
}

.loading-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.spinner-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.spinner {
  border-width: 4rpx;
  border-style: solid;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.dots-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  animation: dotBounce 1.4s ease-in-out infinite both;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes dotBounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.pulse-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.pulse {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  animation: pulse 1.2s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    transform: scale(0.9);
    opacity: 1;
  }
  100% {
    transform: scale(1.3);
    opacity: 0;
  }
}

.skeleton-wrapper {
  width: 100%;
  padding: 24rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #F0E6D2 25%, #FFFAF0 37%, #F0E6D2 63%);
  background-size: 400% 100%;
  animation: skeletonShine 1.4s ease infinite;
  margin-bottom: 20rpx;
}

.skeleton-title {
  height: 28rpx;
  width: 60%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #F0E6D2 25%, #FFFAF0 37%, #F0E6D2 63%);
  background-size: 400% 100%;
  animation: skeletonShine 1.4s ease infinite;
  margin-bottom: 16rpx;
}

.skeleton-text {
  height: 24rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #F0E6D2 25%, #FFFAF0 37%, #F0E6D2 63%);
  background-size: 400% 100%;
  animation: skeletonShine 1.4s ease infinite;
  margin-bottom: 12rpx;
}

.skeleton-text.short {
  width: 60%;
}

.skeleton-line {
  height: 20rpx;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #F0E6D2 25%, #FFFAF0 37%, #F0E6D2 63%);
  background-size: 400% 100%;
  animation: skeletonShine 1.4s ease infinite;
  margin-bottom: 16rpx;
}

.skeleton-line.short {
  width: 50%;
}

@keyframes skeletonShine {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.loading-text {
  font-size: 26rpx;
  color: #795548;
  margin-top: 24rpx;
}
