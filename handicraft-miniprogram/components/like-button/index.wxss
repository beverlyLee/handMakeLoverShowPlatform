.like-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #fff9f9 0%, #fff5f5 100%);
  border: 2rpx dashed #ffb6c1;
  box-shadow: 0 3rpx 12rpx rgba(255, 182, 193, 0.3);
  transition: all 0.3s ease;
}

.like-button.default {
  padding: 10rpx 18rpx;
}

.like-button.small {
  padding: 6rpx 12rpx;
}

.like-button.large {
  padding: 12rpx 22rpx;
}

.like-button.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.like-button.liked {
  background: linear-gradient(135deg, #ffe6ea 0%, #ffd9e0 100%);
  border-color: #ff69b4;
}

.like-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.like-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.popularity-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding-left: 12rpx;
  border-left: 2rpx dashed #ffe4b5;
}

.like-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.2) 0%, rgba(255, 105, 180, 0.1) 100%);
}

.like-button.liked .like-icon-wrapper {
  background: linear-gradient(135deg, rgba(255, 182, 193, 0.4) 0%, rgba(255, 105, 180, 0.3) 100%);
}

.fire-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 165, 0, 0.1) 100%);
}

.like-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.heart-icon, .fire-icon {
  font-size: 28rpx;
  line-height: 1;
  filter: drop-shadow(0 1rpx 2rpx rgba(0, 0, 0, 0.1));
}

.like-count-value, .popularity-value {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
}

.like-count-value {
  color: #ff69b4;
}

.popularity-value {
  color: #ff8c00;
}

.like-icon.liked {
  transform: scale(1.2);
}

.like-icon.animating {
  animation: heartBeat 0.5s ease-in-out;
}

@keyframes heartBeat {
  0% {
    transform: scale(1);
  }
  25% {
    transform: scale(1.4);
  }
  50% {
    transform: scale(1.1);
  }
  75% {
    transform: scale(1.3);
  }
  100% {
    transform: scale(1.2);
  }
}

.like-button.default .heart-icon,
.like-button.default .fire-icon {
  font-size: 32rpx;
}

.like-button.default .like-count-value,
.like-button.default .popularity-value {
  font-size: 26rpx;
}

.like-button.small .heart-icon,
.like-button.small .fire-icon {
  font-size: 24rpx;
}

.like-button.small .like-count-value,
.like-button.small .popularity-value {
  font-size: 20rpx;
}

.like-button.large .heart-icon,
.like-button.large .fire-icon {
  font-size: 40rpx;
}

.like-button.large .like-count-value,
.like-button.large .popularity-value {
  font-size: 30rpx;
}